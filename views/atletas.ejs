            <h1 class="my-4 seccionAtl">Seccion Atletas</h1>
        </div>
        <div class="col-6 d-flex flex-row-reverse">
            <a class="btn btn-primary border border-dark btn-lg col-6 my-4" href="/atletas/crear">
                <p class="haciaMembresia p-0 m-0">Nueva Membresía</p>
            </a>
            <a class="btn btn-primary border border-dark btn-lg col-6 my-4 me-4" href="/preparadores/registrar">
                <p class="haciaMembresia p-0 m-0">Afiliar Preparador</p>
            </a>
        </div>
    </div>
    <!-- Scrollbar superior sincronizado -->
    <div id="scroll-bar-top"><div id="scroll-bar-top-inner"></div></div>

    <div class="table-responsive" id="mydatatable-container">
        <table class="records_list table table-striped table-bordered border-dark table-hover" id="mydatatable">
            <thead class="bg-dark shadow-sm">
                <tr class="text-white">
                    <th scope="col" class="text-center py-3" style="width: 100px;">Acción</th>
                    <th scope="col" style="width: 50px;">IDFDFF</th>
                    <th scope="col" class="atl" style="min-width: 400px;">Atleta</th>
                    <th scope="col">Cedula</th>
                    <th scope="col">Pasaporte</th>
                    <th scope="col">Celular</th>
                    <th scope="col">Telefono</th>
                    <th scope="col">Email</th>
                    <th scope="col">Instagram</th>
                    <th scope="col">Categoria</th>
                    <th scope="col">Fecha Inscripcion</th>
                    <th scope="col">Renovacion</th>
                    <th scope="col">Nacionalidad</th>
                    <th scope="col">Pais</th>
                    <th scope="col">Provincia</th>
                    <th scope="col">Municipio</th>
                    <th scope="col">Sector</th>
                    <th scope="col">Calle</th>
                    <th scope="col">Postal</th>
                    <th scope="col">Nacimiento</th>
                    <th scope="col">Sexo</th>
                    <th scope="col">Peso</th>
                    <th scope="col">Estatura</th>
                    <th scope="col">Ocupacion</th>
                    <th scope="col">Gimnasio</th>
                    <th scope="col">Preparador</th>
                    <th scope="col">Cel Preparador</th>
                    <th scope="col">Email Preparador</th>
                </tr>
                <tr class="filter-row">
                    <td></td>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                    <th><input type="text" placeholder="Filtrar.."></th>
                </tr>
            </thead>
            <tbody>
                <% if (arrayAtletas.length > 0) { %>
                    <% arrayAtletas.forEach(atleta => { %>
                        <tr>
                            <!-- CAMBIO CLAVE: atleta.id en lugar de atleta._id -->
                             <!-- Cambiamos "atletas/crear/idfdff" por "atletas/id" -->
                            <td class="text-center">
                                <a href="/atletas/<%= atleta.id %>"
                                   class="btn btn-sm <%= atleta.estatus_afiliacion !== 'habilitado' ? 'btn-danger text-white fw-bold shadow' : 'btn-warning' %>"
                                >
                                    <%= atleta.estatus_afiliacion !== 'habilitado' ? 'PENDIENTE' : 'Editar' %>
                                </a>
                                <% if (atleta.url_comprobante_membresia && atleta.estatus_afiliacion === 'pendiente') { %>
                                    <button class="btn btn-sm btn-success ms-1 fw-bold"
                                            onclick="verComprobanteMem('<%= atleta.url_comprobante_membresia %>','<%= atleta.id %>','<%= atleta.nombre.replace(/'/g,`\\'`) %>')"
                                            title="Ver comprobante de transferencia">
                                        <i class="fas fa-file-invoice-dollar"></i>
                                    </button>
                                <% } %>
                            </td>
                            <th scope="row"><%= atleta.idfdff %></th>
                            <td class="fw-bold">
                                <%= atleta.nombre %>
                                <% if (atleta.estatus_afiliacion !== 'habilitado') { %>
                                    <span class="badge bg-danger ms-1 small shadow-sm"><i class="fas fa-clock"></i> PENDIENTE</span>
                                <% } else { %>
                                    <span class="badge bg-success ms-1 small shadow-sm"><i class="fas fa-check-circle"></i> OK</span>
                                <% } %>
                            </td>
                            <td><%= atleta.cedula %></td>
                            <td><%= atleta.pasaporte %></td>
                            <td><%= atleta.celular %></td>
                            <td><%= atleta.telfijo %></td>
                            <td><%= atleta.email %></td>
                            <td><%= atleta.instagram %></td>
                            <td><%= atleta.categoria %></td>
                            <td><%= atleta.fecha_inscripcion %></td>
                            <td><%= atleta.renovacion %></td>  
                            <td><%= atleta.nacionalidad %></td>
                            <td><%= atleta.pais %></td>
                            <td><%= atleta.provincia %></td>
                            <td><%= atleta.municipio %></td>
                            <!-- <td><%= atleta.ciudad %></td> -->
                            <td><%= atleta.sector %></td>
                            <td><%= atleta.calle %></td>
                            <td><%= atleta.postal %></td>                      
                            <td><%= atleta.fecha_nacimiento %></td>
                            <!-- <td><%= atleta.edad %></td>-->
                            <td><%= atleta.sexo %></td>
                            <td><%= atleta.peso %></td>
                            <td><%= atleta.estatura %></td>
                            <td><%= atleta.ocupacion %></td>
                            <td><%= atleta.gimnasio %></td>
                            <td><%= atleta.preparador %></td>
                            <td><%= atleta.celular_preparador %></td>
                            <td><%= atleta.email_preparador %></td>  
                        </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>

    <script type="text/javascript">
        $(document).ready(function () {
            var table = $('#mydatatable').DataTable({
                "dom": 'B<"float-left"i><"float-right"f>t<"float-left"l><"float-right"p><"clearfix">',
                "language": { "url": "https://cdn.datatables.net/plug-ins/1.10.19/i18n/Spanish.json" },
                "order": [[0, "desc"]],
                "orderCellsTop": true,  // solo la fila 0 del thead activa el sort
                "initComplete": function () {
                    var api = this.api();
                    var filterRow = $('#mydatatable thead tr.filter-row');

                    api.columns().every(function () {
                        var col = this;
                        var idx = col.index();
                        $('input', filterRow.children('th, td').eq(idx))
                            .on('keyup change', function () {
                                if (col.search() !== this.value) {
                                    col.search(this.value).draw();
                                }
                            });
                    });
                },
                "buttons": ['csv', 'excel', 'pdf', 'print']
            });

            // ── Scrollbar superior sincronizado ──────────────────────────────
            var scrollTop   = document.getElementById('scroll-bar-top');
            var scrollInner = document.getElementById('scroll-bar-top-inner');
            var tableWrap   = document.getElementById('mydatatable-container');

            function syncWidth() {
                scrollInner.style.width = tableWrap.scrollWidth + 'px';
            }
            syncWidth();
            $('#mydatatable').on('draw.dt', syncWidth);
            window.addEventListener('resize', syncWidth);

            scrollTop.addEventListener('scroll', function () {
                tableWrap.scrollLeft = scrollTop.scrollLeft;
            });
            tableWrap.addEventListener('scroll', function () {
                scrollTop.scrollLeft = tableWrap.scrollLeft;
            });
        });
    </script>
</div>

<!-- MODAL: Comprobante de Membresía -->
<div class="modal fade" id="modalComprobanteMem" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-success text-white py-3">
                <h5 class="modal-title fw-bold"><i class="fas fa-file-invoice-dollar me-2"></i>Comprobante de Membresía</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-4">
                <p class="fw-bold mb-3" id="memNombreAtleta"></p>
                <img id="imgComprobanteMem" src="" alt="Comprobante"
                     class="img-fluid rounded shadow mb-3" style="max-height:500px; border:1px solid #ddd;">
                <input type="hidden" id="memAtletaId">
            </div>
            <div class="modal-footer bg-light justify-content-between">
                <button type="button" onclick="rechazarMem()" class="btn btn-danger fw-bold">
                    <i class="fas fa-times me-1"></i> RECHAZAR
                </button>
                <div>
                    <button type="button" class="btn btn-secondary me-2" data-bs-dismiss="modal">Cerrar</button>
                    <button type="button" onclick="validarMem()" class="btn btn-success fw-bold px-4">
                        <i class="fas fa-check me-1"></i> ACTIVAR MEMBRESÍA
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const _modalMem = new bootstrap.Modal(document.getElementById('modalComprobanteMem'));

    function verComprobanteMem(url, atletaId, nombre) {
        document.getElementById('imgComprobanteMem').src = url;
        document.getElementById('memAtletaId').value     = atletaId;
        document.getElementById('memNombreAtleta').textContent = nombre;
        _modalMem.show();
    }

    async function validarMem() {
        const id = document.getElementById('memAtletaId').value;
        if (!confirm('¿Activar la membresía y confirmar el pago?')) return;
        const resp = await fetch('/admin/auditoria/validar-membresia', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ atleta_id: id })
        });
        const json = await resp.json();
        if (json.ok) { _modalMem.hide(); alert(json.mensaje); location.reload(); }
        else alert('Error: ' + json.error);
    }

    async function rechazarMem() {
        const id = document.getElementById('memAtletaId').value;
        const motivo = prompt('Motivo del rechazo:');
        if (!motivo) return;
        const resp = await fetch('/admin/auditoria/rechazar-membresia', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ atleta_id: id, motivo })
        });
        const json = await resp.json();
        if (json.ok) { _modalMem.hide(); location.reload(); }
        else alert('Error: ' + json.error);
    }
</script>

