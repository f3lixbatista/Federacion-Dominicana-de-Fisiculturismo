<%- include("template/cabecera", {tituloWeb: "Pagina de Atletas"}) %>

<style>
    /* Forzar títulos blancos sobre el fondo oscuro, anulando estilos de DataTables */
    #mydatatable thead th {
        color: white !important;
    }
</style>

<div class="p-2 divGeneral">
    <div class="row g-2">
        <div class="col-6">
            <h1 class="my-4 seccionAtl">Seccion Atletas</h1>
        </div>
        <div class="col-6 d-flex flex-row-reverse">
            <a class="btn btn-primary border border-dark btn-lg col-6 my-4" href="/atletas/crear">
                <p class="haciaMembresia p-0 m-0">Nueva Membresía</p>
            </a>
            <a class="btn btn-primary border border-dark btn-lg col-6 my-4 me-4" href="/preparadores/registrar">
                <p class="haciaMembresia p-0 m-0">Afiliar Preparador</p>
            </a>
        </div>
    </div>
    <div class="table-responsive" id="mydatatable-container">
        <table class="records_list table table-striped table-bordered border-dark table-hover" id="mydatatable">
            <thead class="bg-dark shadow-sm">
                <tr class="text-white">
                    <th scope="col" class="text-center py-3" style="width: 100px;">Acción</th>
                    <th scope="col" style="width: 50px;">IDFDFF</th>
                    <th scope="col" class="atl" style="min-width: 400px;">Atleta</th>
                    <th scope="col">Cedula</th>
                    <th scope="col">Pasaporte</th>
                    <th scope="col">Celular</th>
                    <th scope="col">Telefono</th>
                    <th scope="col">Email</th>
                    <th scope="col">Instagram</th>
                    <th scope="col">Categoria</th>
                    <th scope="col">Fecha Inscripcion</th>
                    <th scope="col">Renovacion</th>
                    <th scope="col">Nacionalidad</th>
                    <th scope="col">Pais</th>
                    <th scope="col">Provincia</th>
                    <th scope="col">Municipio</th>
                    <!-- <th scope="col">Ciudad</th> -->
                    <th scope="col">Sector</th>
                    <th scope="col">Calle</th>
                    <th scope="col">Postal</th>
                    <th scope="col">Nacimiento</th>
                     <!--  <th scope="col">Edad</th>-->
                    <th scope="col">Sexo</th>
                    <th scope="col">Peso</th>
                    <th scope="col">Estatura</th>
                    <th scope="col">Ocupacion</th>
                    <th scope="col">Gimnasio</th>
                    <th scope="col">Preparador</th>
                    <th scope="col">Cel Preparador</th>
                    <th scope="col">Email Preparador</th>
            
                </tr>
            </thead>
             <tfoot>
                <tr>
                    <td></td>
                    <th>Filter..</th>
                    <th>Filter..</th>
                    <th class= "col col-md-8">Filter..</th>
                    <th>Filter..</th>
                    <th>Filter..</th>
                    <th>Filter..</th>
                    <th>Filter..</th>
                    <th>Filter..</th>
                    <th>Filter..</th>
                    <th>Filter..</th>
                    <th>Filter..</th>
                    <th>Filter..</th>
                    <th>Filter..</th>
                    <th>Filter..</th>
                    <th>Filter..</th>
                    <th>Filter..</th>
                    <th>Filter..</th>
                    <th>Filter..</th>
                    <th>Filter..</th>
                    <th>Filter..</th>
                    <th>Filter..</th>
                    <th>Filter..</th>
                    <th>Filter..</th>
                    <th>Filter..</th>
                    <th>Filter..</th>
                    <th>Filter..</th>
                    <th>Filter..</th>
                </tr>
            </tfoot>
            <tbody>
                <% if (arrayAtletas.length > 0) { %>
                    <% arrayAtletas.forEach(atleta => { %>
                        <tr>
                            <!-- CAMBIO CLAVE: atleta.id en lugar de atleta._id -->
                             <!-- Cambiamos "atletas/crear/idfdff" por "atletas/id" -->
                            <td>
                                <a href="/atletas/<%= atleta.id %>" 
                                   class="btn btn-sm <%= atleta.estatus_afiliacion !== 'habilitado' ? 'btn-danger text-white fw-bold shadow' : 'btn-warning' %>"
                                >
                                    <%= atleta.estatus_afiliacion !== 'habilitado' ? 'PENDIENTE' : 'Editar' %>
                                </a>
                            </td>
                            <th scope="row"><%= atleta.idfdff %></th>
                            <td class="fw-bold">
                                <%= atleta.nombre %>
                                <% if (atleta.estatus_afiliacion !== 'habilitado') { %>
                                    <span class="badge bg-danger ms-1 small shadow-sm"><i class="fas fa-clock"></i> PENDIENTE</span>
                                <% } else { %>
                                    <span class="badge bg-success ms-1 small shadow-sm"><i class="fas fa-check-circle"></i> OK</span>
                                <% } %>
                            </td>
                            <td><%= atleta.cedula %></td>
                            <td><%= atleta.pasaporte %></td>
                            <td><%= atleta.celular %></td>
                            <td><%= atleta.telfijo %></td>
                            <td><%= atleta.email %></td>
                            <td><%= atleta.instagram %></td>
                            <td><%= atleta.categoria %></td>
                            <td><%= atleta.fecha_inscripcion %></td>
                            <td><%= atleta.renovacion %></td>  
                            <td><%= atleta.nacionalidad %></td>
                            <td><%= atleta.pais %></td>
                            <td><%= atleta.provincia %></td>
                            <td><%= atleta.municipio %></td>
                            <!-- <td><%= atleta.ciudad %></td> -->
                            <td><%= atleta.sector %></td>
                            <td><%= atleta.calle %></td>
                            <td><%= atleta.postal %></td>                      
                            <td><%= atleta.fecha_nacimiento %></td>
                            <!-- <td><%= atleta.edad %></td>-->
                            <td><%= atleta.sexo %></td>
                            <td><%= atleta.peso %></td>
                            <td><%= atleta.estatura %></td>
                            <td><%= atleta.ocupacion %></td>
                            <td><%= atleta.gimnasio %></td>
                            <td><%= atleta.preparador %></td>
                            <td><%= atleta.celular_preparador %></td>
                            <td><%= atleta.email_preparador %></td>  
                        </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>

    <!-- Scripts de DataTables (se mantienen igual) -->
    <script type="text/javascript">
        $(document).ready(function () {
            $('#mydatatable tfoot th').each(function () {
                $(this).html('<input type="text" placeholder="Filtrar.." />');
            });
            var table = $('#mydatatable').DataTable({
                "dom": 'B<"float-left"i><"float-right"f>t<"float-left"l><"float-right"p><"clearfix">',
                "language": { "url": "https://cdn.datatables.net/plug-ins/1.10.19/i18n/Spanish.json" },
                "order": [[0, "desc"]],

                "initComplete": function () {
                    this.api().columns().every(function () {
                        var that = this;
    
                        $('input', this.footer()).on('keyup change', function () {
                            if (that.search() !== this.value) {
                                that
                                    .search(this.value)
                                    .draw();
                            }
                        });
                    })
                },
                "buttons": ['csv', 'excel', 'pdf', 'print']
            });
        });
    </script>
</div>
<%- include("template/footer") %>
