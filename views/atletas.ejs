<%- include("template/cabecera", {tituloWeb: "Pagina de Atletas"}) %>

<style>
    #mydatatable thead tr:first-child th { color: white !important; }
    #mydatatable thead tr.filter-row th,
    #mydatatable thead tr.filter-row td { background: #343a40; padding: 4px 6px; }
    #mydatatable thead tr.filter-row input {
        width: 100%; font-size: .78rem; padding: 2px 5px;
        border: 1px solid #6c757d; border-radius: 4px;
        background: #495057; color: #fff;
    }
    #mydatatable thead tr.filter-row input::placeholder { color: #adb5bd; }
    /* Scrollbar superior sincronizado */
    #scroll-bar-top {
        overflow-x: scroll; overflow-y: hidden;
        height: 14px; margin-bottom: 3px;
        border-radius: 4px;
    }
    #scroll-bar-top-inner { height: 1px; }
</style>

<div class="p-2 divGeneral">
