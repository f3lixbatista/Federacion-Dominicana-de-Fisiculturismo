<%- include("template/cabecera", {tituloWeb: "Detalle de Atleta"}) %>
 
    <% if (error) { %>
        <div class="container mt-5 text-center">
            <p class="alert alert-danger"><%= mensaje %></p>
            <a href="/atletas" class="btn btn-warning">Volver a Atletas</a>
        </div>
    <% } %>

    <% if (!error) { %>
        <div class="container border border-primary border-3 mt-5 p-4">
            <!-- Usamos el id de Supabase para la ruta -->
            <form id="formularioEditar" class="row g-3 needs-validation was-validated" data-id="<%= atleta.id %>">
                
                <h6 class="position-relative mt-4 opacity-50">Datos del Atleta</h6>
                
                <div class="col-md-3">
                    <label class="form-label">ID FDFF</label>
                    <input value="<%= atleta.idfdff %>" type="number" class="form-control" name="idfdff" required>
                </div>

               
            <div class="col-md-3">
                <label class="form-label">Fecha de Inscripción</label>
                <!-- CAMBIO: type="date" y nombre minúsculas. Usamos el helper de JS para la fecha de hoy -->
                <input type="date" class="form-control" name="fecha_inscripcion" value="<%= new Date().toISOString().split('T')[0] %>" required>
            </div>

            <div class="col-md-6">
                <label class="form-label">Nombre(s) y Apellido(s)</label>
                <input value="<%= atleta.nombre %>" type="text" class="form-control" name="nombre" placeholder="Según documento" required>
            </div>

            <div class="col-md-3">
                <label class="form-label">Cédula</label>
                <input value="<%= atleta.cedula %>" type="number" class="form-control" name="cedula" required>
            </div>

            <div class="col-md-3">
                <label class="form-label">Pasaporte</label>
                <input value="<%= atleta.pasaporte %>" type="text" class="form-control" name="pasaporte">
            </div>

            <div class="col-md-3">
                <label class="form-label">Nacionalidad</label>
                <input value="<%= atleta.nacionalidad %>" type="text" value="Dominicana" class="form-control" name="nacionalidad" required>
            </div>

            <div class="col-md-3">
                <label class="form-label">Fecha de Nacimiento</label>
                <input value="<%= atleta.nacimiento %>" type="date" class="form-control" name="nacimiento" required>
            </div>

             <!--<div class="col-md-3">
                <label class="form-label">Edad</label>
                <input value="<%= atleta.edad %>" type="number" class="form-control" name="edad" required>
            </div>-->

            <div class="col-md-2">
                <label class="form-label">Sexo</label>
                <input value="<%= atleta.sexo %>" type="text" class="form-control" name="sexo" required>
            </div>

            <div class="col-md-5">
                <label class="form-label">Ocupación</label>
                <input value="<%= atleta.ocupacion %>" type="text" class="form-control" name="ocupacion">
            </div>

            <h6 class="position-relative mt-5 opacity-50">De la Residencia</h6>
            
            <div class="col-md-6">
                <label class="form-label">Calle y Número</label>
                <input value="<%= atleta.calle %>" type="text" class="form-control" name="calle" required>
            </div>

            <div class="col-md-3">
                <label class="form-label">Sector/Barrio</label>
                <input value="<%= atleta.sector %>" type="text" class="form-control" name="sector" required>
            </div>

           <!--  <div class="col-md-3">
                <label class="form-label">Ciudad</label>
                <input value="<%= atleta.ciudad %>" type="text" class="form-control" name="ciudad" required>
            </div> -->

            <div class="col-md-3">
                <label class="form-label">Municipio</label>
                <input value="<%= atleta.municipio %>" type="text" class="form-control" name="municipio" required>
            </div>

            <div class="col-md-4">
                <label class="form-label">Provincia</label>
                <input value="<%= atleta.provincia %>" type="text" class="form-control" name="provincia" required>
            </div>

            <div class="col-md-4">
                <label class="form-label">País</label>
                <input value="<%= atleta.pais %>" type="text" class="form-control" name="pais" value="Republica Dominicana" required>
            </div>

            <div class="col-md-4">
                <label class="form-label">Código Postal</label>
                <input value="<%= atleta.postal %>" type="number" class="form-control" name="postal">
            </div>

            <div class="col-md-4">
                <label class="form-label">Celular</label>
                <input value="<%= atleta.celular %>" type="tel" class="form-control" name="celular">
            </div>

            <div class="col-md-3 py-0 pt-0  mb-4">
                        <label for="validationTooltip05" class="form-label">Telefono Residencial</label>
                        <input value="<%= atleta.telfijo %>" type="tel" class="form-control" name="telfijo" id="validationTooltip05" required="true">
                        <div class="invalid-tooltip">
                            Telefono Alterno
                        </div>
                    </div>

            <div class="col-md-4">
                <label class="form-label">Correo Electronico</label>
                <input value="<%= atleta.email %>" type="email" class="form-control" name="email">
            </div>

            <div class="col-md-4">
                <label class="form-label">Instagram</label>
                <input value="<%= atleta.instagram %>" type="text" class="form-control" name="instagram">
            </div>

            <div class="col-md-4">
                <label class="form-label">Categoria</label>
                <input value="<%= atleta.categoria %>" type="text" class="form-control" name="categoria" id="validationTooltip05" required>
            </div>

            <div class="col-md-4">
                <label class="form-label">Estatura en Centimetros</label>
                <input value="<%= atleta.estatura %>" type="number" step="0.01" min="0" class="form-control" name="estatura" id="validationTooltip05" required>
            </div>

            <div class="col-md-4">
                <label class="form-label">Peso en Kilos</label>
                <input value="<%= atleta.peso %>" type="number" step="0.01" min="0" class="form-control" name="peso" id="validationTooltip05" required>
            </div>

            <div class="col-md-4">
                <label class="form-label">Gimnasio</label>
                <input value="<%= atleta.gimnasio %>" type="text" class="form-control" name="gimnasio" id="validationTooltip05" required>
            </div>

            <div class="col-md-4">
                <label class="form-label">Preparador</label>
                <input value="<%= atleta.preparador %>" type="text" class="form-control" name="preparador" id="validationTooltip05" required>
            </div>

            <div class="col-md-4">
                <label class="form-label">Celular del Preparador</label>
                <input value="<%= atleta.celular_preparador %>" type="tel" class="form-control" name="celular_preparador">
            </div>

            <div class="col-md-4">
                <label class="form-label">Email del Preparador</label>
                <input value="<%= atleta.email_preparador %>" type="email" class="form-control" name="email_preparador">
            </div>

                <div class="col-12 mt-5 d-flex gap-2">
                    <button class="btn btn-warning flex-grow-1" type="submit">Actualizar Datos</button>
                    <button type="button" class="btn btn-danger flex-grow-1" id="btnEliminar" data-id="<%= atleta.id %>">Eliminar Atleta</button>
                </div>
            </form>
        </div>
    <% } %>

<%- include("template/footer") %>

<script>
    // Lógica para ELIMINAR (DELETE)
    const btnEliminar = document.querySelector('#btnEliminar');
    if(btnEliminar) {
        btnEliminar.addEventListener('click', async () => {
            const id = btnEliminar.dataset.id;
            const confirmar = confirm('¿Estás seguro de eliminar este registro permanentemente?');
            
            if(confirmar) {
                try {
                    const res = await fetch(`/atletas/${id}`, { method: 'DELETE' });
                    const resData = await res.json();
                    
                    if(resData.estado) {
                        window.location.href = '/atletas';
                    } else {
                        alert('Error: ' + resData.mensaje);
                    }
                } catch (e) {
                    console.error("Error en el fetch de eliminación", e);
                }
            }
        });
    }

    // Lógica para EDITAR (PUT)
    const formularioEditar = document.querySelector('#formularioEditar');
    if(formularioEditar) {
        formularioEditar.addEventListener('submit', async (e) => {
            e.preventDefault();
            const id = formularioEditar.dataset.id;
            
            // Creamos un objeto con todos los campos del formulario automáticamente
            const formData = new FormData(formularioEditar);
            const dataObject = Object.fromEntries(formData.entries());

            try {
                const res = await fetch(`/atletas/${id}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(dataObject)
                });
                
                const resData = await res.json();
                
                if(resData.estado) {
                    alert('Atleta actualizado con éxito');
                    window.location.href = '/atletas';
                } else {
                    alert('No se pudo actualizar: ' + resData.mensaje);
                }
            } catch (e) {
                console.error("Error en el fetch de actualización", e);
            }
        });
    }
</script>
