<%- include("template/cabecera", {tituloWeb: "Detalle de Atleta"}) %>
 
    <% if (error) { %>
        <div class="container mt-5 text-center">
            <p class="alert alert-danger"><%= mensaje %></p>
            <a href="/atletas" class="btn btn-warning">Volver a Atletas</a>
        </div>
    <% } %>

    <% if (!error) { %>
        <div class="container border border-primary border-3 mt-5 p-4">
            <!-- Usamos el id de Supabase para la ruta -->
            <form id="formularioEditar" class="row g-3 needs-validation was-validated" data-id="<%= atleta.id %>">
                
                <h6 class="position-relative mt-4 opacity-50">Datos del Atleta</h6>
                
                <div class="col-md-3">
                    <label class="form-label">ID FDFF</label>
                    <input value="<%= atleta.idfdff %>" type="number" class="form-control" name="idfdff" required>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Fecha Inscripción</label>
                    <!-- Asegúrate que el formato sea YYYY-MM-DD para que el input date lo reconozca -->
                    <input type="date" value="<%= atleta.fecha_inscripcion %>" class="form-control" name="fecha_inscripcion" required>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Nombre Completo</label>
                    <input value="<%= atleta.nombre %>" type="text" class="form-control" name="nombre" required>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Cédula</label>
                    <input value="<%= atleta.cedula %>" type="number" class="form-control" name="cedula" required>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Pasaporte</label>
                    <input value="<%= atleta.pasaporte %>" type="text" class="form-control" name="pasaporte">
                </div>

                <div class="col-md-4">
                    <label class="form-label">Nacionalidad</label>
                    <input value="<%= atleta.nacionalidad %>" type="text" class="form-control" name="nacionalidad">
                </div>

                <h6 class="position-relative mt-5 opacity-50">Contacto y Ubicación</h6>

                <div class="col-md-6">
                    <label class="form-label">Email</label>
                    <input value="<%= atleta.email %>" type="email" class="form-control" name="email">
                </div>

                <div class="col-md-6">
                    <label class="form-label">Instagram</label>
                    <input value="<%= atleta.instagram %>" type="text" class="form-control" name="instagram">
                </div>

                <div class="col-md-4">
                    <label class="form-label">Provincia</label>
                    <input value="<%= atleta.provincia %>" type="text" class="form-control" name="provincia">
                </div>

                <div class="col-md-4">
                    <label class="form-label">Municipio</label>
                    <input value="<%= atleta.municipio %>" type="text" class="form-control" name="municipio">
                </div>

                <div class="col-md-4">
                    <label class="form-label">Sector</label>
                    <input value="<%= atleta.sector %>" type="text" class="form-control" name="sector">
                </div>

                <div class="col-12 mt-5 d-flex gap-2">
                    <button class="btn btn-warning flex-grow-1" type="submit">Actualizar Datos</button>
                    <button type="button" class="btn btn-danger flex-grow-1" id="btnEliminar" data-id="<%= atleta.id %>">Eliminar Atleta</button>
                </div>
            </form>
        </div>
    <% } %>

<%- include("template/footer") %>

<script>
    // Lógica para ELIMINAR (DELETE)
    const btnEliminar = document.querySelector('#btnEliminar');
    if(btnEliminar) {
        btnEliminar.addEventListener('click', async () => {
            const id = btnEliminar.dataset.id;
            const confirmar = confirm('¿Estás seguro de eliminar este registro permanentemente?');
            
            if(confirmar) {
                try {
                    const res = await fetch(`/atletas/${id}`, { method: 'DELETE' });
                    const resData = await res.json();
                    
                    if(resData.estado) {
                        window.location.href = '/atletas';
                    } else {
                        alert('Error: ' + resData.mensaje);
                    }
                } catch (e) {
                    console.error("Error en el fetch de eliminación", e);
                }
            }
        });
    }

    // Lógica para EDITAR (PUT)
    const formularioEditar = document.querySelector('#formularioEditar');
    if(formularioEditar) {
        formularioEditar.addEventListener('submit', async (e) => {
            e.preventDefault();
            const id = formularioEditar.dataset.id;
            
            // Creamos un objeto con todos los campos del formulario automáticamente
            const formData = new FormData(formularioEditar);
            const dataObject = Object.fromEntries(formData.entries());

            try {
                const res = await fetch(`/atletas/${id}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(dataObject)
                });
                
                const resData = await res.json();
                
                if(resData.estado) {
                    alert('Atleta actualizado con éxito');
                    window.location.href = '/atletas';
                } else {
                    alert('No se pudo actualizar: ' + resData.mensaje);
                }
            } catch (e) {
                console.error("Error en el fetch de actualización", e);
            }
        });
    }
</script>
