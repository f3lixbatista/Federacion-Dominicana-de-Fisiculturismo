<%- include("template/cabecera", {tituloWeb: "Incluir Categorías"}) %>

    <div class="container container-fluid p-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold">Configurar Categorías del Evento</h2>
            <a class="btn btn-dark" href="/categorias/crearCategoria">
                Nueva Categoría Base
            </a>
        </div>

        <div class="table-responsive" id="mydatatable-container">
            <table class="records_list table table-striped table-bordered table-hover" id="mydatatable">
                <thead class="table-dark">
                  <tr>
                    <th scope="col">Orden de Salida</th>
                    <th scope="col">Nombre del Evento / Categoría</th>
                    <th scope="col">Acción</th>
                  </tr>
                </thead>
                <tbody>
                    <% if (arrayEvento && arrayEvento.length > 0) { %>
                        <% arrayEvento.forEach(evento => { %>
                            <tr>
                                <!-- Usamos minúsculas segun las columnas de Supabase -->
                                <td class="text-center fw-bold"><%= evento.salida %></td>
                                <td><%= evento.nombre %> - <%= evento.categoria %></td>
                                <td class="text-center">
                                    <a href="/categorias/editar/<%= evento.id %>" class="btn btn-sm btn-outline-primary">
                                        Ajustar Parámetros
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="3" class="text-center">No hay eventos configurados.</td>
                        </tr>
                    <% } %>
                </tbody>
                <tfoot>
                    <tr>
                        <th>Filtrar..</th>
                        <th>Filtrar..</th>
                        <td></td> 
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="mt-4">
            <button class="btn btn-primary btn-lg w-100" type="button" onclick="window.location.href='/categorias/nuevoEvento'">
                Agregar Más Categorías a un Evento
            </button> 
        </div>

        <script type="text/javascript">
            $(document).ready(function () {
                // Filtros por columna
                $('#mydatatable tfoot th').each(function () {
                    $(this).html('<input type="text" class="form-control form-control-sm" placeholder="Buscar..." />');
                });
        
                var table = $('#mydatatable').DataTable({
                    "dom": 'Bfrtip',
                    "responsive": true,
                    "language": {
                        "url": "https://cdn.datatables.net/plug-ins/1.10.19/i18n/Spanish.json"
                    },
                    "order": [[0, "asc"]], // Ordenar por salida ascendente
                    "buttons": ['csv', 'excel', 'pdf', 'print']
                });

                table.columns().every(function () {
                    var that = this;
                    $('input', this.footer()).on('keyup change', function () {
                        if (that.search() !== this.value) {
                            that.search(this.value).draw();
                        }
                    });
                });
            });
        </script>
    </div>

<%- include("template/footer") %>
