<%- include("../template/cabecera", {tituloWeb: "Procesando Sesión..."}) %>
<div class="container text-center py-5">
    <div class="spinner-border text-primary" role="status"></div>
    <p class="mt-3">Sincronizando acceso, por favor espere...</p>
</div>

<script src="/js/supabase.js"></script>
<script>
    const _supabase = supabase.createClient("<%= SUPABASE_URL %>", "<%= SUPABASE_ANON_KEY %>");

    // El evento SIGNED_IN se dispara automáticamente cuando Supabase detecta el token en el fragmento (#)
    _supabase.auth.onAuthStateChange(async (event, session) => {
        if (session) {
            // 1. Sincronizamos con el servidor Express para crear la cookie
            await fetch('/set-session', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ session })
            });

            // 2. Lógica de redirección basada en el tipo de evento
            if (event === 'PASSWORD_RECOVERY') {
                window.location.href = '/reset-password';
            } else {
                window.location.href = '/';
            }
        } else {
            // Si no hay sesión, algo falló o el link expiró
            window.location.href = '/login?error=link_expirado';
        }
    });
</script>
<%- include("../template/footer") %>