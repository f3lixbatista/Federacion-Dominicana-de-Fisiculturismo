<%- include("../template/cabecera", {tituloWeb: "Iniciar Sesión - FDFF"}) %>

<style>
  /* Ocultar chrome de layout en la página de login */
  #topbar, #sidebar, #sb-overlay { display: none !important; }
  #main-content {
    margin: 0 !important;
    padding: 0 !important;
    width: 100vw;
    min-height: 100vh;
    display: flex;
  }

  /* ── Tokens ── */
  .login-root {
    --lbg:      #040D1E;
    --lbg2:     #060F20;
    --lacent:   #00E5C8;
    --ltext:    #EAE8F0;
    --lmuted:   rgba(234,232,240,.42);
    --linput:   rgba(255,255,255,.05);
    --lborder:  rgba(0,229,200,.13);
    --lborder2: rgba(255,255,255,.08);
  }

  .login-root {
    display: flex;
    width: 100%;
    min-height: 100vh;
    background: var(--lbg);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
  }

  /* ══ PANEL IZQUIERDO ══ */
  .lr-left {
    width: 42%;
    background: var(--lbg);
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 2.75rem 2.5rem;
    overflow: hidden;
  }
  .lr-left::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,229,200,.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,229,200,.05) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
  }
  .lr-left::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 50% at 20% 70%, rgba(0,229,200,.09) 0%, transparent 65%),
      radial-gradient(ellipse 50% 40% at 80% 15%, rgba(0,80,200,.07) 0%, transparent 60%);
    pointer-events: none;
  }
  .lr-left-top, .lr-left-mid, .lr-left-bot { position: relative; z-index: 1; }
  .lr-left-mid { flex: 1; display: flex; align-items: center; }

  /* Logo */
  .lr-logo { display: flex; align-items: center; gap: .85rem; }
  .lr-logo-circle {
    width: 46px; height: 46px; border-radius: 50%;
    background: rgba(0,229,200,.12);
    border: 1.5px solid rgba(0,229,200,.35);
    display: flex; align-items: center; justify-content: center;
    font-size: .62rem; font-weight: 900; color: var(--lacent);
    letter-spacing: .06em;
  }
  .lr-logo-text { color: var(--ltext); font-size: .78rem; font-weight: 700; line-height: 1.25; }
  .lr-logo-text small {
    color: var(--lmuted); font-weight: 400;
    font-size: .6rem; letter-spacing: .06em; display: block; margin-top: 1px;
  }

  /* Tagline */
  .lr-tagline {
    font-size: 2rem; font-weight: 800;
    color: var(--ltext); line-height: 1.15; letter-spacing: -.03em;
  }
  .lr-tagline em { font-style: normal; color: var(--lacent); }

  /* Chip */
  .lr-chip {
    display: inline-flex; align-items: center; gap: .45rem;
    background: rgba(0,229,200,.08); border: 1px solid rgba(0,229,200,.2);
    border-radius: 20px; padding: .28rem .75rem;
    font-size: .62rem; color: var(--lacent); font-weight: 700;
    letter-spacing: .08em; text-transform: uppercase; margin-top: 2rem;
  }
  .lr-chip::before { content:''; width: 6px; height: 6px; border-radius: 50%; background: var(--lacent); }

  .lr-foot {
    font-size: .6rem; color: rgba(234,232,240,.2);
    letter-spacing: .09em; text-transform: uppercase;
  }

  /* Divisor vertical */
  .lr-divider {
    width: 1px;
    background: linear-gradient(180deg,
      transparent 5%,
      rgba(0,229,200,.15) 30%,
      rgba(0,229,200,.15) 70%,
      transparent 95%);
  }

  /* ══ PANEL DERECHO ══ */
  .lr-right {
    flex: 1; background: var(--lbg2);
    display: flex; align-items: center; justify-content: center;
    padding: 2.5rem 2rem;
    position: relative; overflow: hidden;
  }
  .lr-right::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 60% 50% at 60% 40%, rgba(0,229,200,.04), transparent);
    pointer-events: none;
  }

  .lr-form-wrap { position: relative; z-index: 1; width: 100%; max-width: 360px; }

  /* Alerta */
  #alertaAuth {
    border-radius: 8px; padding: .6rem .9rem;
    font-size: .78rem; margin-bottom: 1.25rem;
  }
  #alertaAuth.lr-alert-danger  { background: rgba(239,83,80,.12); border: 1px solid rgba(239,83,80,.3); color: #ef5350; }
  #alertaAuth.lr-alert-success { background: rgba(0,229,200,.10); border: 1px solid rgba(0,229,200,.25); color: var(--lacent); }
  #alertaAuth.lr-alert-warning { background: rgba(255,193,7,.10); border: 1px solid rgba(255,193,7,.25); color: #ffc107; }

  /* Títulos del form */
  .lr-form-eyebrow {
    font-size: .62rem; letter-spacing: .14em; text-transform: uppercase;
    color: rgba(0,229,200,.7); margin-bottom: 1.25rem;
    display: flex; align-items: center; gap: .5rem;
  }
  .lr-form-eyebrow::before { content:''; width: 18px; height: 1px; background: rgba(0,229,200,.5); }

  .lr-form-title {
    font-size: 1.65rem; font-weight: 800;
    color: var(--ltext); letter-spacing: -.025em;
    line-height: 1.15; margin-bottom: .3rem; text-wrap: balance;
  }
  .lr-form-sub { font-size: .75rem; color: var(--lmuted); margin-bottom: 1.75rem; }

  /* Labels */
  .lr-label {
    display: block; font-size: .65rem;
    letter-spacing: .1em; text-transform: uppercase;
    color: var(--lmuted); margin-bottom: .35rem;
  }

  /* Inputs */
  .lr-input-wrap { position: relative; margin-bottom: 1rem; }
  .lr-input {
    width: 100%; background: var(--linput);
    border: 1px solid var(--lborder); border-radius: 6px;
    padding: .65rem .85rem; color: var(--ltext);
    font-size: .84rem; font-family: inherit; outline: none;
    transition: border-color .15s, background .15s;
  }
  .lr-input:focus { border-color: rgba(0,229,200,.45); background: rgba(0,229,200,.04); }
  .lr-input::placeholder { color: rgba(234,232,240,.2); }
  .lr-input.has-eye { padding-right: 2.5rem; }

  /* Toggle visibilidad */
  .lr-eye {
    position: absolute; right: .75rem; top: 50%; transform: translateY(-50%);
    background: none; border: none; color: rgba(234,232,240,.3);
    cursor: pointer; padding: 0; font-size: .85rem; line-height: 1;
    transition: color .15s;
  }
  .lr-eye:hover { color: rgba(234,232,240,.65); }

  /* Botón principal */
  .lr-btn {
    width: 100%; background: var(--lacent); color: var(--lbg);
    border: none; border-radius: 6px; padding: .72rem;
    font-size: .82rem; font-weight: 800; letter-spacing: .04em;
    cursor: pointer; transition: opacity .15s; margin-top: .25rem;
    display: flex; align-items: center; justify-content: center; gap: .5rem;
    font-family: inherit;
  }
  .lr-btn:hover { opacity: .88; }
  .lr-btn:disabled { opacity: .45; cursor: default; }

  /* Divisor OR */
  .lr-or {
    display: flex; align-items: center; gap: .75rem; margin: 1.1rem 0;
  }
  .lr-or::before, .lr-or::after { content:''; flex:1; height:1px; background: var(--lborder2); }
  .lr-or span { font-size: .62rem; color: rgba(255,255,255,.2); }

  /* Botones sociales */
  .lr-socials { display: flex; gap: .6rem; }
  .lr-social-btn {
    flex: 1; border: 1px solid var(--lborder2); border-radius: 6px;
    background: rgba(255,255,255,.04); padding: .55rem .5rem;
    font-size: .72rem; color: rgba(234,232,240,.5);
    cursor: pointer; text-align: center; font-weight: 600;
    font-family: inherit;
    transition: border-color .15s, background .15s, color .15s;
  }
  .lr-social-btn:hover { border-color: rgba(255,255,255,.2); background: rgba(255,255,255,.07); color: rgba(234,232,240,.8); }

  /* Links inferiores */
  .lr-links { display: flex; justify-content: space-between; margin-top: 1.25rem; }
  .lr-link {
    font-size: .7rem; color: rgba(0,229,200,.55);
    background: none; border: none; cursor: pointer;
    font-family: inherit; padding: 0; transition: color .15s;
  }
  .lr-link:hover { color: var(--lacent); }

  /* Spinner */
  @keyframes lr-spin { to { transform: rotate(360deg); } }
  .lr-spinner {
    width: 13px; height: 13px; border-radius: 50%;
    border: 2px solid rgba(4,13,30,.3);
    border-top-color: var(--lbg);
    animation: lr-spin .6s linear infinite;
    display: inline-block;
  }

  /* ── Responsive ── */
  @media (max-width: 700px) {
    .lr-left, .lr-divider { display: none; }
    .lr-right { min-height: 100vh; padding: 2rem 1.25rem; background: var(--lbg); }
  }
</style>

<div class="login-root">

  <!-- ── PANEL IZQUIERDO: Identidad FDFF ── -->
  <div class="lr-left">
    <div class="lr-left-top">
      <div class="lr-logo">
        <div class="lr-logo-circle">FDFF</div>
        <div class="lr-logo-text">
          Federación Dominicana
          <small>de Fisiculturismo · IFBB</small>
        </div>
      </div>
    </div>

    <div class="lr-left-mid">
      <div>
        <div class="lr-tagline">
          La plataforma del<br>
          <em>fisiculturismo</em><br>
          dominicano.
        </div>
        <div class="lr-chip">Sistema federativo activo</div>
      </div>
    </div>

    <div class="lr-left-bot">
      <div class="lr-foot">FDFF · Sistema v3.7 · Temporada 2026</div>
    </div>
  </div>

  <div class="lr-divider"></div>

  <!-- ── PANEL DERECHO: Formulario ── -->
  <div class="lr-right">
    <div class="lr-form-wrap">

      <div id="alertaAuth" style="display:none;"></div>

      <!-- LOGIN -->
      <form id="formLogin" onsubmit="loginUsuario(event)">
        <div class="lr-form-eyebrow">Acceso al sistema</div>
        <h2 class="lr-form-title">Bienvenido<br>de vuelta.</h2>
        <p class="lr-form-sub">Ingresa con tu cuenta registrada</p>

        <label class="lr-label">Correo electrónico</label>
        <div class="lr-input-wrap">
          <input type="email" id="email" class="lr-input" placeholder="nombre@ejemplo.com" required autocomplete="username">
        </div>

        <label class="lr-label">Contraseña</label>
        <div class="lr-input-wrap">
          <input type="password" id="password" class="lr-input has-eye" placeholder="••••••••" required autocomplete="current-password">
          <button type="button" class="lr-eye" onclick="togglePass('password','ojo-login')">
            <i id="ojo-login" class="far fa-eye"></i>
          </button>
        </div>

        <button type="submit" id="btnLogin" class="lr-btn">Iniciar Sesión →</button>

        <div class="lr-or"><span>o continúa con</span></div>
        <div class="lr-socials">
          <button type="button" class="lr-social-btn" onclick="loginConRedSocial('google')">Google</button>
          <button type="button" class="lr-social-btn" onclick="loginConRedSocial('facebook')">Facebook</button>
        </div>

        <div class="lr-links">
          <button type="button" class="lr-link" onclick="recuperarPassword()">¿Olvidaste tu contraseña?</button>
          <button type="button" class="lr-link" onclick="mostrarRegistro()">Crear cuenta</button>
        </div>
      </form>

      <!-- REGISTRO -->
      <form id="formRegistro" style="display:none;" onsubmit="registrarUsuario(event)">
        <div class="lr-form-eyebrow">Nueva cuenta</div>
        <h2 class="lr-form-title">Regístrate.</h2>
        <p class="lr-form-sub">Crea tu acceso al sistema FDFF</p>

        <label class="lr-label">Nombre completo</label>
        <div class="lr-input-wrap">
          <input type="text" id="regNombre" class="lr-input" placeholder="Juan Pérez" required>
        </div>

        <label class="lr-label">Correo electrónico</label>
        <div class="lr-input-wrap">
          <input type="email" id="regEmail" class="lr-input" placeholder="nombre@ejemplo.com" required autocomplete="email">
        </div>

        <label class="lr-label">Contraseña</label>
        <div class="lr-input-wrap">
          <input type="password" id="regPassword" class="lr-input has-eye" placeholder="Mínimo 6 caracteres" required minlength="6" autocomplete="new-password">
          <button type="button" class="lr-eye" onclick="togglePass('regPassword','ojo-reg')">
            <i id="ojo-reg" class="far fa-eye"></i>
          </button>
        </div>

        <label class="lr-label">Confirmar contraseña</label>
        <div class="lr-input-wrap">
          <input type="password" id="regPasswordConf" class="lr-input" placeholder="Repite tu contraseña" required autocomplete="new-password">
        </div>

        <button type="submit" id="btnRegistro" class="lr-btn">Crear cuenta →</button>

        <div class="lr-links" style="justify-content:center;">
          <button type="button" class="lr-link" onclick="mostrarLogin()">← Volver al inicio de sesión</button>
        </div>
      </form>

    </div>
  </div>
</div>

<script src="/js/supabase.js"></script>
<script>
  const supabaseUrl = "<%= SUPABASE_URL %>";
  const supabaseKey = "<%= SUPABASE_ANON_KEY %>";
  const _supabase = window._supabase = (supabaseUrl && supabaseKey)
    ? supabase.createClient(supabaseUrl, supabaseKey)
    : null;

  if (_supabase) {
    _supabase.auth.onAuthStateChange((event, session) => {
      if (event === 'SIGNED_IN' || event === 'TOKEN_REFRESHED') {
        fetch('/set-session', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ session })
        }).then(() => { window.location.href = '/'; });
      }
      if (event === 'SIGNED_OUT') {
        fetch('/clear-session', { method: 'POST' })
          .then(() => window.location.href = '/login');
      }
    });
  }

  /* ── Toggle visibilidad contraseña ── */
  function togglePass(inputId, iconId) {
    const inp = document.getElementById(inputId);
    const ico = document.getElementById(iconId);
    const show = inp.type === 'password';
    inp.type = show ? 'text' : 'password';
    ico.className = show ? 'far fa-eye-slash' : 'far fa-eye';
  }

  /* ── Alerta ── */
  function mostrarAlerta(msg, tipo) {
    const el = document.getElementById('alertaAuth');
    el.className = 'lr-alert-' + tipo;
    el.textContent = msg;
    el.style.display = '';
  }
  function ocultarAlerta() {
    const el = document.getElementById('alertaAuth');
    el.style.display = 'none';
    el.className = '';
  }

  /* ── Toggle formularios ── */
  function mostrarRegistro() {
    document.getElementById('formLogin').style.display = 'none';
    document.getElementById('formRegistro').style.display = '';
    ocultarAlerta();
  }
  function mostrarLogin() {
    document.getElementById('formRegistro').style.display = 'none';
    document.getElementById('formLogin').style.display = '';
    ocultarAlerta();
  }

  /* ── Login con email/contraseña ── */
  async function loginUsuario(event) {
    event.preventDefault();
    if (!_supabase) return mostrarAlerta('Error de configuración. Contacta al administrador.', 'danger');

    const btn = document.getElementById('btnLogin');
    btn.disabled = true;
    btn.innerHTML = '<span class="lr-spinner"></span>';

    const { error } = await _supabase.auth.signInWithPassword({
      email: document.getElementById('email').value,
      password: document.getElementById('password').value
    });

    if (error) {
      mostrarAlerta(error.message, 'danger');
      btn.disabled = false;
      btn.innerHTML = 'Iniciar Sesión →';
    }
    // Si ok, onAuthStateChange redirige
  }

  /* ── Registro ── */
  async function registrarUsuario(event) {
    event.preventDefault();
    if (!_supabase) return mostrarAlerta('Error de configuración. Contacta al administrador.', 'danger');

    const password = document.getElementById('regPassword').value;
    const passwordConf = document.getElementById('regPasswordConf').value;
    if (password !== passwordConf) return mostrarAlerta('Las contraseñas no coinciden.', 'danger');

    const btn = document.getElementById('btnRegistro');
    btn.disabled = true;
    btn.innerHTML = '<span class="lr-spinner"></span>';

    const { error } = await _supabase.auth.signUp({
      email: document.getElementById('regEmail').value.trim(),
      password,
      options: { data: { full_name: document.getElementById('regNombre').value.trim() } }
    });

    btn.disabled = false;
    btn.innerHTML = 'Crear cuenta →';

    if (error) {
      mostrarAlerta(error.message, 'danger');
    } else {
      mostrarAlerta('Cuenta creada. Revisa tu correo para confirmar el registro antes de iniciar sesión.', 'success');
      document.getElementById('formRegistro').reset();
    }
  }

  /* ── Recuperar contraseña ── */
  async function recuperarPassword() {
    const email = document.getElementById('email').value;
    if (!email) return mostrarAlerta('Escribe tu email primero y luego haz clic aquí.', 'warning');
    if (!_supabase) return mostrarAlerta('Error de configuración.', 'danger');

    const { error } = await _supabase.auth.resetPasswordForEmail(email, {
      redirectTo: window.location.origin + '/auth/callback'
    });

    if (error) {
      mostrarAlerta(error.message, 'danger');
    } else {
      mostrarAlerta('Revisa tu correo para restablecer tu contraseña.', 'success');
    }
  }

  /* ── Login social ── */
  async function loginConRedSocial(provider) {
    if (!_supabase) return mostrarAlerta('Error de configuración.', 'danger');
    const { error } = await _supabase.auth.signInWithOAuth({
      provider,
      options: { redirectTo: window.location.origin + '/auth/callback' }
    });
    if (error) mostrarAlerta(error.message, 'danger');
  }
</script>

<%- include("../template/footer") %>
