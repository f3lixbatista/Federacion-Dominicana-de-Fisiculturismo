<%- include("template/cabecera", {tituloWeb: "Crear Categoría"}) %>

<div class="container my-5" style="max-width: 860px;">
    <h3 class="fw-bold mb-1"><i class="fas fa-layer-group me-2 text-primary"></i>Crear Categoría</h3>
    <p class="text-muted small mb-4">Categoría = Modalidad (edad) + Disciplina (género) + División (peso / estatura)</p>

    <!-- VISTA PREVIA DEL NOMBRE -->
    <div class="card border-primary shadow-sm mb-4">
        <div class="card-body py-3 d-flex align-items-center gap-3">
            <span class="fw-bold text-muted small text-nowrap">NOMBRE:</span>
            <input id="inputNombreCategoria" class="form-control form-control-lg fw-bold border-0 bg-transparent fs-5" readonly
                   placeholder="Se genera automáticamente al completar los campos…">
        </div>
    </div>

    <!-- FILA 1: Modalidad + Sexo -->
    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <label class="form-label fw-bold">Modalidad <span class="text-muted fw-normal small">(edad)</span></label>
            <select id="selModalidad" class="form-select" onchange="onModalidadChange()">
                <option value="">-- Seleccionar --</option>
                <option value="Children">Children</option>
                <option value="Junior">Junior</option>
                <option value="Senior">Senior</option>
                <option value="Master">Master</option>
            </select>
        </div>
        <div class="col-md-4">
            <label class="form-label fw-bold">Sexo <span class="text-muted fw-normal small">(disciplina)</span></label>
            <select id="selSexo" class="form-select" onchange="onSexoChange()">
                <option value="">-- Seleccionar --</option>
                <option value="M">Masculino (M)</option>
                <option value="F">Femenino (F)</option>
                <option value="F-M">Mixto (F-M)</option>
            </select>
        </div>
    </div>

    <!-- FILA 2: Disciplina -->
    <div class="row g-3 mb-2 d-none" id="filaDisciplina">
        <div class="col">
            <label class="form-label fw-bold">Disciplina</label>
            <div class="input-group">
                <select id="selDisciplina" class="form-select" onchange="onDisciplinaChange()">
                    <option value="">-- Seleccionar disciplina --</option>
                </select>
                <button class="btn btn-outline-primary fw-bold" type="button" onclick="togglePanel('panelNuevaDisciplina')">
                    <i class="fas fa-plus"></i> Nueva
                </button>
            </div>
        </div>
    </div>

    <!-- PANEL: Nueva Disciplina -->
    <div id="panelNuevaDisciplina" class="d-none card border-primary mb-3">
        <div class="card-header bg-primary text-white fw-bold py-2 small">
            <i class="fas fa-plus-circle me-1"></i> Nueva Disciplina
        </div>
        <div class="card-body p-3">
            <div class="row g-2 mb-3">
                <div class="col-md-5">
                    <label class="form-label small fw-bold">Nombre de la disciplina</label>
                    <input id="inputNombreDisciplina" class="form-control" placeholder="Ej: Men's Physique">
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold">Sexo</label>
                    <select id="selSexoDisc" class="form-select">
                        <option value="M">Masculino (M)</option>
                        <option value="F">Femenino (F)</option>
                        <option value="F-M">Mixto (F-M)</option>
                    </select>
                </div>
                <div class="col-md-5">
                    <label class="form-label small fw-bold">Grupo de Afinidad
                        <span class="text-muted fw-normal">(disciplinas que compiten juntas)</span>
                    </label>
                    <input id="inputGrupoAfinidad" class="form-control" placeholder="Ej: culturismo, physique_m, bikini_f"
                           list="sugerenciasGrupo">
                    <datalist id="sugerenciasGrupo">
                        <option value="culturismo">
                        <option value="physique_m">
                        <option value="muscular_m">
                        <option value="fitness_m">
                        <option value="bikini_f">
                        <option value="wellness_f">
                        <option value="bodyfitness_f">
                        <option value="physique_f">
                        <option value="pairs">
                        <option value="children_m">
                        <option value="children_f">
                    </datalist>
                </div>
            </div>
            <label class="form-label small fw-bold">Vincular a divisiones existentes:</label>
            <div id="checkboxesDivisiones" class="d-flex flex-wrap gap-2 mb-3 p-2 bg-light rounded">
                <span class="text-muted small">Cargando divisiones…</span>
            </div>
            <button class="btn btn-primary btn-sm fw-bold" onclick="guardarNuevaDisciplina()">
                <i class="fas fa-save me-1"></i> Guardar Disciplina
            </button>
            <button class="btn btn-light btn-sm ms-2" onclick="togglePanel('panelNuevaDisciplina')">Cancelar</button>
        </div>
    </div>

    <!-- FILA 3: División -->
    <div class="row g-3 mb-2 d-none" id="filaDivision">
        <div class="col">
            <label class="form-label fw-bold">División <span class="text-muted fw-normal small">(peso / estatura)</span></label>
            <div class="input-group">
                <select id="selDivision" class="form-select" onchange="onDivisionChange()">
                    <option value="">-- Seleccionar división --</option>
                </select>
                <button class="btn btn-outline-secondary fw-bold" type="button" onclick="togglePanel('panelNuevaDivision')">
                    <i class="fas fa-plus"></i> Nueva
                </button>
            </div>
            <div id="alertSinDivisiones" class="alert alert-warning py-1 small mt-1 d-none">
                Esta disciplina aún no tiene divisiones. Crea la primera con el botón "Nueva".
            </div>
        </div>
    </div>

    <!-- PANEL: Nueva División -->
    <div id="panelNuevaDivision" class="d-none card border-secondary mb-3">
        <div class="card-header bg-secondary text-white fw-bold py-2 small">
            <i class="fas fa-plus-circle me-1"></i> Nueva División
        </div>
        <div class="card-body p-3">
            <div class="row g-2 mb-3">
                <div class="col-md-6">
                    <label class="form-label small fw-bold">Nombre de la división</label>
                    <input id="inputNombreDivision" class="form-control" placeholder="Ej: Class A, Lightweight…">
                </div>
                <div class="col-md-5">
                    <label class="form-label small fw-bold">Parámetro de clasificación</label>
                    <select id="selParametroDivision" class="form-select">
                        <option value="estatura">Estatura (cm)</option>
                        <option value="peso">Peso (kg)</option>
                        <option value="ambos">Peso + Estatura (ambos)</option>
                        <option value="ninguno">Sin parámetro (Open / única)</option>
                    </select>
                </div>
            </div>
            <button class="btn btn-secondary btn-sm fw-bold" onclick="guardarNuevaDivision()">
                <i class="fas fa-save me-1"></i> Guardar División
            </button>
            <button class="btn btn-light btn-sm ms-2" onclick="togglePanel('panelNuevaDivision')">Cancelar</button>
        </div>
    </div>

    <!-- PARÁMETROS -->
    <div id="campoEdad" class="card mb-3" style="display:none; border-left: 4px solid #ffc107;">
        <div class="card-body p-3">
            <h6 class="fw-bold mb-2"><i class="fas fa-birthday-cake me-1 text-warning"></i> Rango de Edad (años)</h6>
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label small">Desde</label>
                    <input type="number" id="desdeEdad" class="form-control" placeholder="16" oninput="actualizarNombre()">
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Hasta <span class="text-muted">(200 = sin límite)</span></label>
                    <input type="number" id="hastaEdad" class="form-control" placeholder="23" oninput="actualizarNombre()">
                </div>
            </div>
        </div>
    </div>

    <div id="campoPeso" class="card mb-3" style="display:none; border-left: 4px solid #0dcaf0;">
        <div class="card-body p-3">
            <h6 class="fw-bold mb-2"><i class="fas fa-weight me-1 text-info"></i> Rango de Peso (kg)</h6>
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label small">Desde</label>
                    <input type="number" step="0.1" id="desdePeso" class="form-control" placeholder="0" oninput="actualizarNombre()">
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Hasta <span class="text-muted">(1000 = sin límite)</span></label>
                    <input type="number" step="0.1" id="hastaPeso" class="form-control" placeholder="75" oninput="actualizarNombre()">
                </div>
            </div>
        </div>
    </div>

    <div id="campoEstatura" class="card mb-3" style="display:none; border-left: 4px solid #198754;">
        <div class="card-body p-3">
            <h6 class="fw-bold mb-2"><i class="fas fa-ruler-vertical me-1 text-success"></i> Rango de Estatura (cm)</h6>
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label small">Desde</label>
                    <input type="number" step="0.1" id="desdeEstatura" class="form-control" placeholder="0" oninput="actualizarNombre()">
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Hasta <span class="text-muted">(1000 = sin límite)</span></label>
                    <input type="number" step="0.1" id="hastaEstatura" class="form-control" placeholder="170" oninput="actualizarNombre()">
                </div>
            </div>
        </div>
    </div>

    <!-- BOTÓN GUARDAR -->
    <div id="seccionGuardar" class="mt-3" style="display:none;">
        <button class="btn btn-primary btn-lg fw-bold px-5" onclick="guardarCategoria()">
            <i class="fas fa-save me-2"></i> GUARDAR CATEGORÍA
        </button>
        <a href="/categorias" class="btn btn-outline-dark btn-lg ms-2">Ver listado</a>
    </div>
</div>

<script>
    let divisionActualData = null; // { id, nombre, parametro }
    let disciplinaActualId = null;
    let todasLasDivisiones = []; // cache para el panel nueva disciplina

    // ── HELPERS ─────────────────────────────────────────────────────────────────

    function togglePanel(id) {
        const el = document.getElementById(id);
        el.classList.toggle('d-none');
        if (id === 'panelNuevaDisciplina' && !el.classList.contains('d-none')) {
            cargarCheckboxesDivisiones();
            const sexoActual = document.getElementById('selSexo').value;
            if (sexoActual) document.getElementById('selSexoDisc').value = sexoActual;
        }
    }

    function limpiarParam() {
        ['desdeEdad','hastaEdad','desdePeso','hastaPeso','desdeEstatura','hastaEstatura']
            .forEach(id => document.getElementById(id).value = '');
    }

    // ── CARGA DE DATOS ───────────────────────────────────────────────────────────

    async function cargarDisciplinas(sexo, modalidad) {
        const sel = document.getElementById('selDisciplina');
        sel.innerHTML = '<option value="">Cargando…</option>';
        const params = new URLSearchParams({ sexo });
        if (modalidad) params.set('modalidad', modalidad);
        const data = await fetch(`/categorias/api/disciplinas?${params}`).then(r => r.json()).catch(() => []);
        sel.innerHTML = '<option value="">-- Seleccionar disciplina --</option>';
        data.forEach(d => {
            const opt = document.createElement('option');
            opt.value = d.id;
            opt.textContent = d.nombre;
            opt.dataset.nombre = d.nombre;
            sel.appendChild(opt);
        });
    }

    async function cargarDivisiones(disciplinaId) {
        const sel = document.getElementById('selDivision');
        sel.innerHTML = '<option value="">Cargando…</option>';
        document.getElementById('alertSinDivisiones').classList.add('d-none');
        const data = await fetch(`/categorias/api/divisiones?disciplinaId=${disciplinaId}`).then(r => r.json()).catch(() => []);
        sel.innerHTML = '<option value="">-- Seleccionar división --</option>';
        if (data.length === 0) {
            document.getElementById('alertSinDivisiones').classList.remove('d-none');
        }
        data.forEach(d => {
            const opt = document.createElement('option');
            opt.value = d.id;
            opt.textContent = d.nombre;
            opt.dataset.nombre = d.nombre;
            opt.dataset.parametro = d.parametro || 'ninguno';
            sel.appendChild(opt);
        });
    }

    async function cargarCheckboxesDivisiones() {
        const contenedor = document.getElementById('checkboxesDivisiones');
        if (todasLasDivisiones.length === 0) {
            const data = await fetch('/categorias/api/divisiones').then(r => r.json()).catch(() => []);
            todasLasDivisiones = data;
        }
        contenedor.innerHTML = '';
        if (todasLasDivisiones.length === 0) {
            contenedor.innerHTML = '<span class="text-muted small">Aún no hay divisiones creadas.</span>';
            return;
        }
        todasLasDivisiones.forEach(div => {
            contenedor.insertAdjacentHTML('beforeend', `
                <div class="form-check me-3">
                    <input class="form-check-input check-div-link" type="checkbox" value="${div.id}" id="chk-${div.id}">
                    <label class="form-check-label small" for="chk-${div.id}">
                        ${div.nombre} <span class="text-muted">(${div.parametro})</span>
                    </label>
                </div>`);
        });
    }

    // ── EVENTOS ──────────────────────────────────────────────────────────────────

    // ── ÚNICA FUENTE DE VERDAD PARA VISIBILIDAD DE CAMPOS ───────────────────────
    // Llamar siempre que cambie modalidad, disciplina o división.
    // Usa style.display (inline) para ganarle a la regla CSS global de cabecera.ejs
    // que fuerza display:none en #campoEdad, #campoPeso, #campoEstatura por ID.
    function mostrarCampo(id, visible) {
        document.getElementById(id).style.display = visible ? 'block' : 'none';
    }

    function actualizarParametros() {
        const modalidad = document.getElementById('selModalidad').value;
        const parametro = divisionActualData?.parametro || 'ninguno';

        mostrarCampo('campoEdad',    ['Junior', 'Master', 'Children'].includes(modalidad));
        mostrarCampo('campoPeso',    parametro === 'peso'     || parametro === 'ambos');
        mostrarCampo('campoEstatura',parametro === 'estatura' || parametro === 'ambos');
        mostrarCampo('seccionGuardar', !!divisionActualData);
    }

    function ocultarTodosLosCampos() {
        ['campoEdad', 'campoPeso', 'campoEstatura', 'seccionGuardar']
            .forEach(id => mostrarCampo(id, false));
    }

    // ── EVENTOS ──────────────────────────────────────────────────────────────────

    function onModalidadChange() {
        limpiarParam();
        const modalidad = document.getElementById('selModalidad').value;
        const sexo = document.getElementById('selSexo').value;

        if (sexo && modalidad) {
            // Resetear todo desde disciplina hacia abajo
            disciplinaActualId = null;
            divisionActualData = null;
            document.getElementById('selDisciplina').value = '';
            document.getElementById('filaDivision').classList.add('d-none');
            document.getElementById('selDivision').innerHTML = '<option value="">-- Seleccionar división --</option>';
            cargarDisciplinas(sexo, modalidad);
        }

        actualizarParametros();
        actualizarNombre();
    }

    function onSexoChange() {
        const sexo = document.getElementById('selSexo').value;
        const modalidad = document.getElementById('selModalidad').value;
        disciplinaActualId = null;
        divisionActualData = null;
        limpiarParam();

        document.getElementById('filaDisciplina').classList.toggle('d-none', !sexo);
        document.getElementById('filaDivision').classList.add('d-none');
        document.getElementById('selDisciplina').value = '';
        document.getElementById('selDivision').innerHTML = '<option value="">-- Seleccionar división --</option>';

        ocultarTodosLosCampos();
        actualizarNombre();

        if (sexo) cargarDisciplinas(sexo, modalidad);
    }

    function onDisciplinaChange() {
        const sel = document.getElementById('selDisciplina');
        disciplinaActualId = sel.value || null;
        divisionActualData = null;
        limpiarParam();

        document.getElementById('filaDivision').classList.toggle('d-none', !disciplinaActualId);
        document.getElementById('selDivision').innerHTML = '<option value="">-- Seleccionar división --</option>';

        // Mantener campoEdad según modalidad, ocultar peso/estatura/guardar
        actualizarParametros();
        actualizarNombre();

        if (disciplinaActualId) cargarDivisiones(disciplinaActualId);
    }

    function onDivisionChange() {
        const sel = document.getElementById('selDivision');
        const opt = sel.selectedOptions[0];

        if (!opt || !opt.value) {
            divisionActualData = null;
            limpiarParam();
            actualizarParametros();
            actualizarNombre();
            return;
        }

        const rawParam = opt.dataset.parametro;
        divisionActualData = {
            id: opt.value,
            nombre: opt.textContent.trim(),
            parametro: (rawParam && rawParam !== 'null') ? rawParam : 'ninguno'
        };
        limpiarParam();
        actualizarParametros(); // muestra campoEdad + (campoPeso | campoEstatura | nada)
        actualizarNombre();
    }

    // ── GENERACIÓN DEL NOMBRE ────────────────────────────────────────────────────

    function actualizarNombre() {
        document.getElementById('inputNombreCategoria').value = generarNombre();
    }

    function generarNombre() {
        const modalidad = document.getElementById('selModalidad').value;
        const discOpt = document.getElementById('selDisciplina').selectedOptions[0];
        const divOpt  = document.getElementById('selDivision').selectedOptions[0];

        if (!modalidad || !discOpt?.value || !divOpt?.value) return '';

        const disciplina = discOpt.dataset.nombre || discOpt.textContent.trim();
        const division   = divisionActualData?.nombre || divOpt.textContent.trim();
        const parametro  = divisionActualData?.parametro || 'ninguno';

        const desdeEdad  = document.getElementById('desdeEdad').value;
        const hastaEdad  = document.getElementById('hastaEdad').value;
        const desdePeso  = document.getElementById('desdePeso').value;
        const hastaPeso  = document.getElementById('hastaPeso').value;
        const desdeEst   = document.getElementById('desdeEstatura').value;
        const hastaEst   = document.getElementById('hastaEstatura').value;

        let nombre = `${modalidad} ${disciplina}`;

        // Rango de edad (Junior / Master / Children)
        if (['Junior', 'Master', 'Children'].includes(modalidad) && desdeEdad) {
            if (hastaEdad === '200' || !hastaEdad) {
                nombre += ` -${desdeEdad} años en adelante-`;
            } else {
                nombre += ` -${desdeEdad} a ${hastaEdad} años-`;
            }
        }

        nombre += ` ${division}`;

        // Parámetro físico
        if ((parametro === 'peso' || parametro === 'ambos') && desdePeso) {
            nombre += hastaPeso === '1000' || !hastaPeso
                ? ` Sobre ${desdePeso} kg.`
                : ` Hasta ${hastaPeso} kg.`;
        }
        if ((parametro === 'estatura' || parametro === 'ambos') && desdeEst) {
            nombre += hastaEst === '1000' || !hastaEst
                ? ` Sobre ${desdeEst} cm.`
                : ` Hasta ${hastaEst} cm.`;
        }

        return nombre;
    }

    // ── GUARDAR NUEVA DISCIPLINA ─────────────────────────────────────────────────

    async function guardarNuevaDisciplina() {
        const nombre         = document.getElementById('inputNombreDisciplina').value.trim();
        const sexo           = document.getElementById('selSexoDisc').value;
        const grupo_afinidad = document.getElementById('inputGrupoAfinidad').value.trim() || null;
        if (!nombre) return alert('Escribe el nombre de la disciplina.');

        const divisionIds = Array.from(document.querySelectorAll('.check-div-link:checked')).map(c => c.value);

        const resp = await fetch('/categorias/api/disciplinas', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ nombre, sexo, grupo_afinidad, divisionIds })
        });
        const result = await resp.json();
        if (!resp.ok || result.error) return alert('Error: ' + (result.error || 'desconocido'));

        alert(`Disciplina "${nombre}" creada.`);
        document.getElementById('inputNombreDisciplina').value = '';
        togglePanel('panelNuevaDisciplina');

        // Recargar disciplinas con el sexo actual
        const sexoActual = document.getElementById('selSexo').value;
        if (sexoActual) await cargarDisciplinas(sexoActual);
    }

    // ── GUARDAR NUEVA DIVISIÓN ────────────────────────────────────────────────────

    async function guardarNuevaDivision() {
        const nombre    = document.getElementById('inputNombreDivision').value.trim();
        const parametro = document.getElementById('selParametroDivision').value;
        if (!nombre) return alert('Escribe el nombre de la división.');

        const resp = await fetch('/categorias/api/divisiones', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ nombre, parametro, disciplinaId: disciplinaActualId })
        });
        const result = await resp.json();
        if (!resp.ok || result.error) return alert('Error: ' + (result.error || 'desconocido'));

        alert(`División "${nombre}" creada.`);
        document.getElementById('inputNombreDivision').value = '';
        todasLasDivisiones = []; // invalidar cache
        togglePanel('panelNuevaDivision');

        // Recargar divisiones de la disciplina actual
        if (disciplinaActualId) await cargarDivisiones(disciplinaActualId);
    }

    // ── GUARDAR CATEGORÍA ─────────────────────────────────────────────────────────

    async function guardarCategoria() {
        const nombre = document.getElementById('inputNombreCategoria').value.trim();
        if (!nombre) return alert('Completa todos los campos para generar el nombre.');

        const modalidad  = document.getElementById('selModalidad').value;
        const sexo       = document.getElementById('selSexo').value;
        const discOpt    = document.getElementById('selDisciplina').selectedOptions[0];
        const disciplina = discOpt?.dataset.nombre || discOpt?.textContent.trim();
        const division   = divisionActualData?.nombre || '';
        const parametro  = divisionActualData?.parametro || 'ninguno';

        const catData = {
            nombre,
            modalidad,
            sexo,
            disciplina,
            division,
            edad_min:      document.getElementById('desdeEdad').value      ? parseInt(document.getElementById('desdeEdad').value)      : null,
            edad_max:      document.getElementById('hastaEdad').value      ? parseInt(document.getElementById('hastaEdad').value)      : null,
            peso_min:      document.getElementById('desdePeso').value      ? parseFloat(document.getElementById('desdePeso').value)    : null,
            peso_max:      document.getElementById('hastaPeso').value      ? parseFloat(document.getElementById('hastaPeso').value)    : null,
            estatura_min:  document.getElementById('desdeEstatura').value  ? parseFloat(document.getElementById('desdeEstatura').value): null,
            estatura_max:  document.getElementById('hastaEstatura').value  ? parseFloat(document.getElementById('hastaEstatura').value): null,
        };

        try {
            const resp = await fetch('/categorias/crear', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(catData)
            });
            const result = await resp.json();
            if (result.estado) {
                alert('¡Categoría guardada!');
                // Reset form
                ['selModalidad','selSexo','selDisciplina','selDivision'].forEach(id => document.getElementById(id).value = '');
                document.getElementById('inputNombreCategoria').value = '';
                limpiarParam();
                divisionActualData = null;
                disciplinaActualId = null;
                document.getElementById('filaDisciplina').classList.add('d-none');
                document.getElementById('filaDivision').classList.add('d-none');
                ocultarTodosLosCampos();
            } else {
                alert('Error: ' + result.mensaje);
            }
        } catch (e) {
            alert('Error de conexión con el servidor.');
        }
    }
</script>

<%- include("template/footer") %>
