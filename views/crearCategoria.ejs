<%- include("template/cabecera", {tituloWeb: "Crear Categoria"}) %>

<div class="container w-75 my-4">
    <!-- El action ahora apunta a la ruta POST de categorías -->
    <form class="mx-0 p-0 row g-4 needs-validation was-validated" action="/categorias/crearCategoria" method="POST" id="formCreaCat">
       
       <!-- Este campo genera el nombre final de la categoría -->
       <input type="text" id="newCat" name="nombre" value="" class="border-0 fs-3 fw-bold" readonly placeholder="Nombre Automático">

        <div class="col-md-2 py-0 pt-0 my-6 mr-4">
            <label class="form-label">Modalidad</label>
            <select class="form-control" id="modalidad" name="modalidad" required>
                <option value="" selected disabled>...</option>
                <option value="Children">Children</option>
                <option value="Junior">Junior</option>
                <option value="Senior">Senior</option>
                <option value="Master">Master</option>
            </select>
        </div>
        
        <div class="col-md-2 py-0 pt-0 mx-4">
            <label class="form-label">Genero</label>
            <select class="form-control" name="genero" id="genero" required>
                <option value="" selected disabled>...</option>
                <option value="F">F</option>
                <option value="M">M</option>
                <option value="F-M">F-M</option>
            </select>
        </div>
        
        <div class="col-md-3 py-0 pt-0  mx-4">
            <label class="form-label">Disciplina</label>
            <select id="disciplina" class="form-control" name="disciplina" required>
                <option value="" selected disabled>Seleccione...</option>
                <option value="Men’s Bodybuilding">Men’s Bodybuilding</option>
                <option value="Men’s Classic Bodybuilding">Men’s Classic Bodybuilding</option>
                <option value="Men's Physique">Men's Physique</option>
                <option value="Women's Wellness">Women's Wellness</option>
                <option value="Women's Bikini">Women's Bikini</option>
                <!-- Agrega aquí el resto de opciones que necesites -->
            </select>
        </div> 
            
        <div class="col-md-3 py-0 pt-0 mx-4">
            <label class="form-label">Division</label>
            <select onchange="writeMessage()" id="division" name="division" class="form-control">
                <option value="Open" selected>Open</option>
                <option value="Bantamweight">Bantamweight</option>
                <option value="Lightweight">Lightweight</option>
                <option value="Class A">Class A</option>
                <option value="Class B">Class B</option>
            </select>
        </div>

        <div class="col-md-4 py-0 pt-0 my-4">
            <h5 class="fw-bold">Edad (Años)</h5>
            <div class="d-flex gap-2">
                <input type="number" class="form-control" name="desde_edad" placeholder="Desde">
                <input type="number" class="form-control" name="hasta_edad" placeholder="Hasta">
            </div>
        </div>

        <div class="col-md-4 py-0 pt-0 my-4">
            <h5 class="fw-bold">Estatura (cm)</h5>
            <div class="d-flex gap-2">
                <input type="number" class="form-control" name="desde_estatura" placeholder="Desde">
                <input type="number" class="form-control" name="hasta_estatura" placeholder="Hasta">
            </div>
        </div>

        <div class="col-md-4 py-0 pt-0 my-4">
            <h5 class="fw-bold">Peso (kg)</h5>
            <div class="d-flex gap-2">
                <input type="number" class="form-control" name="desde_peso" placeholder="Desde">
                <input type="number" class="form-control" name="hasta_peso" placeholder="Hasta">
            </div>
        </div>

        <div class="col-12 mt-4">
            <button type="submit" class="btn btn-success btn-lg w-100">Guardar Nueva Categoría</button>
        </div>
    </form>

    <script>
        // Función para autogenerar el nombre de la categoría mientras seleccionas
        function writeMessage() {
            const mod = document.getElementById('modalidad').value;
            const gen = document.getElementById('genero').value;
            const dis = document.getElementById('disciplina').value;
            const div = document.getElementById('division').value;
            
            document.getElementById('newCat').value = `${mod} ${dis} ${gen} ${div}`.trim();
        }

        // Escuchar cambios en todos los select para actualizar el nombre
        document.querySelectorAll('select').forEach(select => {
            select.addEventListener('change', writeMessage);
        });
    </script>
</div>

<%- include("template/footer") %>
