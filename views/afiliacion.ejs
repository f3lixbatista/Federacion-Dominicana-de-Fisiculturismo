<%- include("template/cabecera", {tituloWeb: "Auto-Afiliación FDFF"}) %>

<div class="container ml-auto mr-auto caja pb-5">
    <h1 id="titulo" class="mx-4 my-4">Solicitud de Membresía</h1>
        
    <div class="container border border-primary border-3 p-4 bg-white shadow-sm" style="border-radius: 15px;">
        <form id="formMembresia" class="row g-3 needs-validation was-validated">

            <h6 class="position-relative mt-5 opacity-25 fw-bold">DATOS DEL ATLETA</h6>
            
            <div class="col-md-3">
                <label class="form-label small">ID-FDFF (Asignado en Pesaje)</label>
                <input type="text" class="form-control bg-light" name="idfdff" readonly placeholder="Pendiente...">
            </div>

            <div class="col-md-6"></div> <!-- Espaciador -->

            <div class="col-md-3">
                <label class="form-label small">Fecha de Solicitud</label>
                <input type="date" class="form-control" name="fecha_inscripcion" value="<%= new Date().toISOString().split('T')[0] %>" required>
            </div>

            <div class="col-md-6 mt-4">
                <label class="form-label small">Nombre(s) y Apellido(s)</label>
                <input type="text" class="form-control" name="nombre" placeholder="Según documento de identidad" required>
            </div>

            <div class="col-md-3 mt-4">
                <label class="form-label small">Cédula</label>
                <input type="text" class="form-control" name="cedula" required>
            </div>

            <div class="col-md-3 mt-4">
                <label class="form-label small">Pasaporte</label>
                <input type="text" class="form-control" name="pasaporte">
            </div>

            <div class="col-md-4 my-4">
                <label class="form-label small">Nacionalidad</label>     
                <input type="text" value="Dominicana" class="form-control" name="nacionalidad" required>
            </div>

            <div class="col-md-3 my-4">
                <label class="form-label small">Fecha de Nacimiento</label>
                <input type="date" class="form-control" name="nacimiento" required>
            </div>

             <div class="col-md-2 my-4">
                <label class="form-label small">Sexo</label>
                <select class="form-control" name="sexo" required>
                    <option value="" selected disabled>Elija...</option>
                    <option value="F">Femenino</option>
                    <option value="M">Masculino</option>
                </select>
            </div>

            <div class="col-md-3 my-4">
                <label class="form-label small">Ocupación</label>
                <input type="text" class="form-control" name="ocupacion" required>
            </div>

            <h6 class="position-relative mt-5 opacity-25 fw-bold">DIRECCIÓN DE RESIDENCIA</h6>
            
            <div class="col-md-6">
                <label class="form-label small">Calle y Número</label>
                <input type="text" class="form-control" name="calle" required>
            </div>

            <div class="col-md-3">
                <label class="form-label small">Sector/Barrio</label>
                <input type="text" class="form-control" name="sector" required>
            </div>

            <div class="col-md-3">
                <label class="form-label small">Municipio/Distrito</label>
                <input type="text" class="form-control" name="municipio" required>
            </div>

            <div class="col-md-4 my-4">
                <label class="form-label small">Provincia/Estado</label>
                <input type="text" class="form-control" name="provincia" required>
            </div>

            <div class="col-md-4 my-4">
                <label class="form-label small">País</label>
                <input type="text" class="form-control" name="pais" value="Republica Dominicana" required>
            </div>

            <div class="col-md-4 my-4">
                <label class="form-label small">Código Postal</label>
                <input type="text" class="form-control" name="postal">
            </div>

            <h6 class="position-relative mt-5 opacity-25 fw-bold">CONTACTOS</h6>

             <div class="col-md-3 mb-4">
                <label class="form-label small">Celular</label>
                <input type="tel" class="form-control" name="celular" required>
            </div>

            <div class="col-md-3 mb-4">
                <label class="form-label small">Teléfono Residencial</label>
                <input type="tel" class="form-control" name="telfijo">
            </div>

            <div class="col-md-3 mb-4">
                <label class="form-label small">Email</label>
                <input type="email" class="form-control" name="email" required>
            </div>

             <div class="col-md-3 mb-4">
                <label class="form-label small">Instagram</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text">@</span>
                    <input type="text" class="form-control" name="instagram">
                </div>
            </div>

            <h6 class="position-relative mt-5 opacity-25 fw-bold">DATOS DEPORTIVOS</h6>
            
            <div class="col-md-3 mb-4">
                <label class="form-label small">Categoría Principal</label>
                <input type="text" class="form-control" name="categoria" required>
            </div>

            <div class="col-md-3 mb-4">
                <label class="form-label small">Estatura (cm)</label>
                <input type="number" step="0.01" class="form-control" name="estatura" required>
            </div>

           <div class="col-md-3 mb-4">
                <label class="form-label small">Peso (kg)</label>
                <input type="number" step="0.01" class="form-control" name="peso" required>
            </div>

            <div class="col-md-3 mb-4">
                <label class="form-label small">Gimnasio</label>
                <input type="text" class="form-control" name="gimnasio" required>
            </div>

            <div class="col-md-6 mb-4">
                <label class="form-label small">Team / Preparador Oficial</label>
                <select name="preparador_id" id="selectPreparadorAfiliacion" class="form-select border-primary select2">
                    <option value="">-- Atleta Independiente --</option>
                    <% (arrayPreparadores || []).forEach(prep => { %>
                        <option value="<%= prep.id %>"><%= prep.nombre_completo %> (<%= prep.gimnasio_labora %>)</option>
                    <% }) %>
                    <% if (locals.nuevoPrepId) { %>
                        <option value="<%= nuevoPrepId %>" selected><%= nuevoPrepNombre %> (pendiente de aprobación)</option>
                    <% } %>
                </select>
                <div class="mt-2">
                    <small class="text-muted d-block mb-2">Si su preparador no aparece, regístrelo primero en el módulo de Preparadores.</small>
                    <a href="/afiliacion/nuevo-preparador" id="btnRegistrarPrep" class="btn btn-sm btn-outline-primary">Registrar nuevo preparador</a>
                </div>
            </div>

            <div class="col-md-3 mb-4">
                <label class="form-label small">Celular del Preparador</label>
                <input type="tel" class="form-control" name="celular_preparador">
            </div>

            <div class="col-md-3 mb-4">
                <label class="form-label small">Email del Preparador</label>
                <input type="email" class="form-control" name="email_preparador">
            </div>

            <div class="col-12 mt-4 p-3 border border-danger rounded bg-light">
                <h6 class="fw-bold text-danger"><i class="fas fa-file-signature me-1"></i>Documento de Descargo y Consentimiento — FDFF / IFBB</h6>
                <p class="small text-muted mb-2">Para poder participar como competidor en eventos de la FDFF, afirmo que entiendo y estoy de acuerdo con la constitución y las reglas de la <strong>IFBB/FDFF</strong>, el código de ética y las reglas antidopajes. Entiendo y concuerdo con las siguientes condiciones:</p>
                <ol class="small text-muted ps-3 mb-2" style="line-height:1.5;">
                    <li>Entiendo que para poder participar en eventos como competidor debo estar de acuerdo con todas las partes de este documento y que lo hago de manera voluntaria.</li>
                    <li>Que concuerdo en descargar a la federación de cualquier reclamación por daños personales, muerte o daños a mi propiedad, incluyendo pero no limitándose a negligencia y/o aplicación de los estatutos por parte de la federación.</li>
                    <li>Confirmo que estoy en buen estado de salud física y mental. Cualquier daño médico durante mi participación es totalmente mi responsabilidad, liberando a los organizadores y a la federación de la cobertura económica.</li>
                    <li>Afirmo que nadie me obligó a participar y que lo hago por voluntad propia.</li>
                    <li>Acuerdo respetar las reglas de la IFBB/FDFF y entiendo que si participo en competencias no avaladas, soy pasible de pruebas de dopaje costeadas por mi persona.</li>
                    <li>Apruebo que fotos y videos tomadas durante eventos por fotógrafos acreditados puedan ser utilizadas por la federación sin requerir pago por derecho.</li>
                    <li>Confirmo que soy mayor de edad y que he leído, entendido y aceptado todas las partes de este documento antes de enviarlo.</li>
                </ol>
                <p class="small mb-0"><em>Cualquier cambio o modificación de datos se realizará el día del pesaje oficial. El descargo completo con firma física se entrega al momento de la inscripción presencial.</em></p>
            </div>

            <button type="submit" class="btn btn-danger btn-lg my-5 col-md-4 shadow" id="btnEnviar">
                SOLICITAR AFILIACIÓN
            </button>

        </form>

        <%# ─── PANEL DE PAGO (oculto hasta que el formulario se envíe) ─── %>
        <div id="panelPago" style="display:none" class="mt-4">
            <div class="alert alert-success border-success border-2">
                <h5 class="fw-bold"><i class="fas fa-check-circle me-1"></i>¡Solicitud enviada!</h5>
                <p class="mb-0">Para completar su afiliación, realice la transferencia y suba el comprobante.</p>
            </div>

            <div class="card border-primary mb-4">
                <div class="card-header bg-primary text-white fw-bold">
                    <i class="fas fa-university me-1"></i> Datos para Transferencia Bancaria
                </div>
                <div class="card-body">
                    <% if ((cuentasBancarias || []).length === 0) { %>
                        <div class="alert alert-warning mb-0 small">
                            <i class="fas fa-exclamation-triangle me-1"></i>
                            No hay cuentas bancarias registradas. Contacte al administrador.
                        </div>
                    <% } else { %>
                        <% cuentasBancarias.forEach(c => { %>
                            <table class="table table-borderless mb-2 small">
                                <tr><td class="fw-bold" style="width:140px;">Banco:</td><td><%= c.banco %></td></tr>
                                <tr><td class="fw-bold">Titular:</td><td><%= c.titular %></td></tr>
                                <tr><td class="fw-bold">Cuenta (<%= c.tipo_cuenta %>):</td><td><strong><%= c.numero_cuenta %></strong></td></tr>
                                <tr><td class="fw-bold">RNC / Cédula:</td><td><%= c.identificacion %></td></tr>
                                <tr><td class="fw-bold">Moneda:</td><td><span class="badge bg-secondary"><%= c.moneda %></span></td></tr>
                            </table>
                            <% if (cuentasBancarias.length > 1) { %><hr class="my-2"><% } %>
                        <% }) %>
                    <% } %>
                    <p class="small text-muted mt-2 mb-0">
                        <i class="fas fa-info-circle me-1"></i>
                        En el concepto de la transferencia escriba su nombre completo y número de cédula.
                    </p>
                </div>
            </div>

            <form id="formComprobante">
                <div class="mb-3">
                    <label class="form-label fw-bold">
                        <i class="fas fa-upload me-1"></i> Subir comprobante de transferencia
                    </label>
                    <input type="file" class="form-control" id="archivoComprobante"
                           name="comprobante" accept="image/*,.pdf" required>
                    <div class="form-text">Formatos aceptados: JPG, PNG, PDF. Máx. 5 MB.</div>
                </div>
                <button type="submit" class="btn btn-success" id="btnSubirComprobante">
                    <i class="fas fa-paper-plane me-1"></i> Enviar Comprobante
                </button>
            </form>

            <div id="msgComprobante" style="display:none" class="alert alert-info mt-3">
                <i class="fas fa-clock me-1"></i> Su comprobante fue recibido. El staff lo revisará y le notificará la activación de su membresía.
            </div>
        </div>
    </div>
</div>

<script>
    const STORAGE_KEY = 'fdff_afiliacion_borrador';

    // Guardar formulario en sessionStorage antes de ir a registrar preparador
    document.getElementById('btnRegistrarPrep').addEventListener('click', () => {
        const form = document.getElementById('formMembresia');
        const datos = {};
        new FormData(form).forEach((val, key) => { datos[key] = val; });
        sessionStorage.setItem(STORAGE_KEY, JSON.stringify(datos));
    });

    // Restaurar formulario si venimos de registrar preparador
    document.addEventListener('DOMContentLoaded', () => {
        const borrador = sessionStorage.getItem(STORAGE_KEY);
        if (borrador) {
            const datos = JSON.parse(borrador);
            const form = document.getElementById('formMembresia');
            Object.entries(datos).forEach(([key, val]) => {
                const campo = form.querySelector(`[name="${key}"]`);
                if (campo && campo.type !== 'hidden') campo.value = val;
            });
            sessionStorage.removeItem(STORAGE_KEY);
        }
    });

    // Enviar formulario de afiliación
    const formMembresia = document.getElementById('formMembresia');
    if (formMembresia) {
        formMembresia.addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('btnEnviar');
            if (btn) btn.disabled = true;

            const formData = new FormData(e.target);
            const selectedPreparadorId = formData.get('preparador_id');
            const preparadorTexto = selectedPreparadorId
                ? document.querySelector('#selectPreparadorAfiliacion option:checked').textContent
                : '';

            const profileData = {
                idfdff: formData.get('idfdff'),
                nombre: formData.get('nombre'),
                cedula: formData.get('cedula'),
                pasaporte: formData.get('pasaporte'),
                nacionalidad: formData.get('nacionalidad'),
                fecha_nacimiento: formData.get('nacimiento'),
                sexo: formData.get('sexo'),
                ocupacion: formData.get('ocupacion'),
                calle: formData.get('calle'),
                sector: formData.get('sector'),
                municipio: formData.get('municipio'),
                provincia: formData.get('provincia'),
                pais: formData.get('pais'),
                postal: formData.get('postal'),
                email: formData.get('email'),
                celular: formData.get('celular'),
                telfijo: formData.get('telfijo'),
                instagram: formData.get('instagram'),
                categoria: formData.get('categoria'),
                estatura: parseFloat(formData.get('estatura')) || null,
                peso: parseFloat(formData.get('peso')) || null,
                gimnasio: formData.get('gimnasio'),
                preparador_id: selectedPreparadorId || null,
                preparador: preparadorTexto,
                celular_preparador: formData.get('celular_preparador'),
                email_preparador: formData.get('email_preparador'),
                estatus_afiliacion: 'pendiente'
            };

            try {
                const response = await fetch('/atletas/solicitar-afiliacion', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(profileData)
                });

                const contentType = response.headers.get("content-type");
                if (!contentType || !contentType.includes("application/json")) {
                    throw new Error("Sesión expirada. Inicia sesión nuevamente.");
                }

                const result = await response.json();
                if (!result.estado) throw new Error(result.mensaje);

                sessionStorage.removeItem(STORAGE_KEY);
                // Mostrar panel de pago en lugar de redirigir
                document.getElementById('formMembresia').style.display = 'none';
                document.getElementById('panelPago').style.display = 'block';
                window.scrollTo({ top: 0, behavior: 'smooth' });
            } catch (err) {
                alert("Error al registrar: " + err.message);
                if (btn) btn.disabled = false;
            }
        });
    }

    // ── Subir comprobante de membresía ──────────────────────────────────────
    const formComprobante = document.getElementById('formComprobante');
    if (formComprobante) {
        formComprobante.addEventListener('submit', async (e) => {
            e.preventDefault();
            const archivo = document.getElementById('archivoComprobante').files[0];
            if (!archivo) return alert('Selecciona un archivo.');
            if (archivo.size > 5 * 1024 * 1024) return alert('El archivo es demasiado grande (máx. 5 MB).');

            const btn = document.getElementById('btnSubirComprobante');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Subiendo…';

            const fd = new FormData();
            fd.append('comprobante', archivo);

            try {
                const resp = await fetch('/atletas/subir-comprobante-membresia', { method: 'POST', body: fd });
                const json = await resp.json();
                if (!json.estado) throw new Error(json.mensaje);
                formComprobante.style.display = 'none';
                document.getElementById('msgComprobante').style.display = 'block';
            } catch (err) {
                alert('Error: ' + err.message);
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-paper-plane me-1"></i> Enviar Comprobante';
            }
        });
    }
</script>

<%- include("template/footer") %>
