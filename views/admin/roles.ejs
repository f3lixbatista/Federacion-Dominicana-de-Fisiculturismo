<%- include("../template/cabecera", {tituloWeb: "Gestión de Roles y Permisos"}) %>

<style>
    .rol-tab { cursor:pointer; transition:all .18s; border:2px solid transparent; }
    .rol-tab.activo { border-color: var(--bs-primary)!important; transform:scale(1.03); }
    .perm-table th { font-size:.8rem; text-align:center; vertical-align:middle; }
    .perm-table td { vertical-align:middle; }
    .perm-table td:not(:first-child) { text-align:center; }
    .form-check-input { width:1.3em; height:1.3em; cursor:pointer; }
    .badge-sistema { font-size:.65rem; }
    .saving-spinner { display:none; width:14px; height:14px; }
    .saving-spinner.show { display:inline-block; }
    #toast-perm {
        position:fixed; bottom:1.5rem; right:1.5rem; z-index:9999;
        min-width:220px;
    }
    #tabla-usuarios tbody td { vertical-align:middle; }
    #tabla-usuarios .form-select-sm { font-size:.82rem; }
</style>

<div class="p-3 divGeneral">

    <%# ─── CABECERA ─────────────────────────────────────────────────────── %>
    <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
        <div>
            <h4 class="mb-0"><i class="fas fa-shield-alt me-2 text-danger"></i>Roles y Permisos</h4>
            <small class="text-muted">Los cambios se aplican en tiempo real sin reiniciar el servidor.</small>
        </div>
        <div class="d-flex gap-2">
            <div class="spinner-border spinner-border-sm text-secondary saving-spinner" id="global-spinner" role="status"></div>
            <button class="btn btn-outline-secondary btn-sm" onclick="recargarCache()">
                <i class="fas fa-sync-alt me-1"></i>Recargar caché
            </button>
            <button class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#modalNuevoRol">
                <i class="fas fa-plus me-1"></i>Nuevo rol
            </button>
        </div>
    </div>

    <%# ─── PESTAÑAS PRINCIPALES ─────────────────────────────────────────── %>
    <ul class="nav nav-pills mb-3 border-bottom pb-2" role="tablist">
        <li class="nav-item">
            <button class="nav-link active" id="btn-tab-permisos"
                    data-bs-toggle="pill" data-bs-target="#tab-permisos"
                    type="button" role="tab">
                <i class="fas fa-lock me-1"></i>Permisos por Rol
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="btn-tab-usuarios"
                    data-bs-toggle="pill" data-bs-target="#tab-usuarios"
                    type="button" role="tab">
                <i class="fas fa-users me-1"></i>Usuarios y Roles
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="btn-tab-cuentas"
                    data-bs-toggle="pill" data-bs-target="#tab-cuentas"
                    type="button" role="tab">
                <i class="fas fa-university me-1"></i>Cuentas Bancarias
            </button>
        </li>
    </ul>

    <div class="tab-content">

        <%# ══════════════════════════════════════════════════════════════════ %>
        <%# TAB 1 — PERMISOS POR ROL                                         %>
        <%# ══════════════════════════════════════════════════════════════════ %>
        <div class="tab-pane fade show active" id="tab-permisos" role="tabpanel">

            <%# ─── TARJETAS DE ROLES ──────────────────────────────────────── %>
            <div class="d-flex flex-wrap gap-2 mb-4" id="roles-tabs">
                <% roles.forEach((rol, i) => { %>
                    <div class="card rol-tab px-3 py-2 <%= i===0 ? 'activo' : '' %>"
                         data-rol-id="<%= rol.id %>"
                         data-rol-nombre="<%= rol.nombre %>"
                         onclick="seleccionarRol(this)">
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge bg-<%= rol.color_badge %>"><%= rol.nombre %></span>
                            <% if (rol.es_sistema) { %>
                                <span class="badge bg-secondary badge-sistema"><i class="fas fa-lock"></i> sistema</span>
                            <% } else { %>
                                <button class="btn btn-link btn-sm text-danger p-0 ms-1"
                                        onclick="eliminarRol(event,'<%= rol.id %>','<%= rol.nombre %>')"
                                        title="Eliminar rol">
                                    <i class="fas fa-times-circle"></i>
                                </button>
                            <% } %>
                        </div>
                        <% if (rol.descripcion) { %>
                            <small class="text-muted d-block mt-1" style="font-size:.72rem;max-width:180px"><%= rol.descripcion %></small>
                        <% } %>
                    </div>
                <% }) %>
            </div>

            <%# ─── TABLA DE PERMISOS DEL ROL SELECCIONADO ─────────────────── %>
            <div class="card shadow-sm">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class="fas fa-table me-1"></i>
                    <span id="titulo-rol">Cargando…</span>
                    <span class="badge" id="badge-rol-sel"></span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-bordered perm-table mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th style="min-width:190px">Área</th>
                                    <th><i class="fas fa-eye me-1"></i>Ver</th>
                                    <th><i class="fas fa-plus me-1"></i>Crear</th>
                                    <th><i class="fas fa-pen me-1"></i>Editar</th>
                                    <th><i class="fas fa-trash me-1"></i>Eliminar</th>
                                </tr>
                            </thead>
                            <tbody id="perm-tbody">
                                <% AREAS.forEach(area => { %>
                                <tr data-area="<%= area.key %>">
                                    <td>
                                        <i class="<%= area.icono %> me-2 text-secondary"></i>
                                        <strong><%= area.label %></strong>
                                        <small class="text-muted ms-1" style="font-size:.7rem;opacity:.6"><%= area.key %></small>
                                    </td>
                                    <% ['ver','crear','editar','eliminar'].forEach(accion => { %>
                                    <td>
                                        <div class="form-check d-flex justify-content-center">
                                            <input class="form-check-input perm-check"
                                                   type="checkbox"
                                                   id="perm_<%= area.key %>_<%= accion %>"
                                                   data-area="<%= area.key %>"
                                                   data-accion="<%= accion %>"
                                                   onchange="guardarPermiso(this)">
                                        </div>
                                    </td>
                                    <% }) %>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div><%# fin #tab-permisos %>

        <%# ══════════════════════════════════════════════════════════════════ %>
        <%# TAB 2 — USUARIOS Y ROLES                                          %>
        <%# ══════════════════════════════════════════════════════════════════ %>
        <div class="tab-pane fade" id="tab-usuarios" role="tabpanel">

            <%# Resumen rápido por rol %>
            <div class="d-flex flex-wrap gap-2 mb-3" id="resumen-roles">
                <span class="text-muted small"><i class="fas fa-info-circle me-1"></i>Cargando resumen…</span>
            </div>

            <%# Filtros %>
            <div class="d-flex flex-wrap gap-2 mb-3 align-items-center">
                <input type="text" class="form-control form-control-sm" id="filtro-usuario"
                       placeholder="Buscar nombre, cédula, ID FDFF o email…"
                       oninput="filtrarUsuarios()"
                       style="max-width:320px">
                <select class="form-select form-select-sm" id="filtro-rol-usu"
                        onchange="filtrarUsuarios()"
                        style="max-width:150px">
                    <option value="">Todos los roles</option>
                    <% roles.forEach(r => { %>
                    <option value="<%= r.nombre %>"><%= r.nombre %></option>
                    <% }) %>
                </select>
                <small class="text-muted" id="contador-usuarios"></small>
            </div>

            <%# Tabla %>
            <div class="table-responsive">
                <table class="table table-hover table-sm" id="tabla-usuarios">
                    <thead class="table-dark">
                        <tr>
                            <th>Nombre</th>
                            <th>ID FDFF / Cédula</th>
                            <th>Email</th>
                            <th>Rol actual</th>
                            <th style="min-width:160px">Cambiar rol</th>
                        </tr>
                    </thead>
                    <tbody id="tbody-usuarios">
                        <tr><td colspan="5" class="text-center text-muted py-4" id="msg-usuarios-inicial">
                            <i class="fas fa-users me-1"></i>Cargando usuarios…
                        </td></tr>
                    </tbody>
                </table>
            </div>

        </div><%# fin #tab-usuarios %>

        <%# ══════════════════════════════════════════════════════════════════ %>
        <%# TAB 3 — CUENTAS BANCARIAS                                         %>
        <%# ══════════════════════════════════════════════════════════════════ %>
        <div class="tab-pane fade" id="tab-cuentas" role="tabpanel">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h6 class="fw-bold mb-0"><i class="fas fa-university me-1 text-primary"></i>Cuentas para transferencias</h6>
                    <small class="text-muted">Se muestran automáticamente en los formularios de afiliación e inscripción web.</small>
                </div>
                <button class="btn btn-success btn-sm fw-bold" onclick="abrirModalCuenta()">
                    <i class="fas fa-plus me-1"></i>Nueva Cuenta
                </button>
            </div>

            <div id="cuentas-loading" class="text-center py-4 text-muted">
                <span class="spinner-border spinner-border-sm me-2"></span>Cargando…
            </div>
            <div id="cuentas-tabla" style="display:none">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Banco</th>
                                <th>Número de Cuenta</th>
                                <th>Tipo</th>
                                <th>Titular</th>
                                <th>Moneda</th>
                                <th>Identificación</th>
                                <th class="text-center">Estado</th>
                                <th class="text-center" style="width:100px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="tbody-cuentas"></tbody>
                    </table>
                </div>
            </div>
            <div id="cuentas-vacio" style="display:none" class="text-center py-5 text-muted">
                <i class="fas fa-university fa-3x mb-3 d-block opacity-25"></i>
                No hay cuentas registradas. Agrega la primera con el botón "Nueva Cuenta".
            </div>

        </div><%# fin #tab-cuentas %>

    </div><%# fin .tab-content %>

<!-- MODAL CUENTAS BANCARIAS -->
<div class="modal fade" id="modalCuenta" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold" id="modalCuentaTitulo"><i class="fas fa-university me-2"></i>Nueva Cuenta Bancaria</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="cuentaId">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label fw-bold small">Institución Bancaria <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="cuentaBanco" placeholder="Ej: Banco Popular Dominicano">
                    </div>
                    <div class="col-md-8">
                        <label class="form-label fw-bold small">Número de Cuenta <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="cuentaNumero" placeholder="000-000000-0">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold small">Tipo de Cuenta</label>
                        <select class="form-select" id="cuentaTipo">
                            <option value="corriente">Corriente</option>
                            <option value="ahorros">Ahorros</option>
                            <option value="inversion">Inversión</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-bold small">Nombre del Titular <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="cuentaTitular" placeholder="Nombre completo o razón social">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold small">Moneda</label>
                        <select class="form-select" id="cuentaMoneda">
                            <option value="RD$">RD$ — Peso Dominicano</option>
                            <option value="USD">USD — Dólar Americano</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold small">Cédula / RNC <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="cuentaIdentificacion" placeholder="0-00-00000-0">
                    </div>
                    <div class="col-12">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="cuentaActiva" checked>
                            <label class="form-check-label fw-bold" for="cuentaActiva">Cuenta activa (visible en formularios)</label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary fw-bold px-4" onclick="guardarCuenta()">
                    <i class="fas fa-save me-1"></i>Guardar
                </button>
            </div>
        </div>
    </div>
</div>

</div><%# fin .divGeneral %>

<%# ─── MODAL NUEVO ROL ──────────────────────────────────────────────────── %>
<div class="modal fade" id="modalNuevoRol" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Nuevo Rol</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-2">
                    <label class="form-label form-label-sm">Nombre (clave interna)</label>
                    <input type="text" class="form-control form-control-sm" id="nr-nombre"
                           placeholder="ej: moderador" maxlength="40">
                </div>
                <div class="mb-2">
                    <label class="form-label form-label-sm">Descripción</label>
                    <input type="text" class="form-control form-control-sm" id="nr-desc" placeholder="Descripción breve">
                </div>
                <div class="mb-2">
                    <label class="form-label form-label-sm">Color badge</label>
                    <select class="form-select form-select-sm" id="nr-color">
                        <option value="secondary">Gris (secondary)</option>
                        <option value="primary">Azul (primary)</option>
                        <option value="success">Verde (success)</option>
                        <option value="info">Celeste (info)</option>
                        <option value="warning">Amarillo (warning)</option>
                        <option value="danger">Rojo (danger)</option>
                        <option value="dark">Oscuro (dark)</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-success btn-sm" onclick="guardarNuevoRol()">Crear Rol</button>
            </div>
        </div>
    </div>
</div>

<%# ─── TOAST DE CONFIRMACIÓN ────────────────────────────────────────────── %>
<div id="toast-perm" class="toast align-items-center border-0" role="alert">
    <div class="d-flex">
        <div class="toast-body" id="toast-msg">Guardado</div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
    </div>
</div>

<script>
// ── Datos globales ──────────────────────────────────────────────────────────
const _ROLES    = <%- JSON.stringify(roles) %>;
const _PERMISOS = <%- JSON.stringify(permisos) %>;
let _rolActual  = _ROLES[0] || null;
let _usuarios   = null;   // null = no cargado aún

const toastEl  = document.getElementById('toast-perm');
let bsToast = null;
try { bsToast = toastEl ? new bootstrap.Toast(toastEl, { delay: 2400 }) : null; } catch(e) {}
const spinner  = document.getElementById('global-spinner');

function mostrarToast(msg, ok = true) {
    if (!bsToast) return;
    toastEl.className = `toast align-items-center border-0 text-bg-${ok ? 'success' : 'danger'}`;
    document.getElementById('toast-msg').textContent = msg;
    bsToast.show();
}

// ══════════════════════════════════════════════════════════════════════════════
// TAB 1 — PERMISOS POR ROL
// ══════════════════════════════════════════════════════════════════════════════

function seleccionarRol(el) {
    document.querySelectorAll('.rol-tab').forEach(t => t.classList.remove('activo'));
    el.classList.add('activo');
    const rolId     = el.dataset.rolId;
    const rolNombre = el.dataset.rolNombre;
    _rolActual = _ROLES.find(r => r.id === rolId) || null;
    renderizarPermisos(rolNombre);
}

function renderizarPermisos(rolNombre) {
    const p = _PERMISOS[rolNombre] || {};
    document.getElementById('titulo-rol').textContent = rolNombre;
    const badgeEl = document.getElementById('badge-rol-sel');
    const rol = _ROLES.find(r => r.nombre === rolNombre);
    badgeEl.className = `badge bg-${rol?.color_badge || 'secondary'}`;
    badgeEl.textContent = rol?.es_sistema ? 'sistema' : 'personalizado';

    const esAdmin = rolNombre === 'admin';
    document.querySelectorAll('.perm-check').forEach(chk => {
        const area   = chk.dataset.area;
        const accion = chk.dataset.accion;
        chk.checked  = esAdmin ? true : !!(p[area]?.[accion]);
        chk.disabled = esAdmin;
    });
}

if (_rolActual) renderizarPermisos(_rolActual.nombre);

async function guardarPermiso(chk) {
    if (!_rolActual) return;
    spinner.classList.add('show');
    try {
        const res = await fetch('/admin/roles/permiso', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                rol_id: _rolActual.id,
                area:   chk.dataset.area,
                accion: chk.dataset.accion,
                valor:  chk.checked
            })
        });
        const json = await res.json();
        if (!json.ok) throw new Error(json.error);

        if (!_PERMISOS[_rolActual.nombre]) _PERMISOS[_rolActual.nombre] = {};
        if (!_PERMISOS[_rolActual.nombre][chk.dataset.area])
            _PERMISOS[_rolActual.nombre][chk.dataset.area] = {};
        _PERMISOS[_rolActual.nombre][chk.dataset.area][chk.dataset.accion] = chk.checked;

        mostrarToast(`${chk.dataset.area}.${chk.dataset.accion} → ${chk.checked ? 'activado' : 'desactivado'}`);
    } catch (e) {
        chk.checked = !chk.checked;
        mostrarToast('Error: ' + e.message, false);
    } finally {
        spinner.classList.remove('show');
    }
}

async function recargarCache() {
    try {
        const res = await fetch('/admin/roles/recargar', { method: 'POST' });
        const json = await res.json();
        if (json.ok) mostrarToast('Caché recargado correctamente');
        else throw new Error(json.error);
    } catch (e) {
        mostrarToast('Error: ' + e.message, false);
    }
}

async function guardarNuevoRol() {
    const nombre = document.getElementById('nr-nombre').value.trim();
    if (!nombre) return alert('El nombre es requerido');
    try {
        const res = await fetch('/admin/roles/crear', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                nombre,
                descripcion: document.getElementById('nr-desc').value.trim(),
                color_badge: document.getElementById('nr-color').value
            })
        });
        const json = await res.json();
        if (!json.ok) throw new Error(json.error);
        mostrarToast(`Rol "${nombre}" creado. Recargando…`);
        setTimeout(() => location.reload(), 1200);
    } catch (e) {
        mostrarToast('Error: ' + e.message, false);
    }
}

async function eliminarRol(evt, id, nombre) {
    evt.stopPropagation();
    if (!confirm(`¿Eliminar el rol "${nombre}"? Esta acción no se puede deshacer.`)) return;
    try {
        const res = await fetch(`/admin/roles/${id}`, { method: 'DELETE' });
        const json = await res.json();
        if (!json.ok) throw new Error(json.error);
        mostrarToast(`Rol "${nombre}" eliminado. Recargando…`);
        setTimeout(() => location.reload(), 1200);
    } catch (e) {
        mostrarToast('Error: ' + e.message, false);
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// TAB 2 — USUARIOS Y ROLES
// ══════════════════════════════════════════════════════════════════════════════

// Carga lazy: click directo (más fiable que shown.bs.tab con fade activo)
let _cargandoUsuarios = false;

(function() {
    const btnTab = document.getElementById('btn-tab-usuarios');
    function _intentarCargar() {
        if (_usuarios === null && !_cargandoUsuarios) cargarUsuarios();
    }
    // Fallback principal: click con pequeña demora para que Bootstrap cambie el pane
    btnTab.addEventListener('click', function() { setTimeout(_intentarCargar, 80); });
    // También escuchar el evento Bootstrap por si funciona
    btnTab.addEventListener('shown.bs.tab', _intentarCargar);
})();

async function cargarUsuarios() {
    _cargandoUsuarios = true;
    const tbody = document.getElementById('tbody-usuarios');
    tbody.innerHTML = '<tr><td colspan="5" class="text-center py-4"><span class="spinner-border spinner-border-sm me-2"></span>Cargando usuarios…</td></tr>';

    try {
        const res  = await fetch('/admin/roles/usuarios');
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const json = await res.json();
        if (!json.ok) throw new Error(json.error);

        _usuarios = json.usuarios;
        actualizarResumenRoles();
        renderizarUsuarios(_usuarios);
    } catch (e) {
        _cargandoUsuarios = false; // permite reintentar
        tbody.innerHTML = `<tr><td colspan="5" class="text-danger text-center py-3">
            <i class="fas fa-exclamation-triangle me-1"></i>${escHtml(e.message)}
            <button class="btn btn-sm btn-outline-danger ms-2" onclick="_cargandoUsuarios=false;cargarUsuarios()">Reintentar</button>
            </td></tr>`;
    }
}

function actualizarResumenRoles() {
    const conteo = {};
    (_usuarios || []).forEach(u => { conteo[u.role] = (conteo[u.role] || 0) + 1; });

    const el = document.getElementById('resumen-roles');
    const chips = _ROLES
        .filter(r => conteo[r.nombre])
        .map(r => `<span class="badge bg-${r.color_badge} me-1">${r.nombre}: ${conteo[r.nombre]}</span>`)
        .join('');
    el.innerHTML = chips || '<span class="text-muted small">Sin usuarios cargados</span>';
}

function filtrarUsuarios() {
    if (_usuarios === null) return;
    const texto = (document.getElementById('filtro-usuario').value || '').toLowerCase().trim();
    const rol   = document.getElementById('filtro-rol-usu').value;

    const lista = _usuarios.filter(u => {
        const matchTexto = !texto ||
            (u.nombre  || '').toLowerCase().includes(texto) ||
            (u.email   || '').toLowerCase().includes(texto) ||
            (u.cedula  || '').toLowerCase().includes(texto) ||
            String(u.id_fdff || '').toLowerCase().includes(texto);
        const matchRol = !rol || u.role === rol;
        return matchTexto && matchRol;
    });

    renderizarUsuarios(lista);
}

function renderizarUsuarios(lista) {
    const tbody = document.getElementById('tbody-usuarios');
    const total = (_usuarios || []).length;
    document.getElementById('contador-usuarios').textContent =
        total ? `${lista.length} de ${total} usuario${total !== 1 ? 's' : ''}` : '';

    if (!lista.length) {
        tbody.innerHTML = '<tr><td colspan="5" class="text-muted text-center py-3">Sin resultados para el filtro aplicado.</td></tr>';
        return;
    }

    const opcionesRol = _ROLES.map(r =>
        `<option value="${escHtml(r.nombre)}">${escHtml(r.nombre)}</option>`
    ).join('');

    tbody.innerHTML = lista.map(u => {
        const rolObj = _ROLES.find(r => r.nombre === u.role) || { color_badge: 'secondary', nombre: u.role || '—' };
        const opts   = _ROLES.map(r =>
            `<option value="${escHtml(r.nombre)}"${r.nombre === u.role ? ' selected' : ''}>${escHtml(r.nombre)}</option>`
        ).join('');

        const idFdff = u.id_fdff ? `<span class="fw-bold">${escHtml(String(u.id_fdff))}</span>` : '';
        const cedula = u.cedula  ? `<span class="text-muted">${escHtml(u.cedula)}</span>` : '';
        const sep    = idFdff && cedula ? ' / ' : '';

        return `<tr>
            <td>${escHtml(u.nombre || '(sin nombre)')}</td>
            <td class="small">${idFdff}${sep}${cedula}</td>
            <td class="small text-muted">${escHtml(u.email || '')}</td>
            <td><span class="badge bg-${escHtml(rolObj.color_badge)}" id="badge-u-${u.id}">${escHtml(rolObj.nombre)}</span></td>
            <td>
                <select class="form-select form-select-sm"
                        onchange="cambiarRolUsuario('${u.id}', this)"
                        data-rol-actual="${escHtml(u.role || '')}">
                    ${opts}
                </select>
            </td>
        </tr>`;
    }).join('');
}

async function cambiarRolUsuario(userId, selectEl) {
    const nuevoRol    = selectEl.value;
    const rolAnterior = selectEl.dataset.rolActual;
    if (nuevoRol === rolAnterior) return;

    spinner.classList.add('show');
    try {
        const res  = await fetch('/admin/roles/usuarios/cambiar-rol', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ user_id: userId, nuevo_rol: nuevoRol })
        });
        const json = await res.json();
        if (!json.ok) throw new Error(json.error);

        // Actualizar caché local
        const u = (_usuarios || []).find(u => u.id === userId);
        if (u) u.role = nuevoRol;
        selectEl.dataset.rolActual = nuevoRol;

        // Actualizar badge en la fila sin re-renderizar
        const rolObj = _ROLES.find(r => r.nombre === nuevoRol) || { color_badge: 'secondary' };
        const badge  = document.getElementById('badge-u-' + userId);
        if (badge) {
            badge.className   = `badge bg-${rolObj.color_badge}`;
            badge.textContent = nuevoRol;
        }

        actualizarResumenRoles();
        mostrarToast(`Rol cambiado a "${nuevoRol}"`);
    } catch (e) {
        selectEl.value = rolAnterior;
        mostrarToast('Error: ' + e.message, false);
    } finally {
        spinner.classList.remove('show');
    }
}

function escHtml(str) {
    if (str === null || str === undefined) return '';
    return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
}

// ══════════════════════════════════════════════════════════════════════════════
// TAB 3 — CUENTAS BANCARIAS
// ══════════════════════════════════════════════════════════════════════════════
let _cuentas = null;
let _cargandoCuentas = false;
const _modalCuenta = new bootstrap.Modal(document.getElementById('modalCuenta'));

(function() {
    const btn = document.getElementById('btn-tab-cuentas');
    function _intentarCargar() {
        if (_cuentas === null && !_cargandoCuentas) cargarCuentas();
    }
    btn.addEventListener('click', function() { setTimeout(_intentarCargar, 80); });
    btn.addEventListener('shown.bs.tab', _intentarCargar);
})();

async function cargarCuentas() {
    _cargandoCuentas = true;
    try {
        const res = await fetch('/admin/roles/cuentas');
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const json = await res.json();
        if (!json.ok) throw new Error(json.error);
        _cuentas = json.cuentas;
        renderizarCuentas();
    } catch (e) {
        _cargandoCuentas = false;
        document.getElementById('cuentas-loading').innerHTML =
            `<span class="text-danger"><i class="fas fa-exclamation-triangle me-1"></i>${escHtml(e.message)}
             <button class="btn btn-sm btn-outline-danger ms-2" onclick="_cargandoCuentas=false;cargarCuentas()">Reintentar</button></span>`;
    }
}

function renderizarCuentas() {
    document.getElementById('cuentas-loading').style.display = 'none';
    const tbody = document.getElementById('tbody-cuentas');
    if (!_cuentas.length) {
        document.getElementById('cuentas-vacio').style.display = 'block';
        document.getElementById('cuentas-tabla').style.display = 'none';
        return;
    }
    document.getElementById('cuentas-tabla').style.display = 'block';
    document.getElementById('cuentas-vacio').style.display = 'none';

    const tipoLabel = { corriente: 'Corriente', ahorros: 'Ahorros', inversion: 'Inversión' };
    tbody.innerHTML = _cuentas.map(c => `
        <tr class="${c.activa ? '' : 'table-secondary text-muted'}">
            <td class="fw-bold">${escHtml(c.banco)}</td>
            <td><code>${escHtml(c.numero_cuenta)}</code></td>
            <td>${escHtml(tipoLabel[c.tipo_cuenta] || c.tipo_cuenta)}</td>
            <td>${escHtml(c.titular)}</td>
            <td><span class="badge bg-secondary">${escHtml(c.moneda)}</span></td>
            <td class="small text-muted">${escHtml(c.identificacion)}</td>
            <td class="text-center">
                ${c.activa
                    ? '<span class="badge bg-success">Activa</span>'
                    : '<span class="badge bg-secondary">Inactiva</span>'}
            </td>
            <td class="text-center">
                <button class="btn btn-sm btn-outline-primary me-1" onclick="abrirModalCuenta(${c.id})" title="Editar">
                    <i class="fas fa-edit"></i>
                </button>
                <button class="btn btn-sm btn-outline-danger" onclick="eliminarCuenta(${c.id}, '${escHtml(c.banco)}')" title="Eliminar">
                    <i class="fas fa-trash"></i>
                </button>
            </td>
        </tr>`).join('');
}

function abrirModalCuenta(id) {
    const c = id ? (_cuentas || []).find(x => x.id === id) : null;
    document.getElementById('modalCuentaTitulo').innerHTML =
        `<i class="fas fa-university me-2"></i>${c ? 'Editar' : 'Nueva'} Cuenta Bancaria`;
    document.getElementById('cuentaId').value              = c ? c.id : '';
    document.getElementById('cuentaBanco').value           = c ? c.banco : '';
    document.getElementById('cuentaNumero').value          = c ? c.numero_cuenta : '';
    document.getElementById('cuentaTipo').value            = c ? c.tipo_cuenta : 'corriente';
    document.getElementById('cuentaTitular').value         = c ? c.titular : '';
    document.getElementById('cuentaMoneda').value          = c ? c.moneda : 'RD$';
    document.getElementById('cuentaIdentificacion').value  = c ? c.identificacion : '';
    document.getElementById('cuentaActiva').checked        = c ? c.activa : true;
    _modalCuenta.show();
}

async function guardarCuenta() {
    const banco          = document.getElementById('cuentaBanco').value.trim();
    const numero_cuenta  = document.getElementById('cuentaNumero').value.trim();
    const titular        = document.getElementById('cuentaTitular').value.trim();
    const identificacion = document.getElementById('cuentaIdentificacion').value.trim();
    if (!banco || !numero_cuenta || !titular || !identificacion)
        return alert('Completa los campos obligatorios.');

    try {
        const res = await fetch('/admin/roles/cuentas', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                id:             document.getElementById('cuentaId').value || undefined,
                banco,
                numero_cuenta,
                tipo_cuenta:    document.getElementById('cuentaTipo').value,
                titular,
                moneda:         document.getElementById('cuentaMoneda').value,
                identificacion,
                activa:         document.getElementById('cuentaActiva').checked
            })
        });
        const json = await res.json();
        if (!json.ok) throw new Error(json.error);
        _modalCuenta.hide();
        _cuentas = null; _cargandoCuentas = false;
        await cargarCuentas();
        mostrarToast('Cuenta guardada correctamente');
    } catch (e) {
        alert('Error: ' + e.message);
    }
}

async function eliminarCuenta(id, banco) {
    if (!confirm(`¿Eliminar la cuenta de "${banco}"? Esta acción no se puede deshacer.`)) return;
    try {
        const res = await fetch(`/admin/roles/cuentas/${id}`, { method: 'DELETE' });
        const json = await res.json();
        if (!json.ok) throw new Error(json.error);
        _cuentas = _cuentas.filter(c => c.id !== id);
        renderizarCuentas();
        mostrarToast('Cuenta eliminada');
    } catch (e) {
        alert('Error: ' + e.message);
    }
}
</script>

