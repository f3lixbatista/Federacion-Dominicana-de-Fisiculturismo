<%- include("../template/cabecera", {tituloWeb: evento.nombre}) %>

<div class="container my-4">
    <!-- BANNER Y TITULO -->
    <div class="card border-0 shadow-lg mb-4 overflow-hidden" style="border-radius: 20px;">
        <img src="<%= evento.banner_url || '/img/default-event.jpg' %>" class="w-100" style="height: 300px; object-fit: cover;">
        <div class="card-body p-4 bg-white">
            <div class="d-flex justify-content-between align-items-center">
                <h1 class="fw-bold mb-0"><%= evento.nombre %></h1>
                <span class="badge bg-primary p-2 fs-6"><%= evento.estado.toUpperCase() %></span>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- LADO IZQUIERDO: INFORMACIÓN E IMÁGENES -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm p-4 mb-4">
                <h4 class="fw-bold">Información General</h4>
                <p><%= evento.descripcion || 'Sin descripción disponible.' %></p>
                <hr>
                <div class="row g-2">
                    <% if(evento.imagenes_galeria) { %>
                        <% evento.imagenes_galeria.forEach(img => { %>
                            <div class="col-4"><img src="<%= img %>" class="img-fluid rounded"></div>
                        <% }) %>
                    <% } %>
                </div>
            </div>

            <!-- RESULTADOS (PUBLICO GENERAL) -->
            <% if(evento.estado === 'finalizado') { %>
                <div class="alert alert-success d-flex justify-content-between align-items-center p-4">
                    <h4 class="mb-0 fw-bold"><i class="fas fa-trophy"></i> Reporte de Resultados Finales</h4>
                    <a href="/eventos/<%= evento.id %>/resultados" class="btn btn-success fw-bold">Ver Resultados</a>
                </div>
            <% } %>
        </div>

        <!-- LADO DERECHO: ACCIONES SEGÚN ROL -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm p-4 sticky-top" style="top: 20px;">
                <h4 class="fw-bold mb-3 text-primary">Acciones Disponibles</h4>
                <div class="d-grid gap-3">
                    
                    <% if (locals.user) { %>
                        <!-- ROL ATLETA / ADMIN -->
                        <% if (['admin', 'atleta'].includes(user.role) && evento.estado === 'inscripcion') { %>
                            <a href="/inscripcion/IscripcionAtleta?evento=<%= evento.id %>" class="btn btn-primary btn-lg fw-bold">
                                <i class="fas fa-edit"></i> SELECCIÓN WEB
                            </a>
                        <% } %>

                        <!-- ROL ADMIN / ESTADISTICO / JUEZ -->
                        <% if (['admin', 'estadistico', 'juez'].includes(user.role)) { %>
                            <div class="border-top pt-3 mt-2">
                                <p class="small fw-bold text-muted mb-2">PERSONAL TÉCNICO</p>
                                <a href="/inscripcion/pesaje?evento=<%= evento.id %>" class="btn btn-dark w-100 mb-2">
                                    <i class="fas fa-balance-scale"></i> PESAJE Y MEDICIÓN
                                </a>
                                <a href="/votacion?evento=<%= evento.id %>" class="btn btn-outline-dark w-100">
                                    <i class="fas fa-clipboard-check"></i> BOLETAS DE VOTACIÓN
                                </a>
                            </div>
                        <% } %>

                        <!-- ROL ADMIN / ESTADISTICO / EJECUTIVO -->
                        <% if (['admin', 'estadistico', 'ejecutivo'].includes(user.role)) { %>
                            <div class="border-top pt-3 mt-2">
                                <p class="small fw-bold text-muted mb-2">PERSONAL ESTADÍSTICO</p>
                                <a href="/inscripcion?evento=<%= evento.id %>" class="btn btn-danger w-100 mb-2 fw-bold text-dark">
                                    <i class="fas fa-user-plus"></i> INSCRIPCIÓN ASISTIDA
                                </a>
                                 <a href="/votacion?evento=<%= evento.id %>" class="btn btn-outline-danger w-100 text-dark">
                                    <i class="fas fa-clipboard-check"></i> MODULO ESTADÍSTICO
                                </a>
                            </div>
                        <% } %>

                         <!-- ROL ADMIN / ESTADISTICO / EJECUTIVO -->
                        <% if (['admin', 'estadistico', 'ejecutivo'].includes(user.role)) { %>
                            <div class="border-top pt-3 mt-2">
                                <p class="small fw-bold text-muted mb-2">GESTIÓN ADMINISTRATIVA</p>
                                <a href="/preparacion-evento/<%= evento.id %>" class="btn btn-warning w-100 mb-2 fw-bold">
                                    <i class="fas fa-user-plus"></i> PREPARACIÓN DE EVENTO
                                </a>
                                <a href= "/inscripcion?evento=<%= evento.id %>" class="btn btn-outline-warning text-dark w-100">
                                    <i class="fas fa-tasks"></i> PROGRAMA DE COMPETENCIA
                                </a>
                            </div>
                        <% } %>

                    <% } else { %>
                        <div class="alert alert-light text-center">
                            <p class="small mb-2 text-muted">Inicia sesión para ver opciones adicionales</p>
                            <a href="/login" class="btn btn-dark w-100">Iniciar Sesión</a>
                        </div>
                    <% } %>
                    
                </div>
            </div>
        </div>
    </div>
</div>

<%- include("../template/footer") %>
