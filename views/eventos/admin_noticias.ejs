<%- include("../template/cabecera", {tituloWeb: "Publicar Noticia"}) %>

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 p-4" style="border-radius: 20px;">
                <h4 class="fw-bold mb-4"><i class="fas fa-newspaper text-primary me-2"></i> Publicar Noticia / Comunicado</h4>
                <form action="/social/publicar-noticia" method="POST" enctype="multipart/form-data">
                    <input type="text" name="titulo" class="form-control mb-3" placeholder="Título de la noticia" required>
                    <textarea name="contenido" class="form-control mb-3" rows="5" placeholder="Contenido del anuncio..."></textarea>
                    <label class="form-label small fw-bold">Imagen de portada:</label>
                    <input type="file" name="imagen" class="form-control mb-3" accept="image/*">
                    <div class="form-check form-switch mb-4">
                        <input class="form-check-input" type="checkbox" name="destacado" id="switchDestacado">
                        <label class="form-check-label" for="switchDestacado">Noticia Destacada (Aparecerá en el inicio)</label>
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow">PUBLICAR AHORA</button>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include("../template/footer") %>