<%- include("../template/cabecera", {tituloWeb: "Próximos Eventos"}) %>

<%
const hoyComp = new Date().toISOString().split('T')[0];
const eventosAbiertos  = eventos.filter(ev => ev.estado !== 'cerrado' && !(ev.estado === 'inscripcion' && ev.fecha_inicio && ev.fecha_inicio.slice(0,10) < hoyComp));
const eventosCerrados  = eventos.filter(ev => ev.estado === 'cerrado'  || (ev.estado === 'inscripcion' && ev.fecha_inicio && ev.fecha_inicio.slice(0,10) < hoyComp));
%>

<div class="container my-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">Calendario de Eventos FDFF</h1>
        <p class="lead text-muted">Explora nuestras próximas competencias y eventos oficiales.</p>
    </div>

    <!-- EVENTOS ABIERTOS -->
    <% if (eventosAbiertos.length > 0) { %>
        <div class="row g-4 mb-5">
            <% eventosAbiertos.forEach(evento => {
                const estadoBadge = {
                    inscripcion: { txt: 'Inscripciones Abiertas', cls: 'success' },
                    pesaje:      { txt: 'En Pesaje',              cls: 'warning' },
                    competencia: { txt: 'En Curso',               cls: 'danger'  }
                }[evento.estado] || { txt: evento.estado, cls: 'secondary' };
            %>
                <div class="col-md-4" id="evento-<%= evento.id %>">
                    <div class="card h-100 border-0 shadow-lg" style="border-radius: 20px; overflow: hidden;">
                        <img src="<%= evento.url_afiche_evento || '/img/default-event.jpg' %>"
                             class="card-img-top" style="height: 220px; object-fit: cover;">
                        <div class="card-body p-4">
                            <span class="badge mb-2 bg-<%= estadoBadge.cls %>"><%= estadoBadge.txt %></span>
                            <h4 class="fw-bold"><%= evento.nombre %></h4>
                            <p class="text-muted small mb-3">
                                <i class="fas fa-map-marker-alt"></i> <%= evento.lugar %><br>
                                <i class="fas fa-calendar"></i> <%= evento.fecha_inicio %>
                            </p>

                            <% if (evento.info_boletas) { %>
                                <div class="p-3 bg-light rounded border-start border-success border-3 mb-3">
                                    <p class="fw-bold small text-success mb-1"><i class="fas fa-ticket-alt me-1"></i> Información de Boletas</p>
                                    <p class="small text-dark mb-0" style="white-space:pre-wrap;"><%= evento.info_boletas %></p>
                                </div>
                            <% } %>

                            <div class="d-grid gap-2">
                                <% if (locals.user && ['admin','ejecutivo','estadistico'].includes(locals.user.role)) { %>
                                    <a href="/eventos/<%= evento.id %>" class="btn btn-primary fw-bold">
                                        <i class="fas fa-arrow-right me-1"></i> Ver Evento
                                    </a>
                                <% } %>
                                <% if (locals.user && locals.user.role === 'atleta' && evento.estado === 'inscripcion') { %>
                                    <a href="/inscripcion/InscripcionAtleta?evento=<%= evento.id %>" class="btn btn-success fw-bold">
                                        <i class="fas fa-clipboard-list me-1"></i> Inscribirme
                                    </a>
                                <% } %>
                                <% if (evento.info_boletas) { %>
                                    <button class="btn btn-outline-success fw-bold"
                                            onclick="verBoletas('<%= encodeURIComponent(evento.nombre) %>', '<%= encodeURIComponent(evento.info_boletas) %>')">
                                        <i class="fas fa-ticket-alt me-1"></i> Adquirir Boletas
                                    </button>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
        <% if (eventosCerrados.length > 0) { %>
            <hr class="mb-5">
        <% } %>
    <% } %>

    <!-- EVENTOS REALIZADOS -->
    <% if (eventosCerrados.length > 0) { %>
        <h5 class="fw-bold text-secondary mb-4"><i class="fas fa-flag-checkered me-2"></i> Eventos Realizados</h5>
        <div class="row g-4">
            <% eventosCerrados.forEach(evento => { %>
                <div class="col-md-4" id="evento-<%= evento.id %>">
                    <div class="card h-100 border-0 shadow" style="border-radius: 20px; overflow: hidden; opacity:.85;">
                        <img src="<%= evento.url_afiche_evento || '/img/default-event.jpg' %>"
                             class="card-img-top" style="height: 200px; object-fit: cover; filter:grayscale(20%);">
                        <div class="card-body p-4">
                            <span class="badge mb-2 bg-secondary">Evento Realizado</span>
                            <h4 class="fw-bold"><%= evento.nombre %></h4>
                            <p class="text-muted small mb-3">
                                <i class="fas fa-map-marker-alt"></i> <%= evento.lugar %><br>
                                <i class="fas fa-calendar"></i> <%= evento.fecha_inicio %>
                            </p>
                            <div class="d-grid gap-2">
                                <a href="/eventos/historico" class="btn btn-outline-dark fw-bold">
                                    <i class="fas fa-list-ol me-1"></i> Ver Resultados
                                </a>
                                <a href="/estadisticas/gestion-absolutos" class="btn btn-outline-secondary btn-sm fw-bold">
                                    <i class="fas fa-users me-1"></i> Ranking por Equipo
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>

    <% if (eventos.length === 0) { %>
        <div class="col-12 text-center py-5">
            <h3 class="text-muted">No hay eventos disponibles actualmente.</h3>
        </div>
    <% } %>
</div>

<!-- Modal: Info de boletas -->
<div class="modal fade" id="modalBoletas" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius:20px;">
            <div class="modal-header bg-success text-white border-0" style="border-radius:20px 20px 0 0;">
                <h5 class="modal-title fw-bold"><i class="fas fa-ticket-alt me-2"></i> <span id="modalBoletasEvento"></span></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <h6 class="fw-bold text-success mb-3">Información para adquirir boletas:</h6>
                <p id="modalBoletasInfo" class="text-dark lh-lg" style="white-space:pre-wrap;"></p>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<script>
    function verBoletas(nombre, info) {
        document.getElementById('modalBoletasEvento').textContent = decodeURIComponent(nombre);
        document.getElementById('modalBoletasInfo').textContent   = decodeURIComponent(info);
        new bootstrap.Modal(document.getElementById('modalBoletas')).show();
    }

    // Scroll suave al evento si viene con anchor
    window.addEventListener('DOMContentLoaded', () => {
        const hash = window.location.hash;
        if (hash) {
            const el = document.querySelector(hash);
            if (el) el.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
    });
</script>

<%- include("../template/footer") %>
