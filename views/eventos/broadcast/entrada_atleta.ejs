<%- include("../../template/cabecera", {tituloWeb: "LED Wall - FDFF Live"}) %>

<style>
  /* ── Modo transparente para OBS/Vmix ── */
  html, body, #main-content { background: transparent !important; overflow: hidden; margin: 0; padding: 0; }
  aside#sidebar, #topbar { display: none !important; }
  #main-content { margin: 0 !important; padding: 0 !important; }

  :root {
    --led-bg1: #0d1b4b;
    --led-bg2: #1a3a8f;
    --led-glow: rgba(26,58,143,.5);
  }

  .escenario {
    position: fixed;
    inset: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    background: radial-gradient(ellipse at center, var(--led-bg1) 0%, var(--led-bg2) 100%);
    transition: background .8s ease, opacity .5s ease;
  }

  /* ── Foto atlética ── */
  .foto-wrap {
    position: relative;
    height: 82vh;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    filter: drop-shadow(0 0 30px var(--led-glow));
    animation: pulsoFuego 2.5s infinite alternate;
    transition: opacity .5s ease;
  }
  .foto-wrap img {
    height: 100%;
    object-fit: contain;
    max-width: 60vw;
  }
  @keyframes pulsoFuego {
    from { filter: drop-shadow(0 0 20px rgba(255,69,0,.45)); }
    to   { filter: drop-shadow(0 0 60px rgba(255,140,0,.8)); transform: scale(1.015); }
  }

  /* ── Cinta superior de categoría ── */
  .cinta-categoria {
    position: fixed;
    top: 32px; right: 0;
    background: #000;
    color: #f1c40f;
    padding: 10px 44px 10px 20px;
    font-weight: 900;
    text-transform: uppercase;
    border-left: 6px solid #f1c40f;
    font-size: clamp(1rem, 2vw, 1.5rem);
    letter-spacing: 2px;
    box-shadow: -6px 6px 20px rgba(0,0,0,.4);
    z-index: 20;
    transition: opacity .4s ease, transform .4s ease;
  }

  /* ── Lower Third de atleta ── */
  .cinta-atleta {
    position: fixed;
    bottom: 42px; left: 50%;
    transform: translateX(-50%);
    width: 88%;
    background: linear-gradient(90deg, rgba(0,45,114,.92) 0%, rgba(206,17,38,.92) 100%);
    color: white;
    padding: 18px 24px;
    border-radius: 14px;
    border-left: 10px solid #f1c40f;
    box-shadow: 0 10px 40px rgba(0,0,0,.6);
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 20;
    animation: entradaCinta .8s cubic-bezier(.22,1,.36,1);
    transition: opacity .4s ease;
  }
  @keyframes entradaCinta {
    from { transform: translate(-50%, 80px); opacity: 0; }
    to   { transform: translate(-50%, 0);    opacity: 1; }
  }

  /* ── Lower Third de MENSAJE ── */
  .cinta-mensaje {
    position: fixed;
    bottom: 42px; left: 50%;
    transform: translateX(-50%);
    width: 88%;
    color: white;
    padding: 20px 28px;
    border-radius: 14px;
    border-left: 10px solid #f1c40f;
    box-shadow: 0 10px 40px rgba(0,0,0,.7);
    z-index: 30;
    animation: entradaCinta .8s cubic-bezier(.22,1,.36,1);
    transition: opacity .4s ease;
    display: none;
    text-align: center;
    font-size: clamp(1.2rem, 3vw, 2rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
  }
  .cinta-mensaje.estilo-info        { background: linear-gradient(90deg,rgba(0,62,133,.95),rgba(0,114,255,.9)); }
  .cinta-mensaje.estilo-advertencia { background: linear-gradient(90deg,rgba(90,60,0,.95),rgba(200,140,0,.95)); color:#000; }
  .cinta-mensaje.estilo-celebracion { background: linear-gradient(90deg,rgba(140,0,0,.95),rgba(206,17,38,.95)); }
  .cinta-mensaje.estilo-neutro      { background: linear-gradient(90deg,rgba(10,10,10,.96),rgba(30,30,30,.95)); }

  /* ── Overlay de PODIO ── */
  .podio-overlay {
    position: fixed;
    inset: 0;
    z-index: 40;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: radial-gradient(ellipse,rgba(180,130,0,.18) 0%,rgba(0,0,0,.85) 100%);
    animation: fadeInOverlay .6s ease;
  }
  @keyframes fadeInOverlay { from { opacity: 0; } to { opacity: 1; } }

  .podio-titulo {
    color: #ffd700;
    font-size: clamp(1.5rem, 4vw, 3rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 4px;
    text-shadow: 0 0 30px rgba(255,215,0,.7);
    margin-bottom: 2rem;
  }
  .podio-grid { display: flex; gap: 1.5rem; align-items: flex-end; justify-content: center; flex-wrap: wrap; }
  .podio-card {
    border-radius: 16px;
    padding: 1.5rem 1rem;
    text-align: center;
    min-width: 180px;
    animation: subirPodio .7s cubic-bezier(.22,1,.36,1) both;
  }
  .podio-card:nth-child(1) { animation-delay: .1s; }
  .podio-card:nth-child(2) { animation-delay: .3s; }
  .podio-card:nth-child(3) { animation-delay: .5s; }
  @keyframes subirPodio {
    from { transform: translateY(60px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }
  .podio-card.pos-1 { background: linear-gradient(160deg,#b8860b,#ffd700); color:#000; transform:scale(1.08); }
  .podio-card.pos-2 { background: linear-gradient(160deg,#5c5c5c,#c0c0c0); color:#000; }
  .podio-card.pos-3 { background: linear-gradient(160deg,#7c3d0a,#cd7f32); color:#fff; }
  .podio-trofeo { font-size: 3rem; }
  .podio-nombre { font-weight: 900; font-size: 1.1rem; margin-top:.5rem; }
  .podio-detalle { font-size:.82rem; opacity:.8; }
</style>

<!-- ── Escenario principal (foto + cinta atleta) ── -->
<div class="escenario" id="escenario">
  <div class="cinta-categoria" id="displayCategoria"><%= atleta.categoria %></div>

  <div class="foto-wrap" id="fotoWrap">
    <img src="<%= atleta.foto_atletica_url || '/img/placeholder_poses.png' %>" id="displayFoto" alt="">
  </div>

  <div class="cinta-atleta" id="cintaAtleta">
    <div>
      <h1 class="fw-bold mb-0 text-uppercase" id="displayNombre" style="font-size:clamp(1.3rem,3vw,2.2rem)"><%= atleta.nombre %></h1>
      <h5 class="mb-0 opacity-75" id="displayOrigen"><%= atleta.provincia %> | <%= atleta.preparador %></h5>
    </div>
    <div class="text-end">
      <div class="badge bg-warning text-dark fw-bold mb-1" id="displayDorsal" style="font-size:clamp(1rem,2vw,1.4rem)">DORSAL <%= atleta.dorsal %></div>
      <div class="small fw-bold" id="displayTecnico"><%= atleta.peso %> KG | <%= atleta.estatura %> CM | <%= atleta.edad %> AÑOS</div>
    </div>
  </div>

  <!-- Mensaje lower third (superpuesto) -->
  <div class="cinta-mensaje estilo-info" id="cintaMensaje"></div>
</div>

<!-- ── Overlay de Podio (pantalla completa) ── -->
<div class="podio-overlay" id="podioOverlay">
  <div class="podio-titulo" id="podioTitulo">Resultados Oficiales</div>
  <div class="podio-grid" id="podioGrid"></div>
</div>

<script src="/js/supabase.js"></script>
<script>
const _supabase = supabase.createClient("<%= SUPABASE_URL %>", "<%= SUPABASE_ANON_KEY %>");
const eventoId = "<%= eventoId %>";

// ─── TTS ────────────────────────────────────────────────────────────────────

function hablar(texto) {
    if (!window.speechSynthesis) return;
    window.speechSynthesis.cancel();
    const msg = new SpeechSynthesisUtterance(texto);
    msg.lang = 'es-DO';
    msg.rate = 0.9;
    window.speechSynthesis.speak(msg);
}

// ─── MANEJADORES DE TIPOS ────────────────────────────────────────────────────

function ocultarTodo() {
    document.getElementById('cintaMensaje').style.display = 'none';
    document.getElementById('podioOverlay').style.display = 'none';
    document.getElementById('cintaAtleta').style.opacity = '1';
    document.getElementById('cintaAtleta').style.display = 'flex';
    document.getElementById('cintaCategoria')?.style.setProperty('opacity', '1');
}

async function manejarAtletaEntrada(data) {
    document.getElementById('cintaMensaje').style.display = 'none';
    document.getElementById('podioOverlay').style.display = 'none';

    const { data: c, error } = await _supabase
        .from('competidores')
        .select('numero_atleta, foto_atletica_url, atletas(nombre, provincia, preparador, peso, estatura, fecha_nacimiento)')
        .eq('id_evento', eventoId)
        .eq('atleta_id', data.atleta_id)
        .single();

    if (error || !c) return;

    const atl = c.atletas;
    const edad = atl?.fecha_nacimiento
        ? new Date().getFullYear() - new Date(atl.fecha_nacimiento).getFullYear()
        : '--';

    const escenario = document.getElementById('escenario');
    escenario.style.opacity = '0';

    setTimeout(() => {
        document.getElementById('displayFoto').src = c.foto_atletica_url || '/img/placeholder_poses.png';
        document.getElementById('displayNombre').textContent = atl?.nombre || '—';
        document.getElementById('displayOrigen').textContent = `${atl?.provincia || 'N/A'} | ${atl?.preparador || 'Independiente'}`;
        document.getElementById('displayDorsal').textContent = `DORSAL ${c.numero_atleta || '00'}`;
        document.getElementById('displayTecnico').textContent = `${atl?.peso || '--'} KG | ${atl?.estatura || '--'} CM | ${edad} AÑOS`;
        document.getElementById('displayCategoria').textContent = data.categoria_nombre || 'Competencia';
        document.getElementById('cintaAtleta').style.display = 'flex';
        escenario.style.opacity = '1';
        hablar(`Atleta número ${c.numero_atleta}, ${atl?.nombre}, del equipo ${atl?.preparador || 'Independiente'}`);
    }, 500);
}

function manejarMensaje(data) {
    document.getElementById('podioOverlay').style.display = 'none';
    document.getElementById('cintaAtleta').style.display = 'none';

    const el = document.getElementById('cintaMensaje');
    el.className = 'cinta-mensaje estilo-' + (data.estilo || 'info');
    el.textContent = data.texto || '';
    el.style.display = 'block';

    if (data.texto) hablar(data.texto);
}

function manejarPodio(data) {
    document.getElementById('cintaMensaje').style.display = 'none';
    document.getElementById('cintaAtleta').style.display = 'none';

    const overlay = document.getElementById('podioOverlay');
    document.getElementById('podioTitulo').textContent = data.categoria_nombre || 'Resultados Oficiales';

    const trofeos = { 1:'🥇', 2:'🥈', 3:'🥉' };
    const clases  = { 1:'pos-1', 2:'pos-2', 3:'pos-3' };

    document.getElementById('podioGrid').innerHTML = (data.top3 || []).map(p => `
        <div class="podio-card ${clases[p.posicion] || ''}">
            <div class="podio-trofeo">${trofeos[p.posicion] || '🏅'}</div>
            <div class="podio-nombre">${p.nombre || '—'}</div>
            <div class="podio-detalle">${p.provincia || ''}</div>
            ${p.preparador ? `<div class="podio-detalle">Coach: ${p.preparador}</div>` : ''}
        </div>`).join('');

    overlay.style.display = 'flex';

    const top1 = data.top3?.find(p => p.posicion === 1);
    if (top1) {
        setTimeout(() => hablar(`Campeón de ${data.categoria_nombre || 'la categoría'}: ${top1.nombre}`), 800);
    }
}

function manejarEscena(data) {
    const root = document.documentElement;
    root.style.setProperty('--led-bg1', data.grad1 || '#0d1b4b');
    root.style.setProperty('--led-bg2', data.grad2 || '#1a3a8f');
}

function manejarLimpiar() {
    const escenario = document.getElementById('escenario');
    escenario.style.opacity = '0';
    setTimeout(() => {
        document.getElementById('cintaMensaje').style.display = 'none';
        document.getElementById('podioOverlay').style.display = 'none';
        document.getElementById('cintaAtleta').style.display = 'flex';
        document.getElementById('displayNombre').textContent = '—';
        document.getElementById('displayOrigen').textContent = '';
        document.getElementById('displayDorsal').textContent = 'FDFF LIVE';
        document.getElementById('displayTecnico').textContent = 'Federación Dominicana de Fisiculturismo · IFBB';
        document.getElementById('displayFoto').src = '/img/placeholder_poses.png';
        document.getElementById('displayCategoria').textContent = '';
        escenario.style.opacity = '1';
    }, 500);
}

// ─── REALTIME ────────────────────────────────────────────────────────────────

_supabase.channel('led-wall')
    .on('postgres_changes', {
        event: 'UPDATE',
        schema: 'public',
        table: 'eventos',
        filter: `id=eq.${eventoId}`
    }, ({ new: row }) => {
        const d = row.resultados_en_vivo;
        if (!d) return;
        switch (d.tipo) {
            case 'atleta_entrada': manejarAtletaEntrada(d); break;
            case 'mensaje':        manejarMensaje(d);       break;
            case 'podio':          manejarPodio(d);         break;
            case 'escena':         manejarEscena(d);        break;
            case 'limpiar':        manejarLimpiar();        break;
        }
    }).subscribe();

// ─── CARGA INICIAL SSR ───────────────────────────────────────────────────────

window.addEventListener('DOMContentLoaded', () => {
    setTimeout(() => {
        hablar(`Atleta número <%= atleta.dorsal %>, <%= atleta.nombre %>, del equipo <%= atleta.preparador %>`);
    }, 1200);
});
</script>
<%- include("../../template/footer") %>
