<%- include("../template/cabecera", {tituloWeb: "Auditoría de Recaudación"}) %>

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="fas fa-cash-register text-success"></i> Auditoría: <%= evento.nombre %></h2>
        <div class="text-end">
            <span class="text-muted d-block small">TOTAL RECAUDADO:</span>
            <h2 class="text-success fw-bold">RD$ <%= granTotal.toLocaleString() %></h2>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <table class="table table-hover align-middle" id="tablaRecaudacion">
                <thead class="table-light">
                    <tr>
                        <th>Atleta</th>
                        <th>Cédula</th>
                        <th class="text-center">Categorías</th>
                        <th class="text-end">Monto Generado</th>
                    </tr>
                </thead>
                <tbody>
                    <% recaudacion.forEach(atl => { %>
                        <tr>
                            <td class="fw-bold"><%= atl.nombre %></td>
                            <td><%= atl.cedula %></td>
                            <td class="text-center"><span class="badge bg-dark"><%= atl.cant %></span></td>
                            <td class="text-end fw-bold text-primary">RD$ <%= atl.monto.toLocaleString() %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
    <div class="mt-4 no-print">
        <button onclick="window.print()" class="btn btn-outline-dark"><i class="fas fa-print"></i> Imprimir Informe</button>
    </div>
</div>

<script>
    $(document).ready(function() {
        $('#tablaRecaudacion').DataTable({
            "dom": 'Bfrtip',
            "buttons": ['excel', 'pdf']
        });
    });
</script>

<%- include("../template/footer") %>