<%- include("../template/cabecera", {tituloWeb: "Balance del Evento - FDFF"}) %>

<div class="container my-5">
    <div class="row g-4">
        <!-- Dashboard de Totales -->
        <div class="col-md-4">
            <div class="card bg-success text-white p-4 shadow-sm border-0">
                <h6 class="text-uppercase small">Total Ingresos</h6>
                <h2 class="fw-bold">RD$ <%= (totalInscripciones + totalExtra).toLocaleString() %></h2>
                <small>Inscripciones + Patrocinios/Tickets</small>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-danger text-white p-4 shadow-sm border-0">
                <h6 class="text-uppercase small">Total Gastos</h6>
                <h2 class="fw-bold">RD$ <%= totalGastos.toLocaleString() %></h2>
                <small>Operación y Logística</small>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card <%= (totalInscripciones + totalExtra - totalGastos) >= 0 ? 'bg-dark' : 'bg-warning' %> text-white p-4 shadow-sm border-0">
                <h6 class="text-uppercase small">Balance Final</h6>
                <h2 class="fw-bold">RD$ <%= (totalInscripciones + totalExtra - totalGastos).toLocaleString() %></h2>
                <small>Utilidad Neta del Evento</small>
            </div>
        </div>

        <!-- Formularios de Registro Rápido -->
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 p-4">
                <h5 class="fw-bold text-success mb-3"><i class="fas fa-plus-circle"></i> Otros Ingresos (Tickets/Patrocinio)</h5>
                <form action="/eventos/ingreso-extra" method="POST" class="row g-2">
                    <input type="hidden" name="evento_id" value="<%= evento.id %>">
                    <div class="col-8">
                        <input type="text" name="concepto" class="form-control" placeholder="Ej: Venta 50 Boletas VIP" required>
                    </div>
                    <div class="col-4">
                        <input type="number" name="monto" class="form-control" placeholder="Monto" required>
                    </div>
                    <button class="btn btn-success w-100 mt-2 fw-bold">Registrar Ingreso</button>
                </form>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm border-0 p-4">
                <h5 class="fw-bold text-danger mb-3"><i class="fas fa-minus-circle"></i> Registro de Gastos</h5>
                <form action="/eventos/gasto-operativo" method="POST" class="row g-2" enctype="multipart/form-data">
                    <input type="hidden" name="evento_id" value="<%= evento.id %>">
                    <div class="col-8">
                        <input type="text" name="concepto" class="form-control" placeholder="Ej: Pago de Trofeos" required>
                    </div>
                    <div class="col-4">
                        <input type="number" name="monto" class="form-control" placeholder="Monto" required>
                    </div>
                    <div class="col-12 mt-2">
                        <label class="small fw-bold">Foto del Recibo / Factura (Opcional)</label>
                        <input type="file" name="recibo_foto" class="form-control form-control-sm" accept="image/*">
                    </div>
                    <button class="btn btn-danger w-100 mt-2 fw-bold">Registrar Gasto</button>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include("../template/footer") %>