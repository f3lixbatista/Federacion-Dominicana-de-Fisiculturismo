<%- include("../template/cabecera", {tituloWeb: "Centro de Mando FDFF"}) %>

<div class="container-fluid my-4 px-5">
    <!-- SECCIÓN: HERRAMIENTAS DE CAMPO (STAFF) -->
    <div class="card shadow-sm border-0 mb-4" style="border-radius: 15px;">
        <div class="card-header bg-dark text-white fw-bold"><i class="fas fa-tools me-2 text-warning"></i> Herramientas de Campo</div>
        <div class="card-body d-flex flex-wrap gap-3">
            <a href="/eventos/<%= evento.id %>/backstage-seguridad" class="btn btn-outline-danger fw-bold">
                <i class="fas fa-shield-alt me-1"></i> Portería (Escanear QR)
            </a>
            <a href="/eventos/<%= evento.id %>/recaudacion" class="btn btn-outline-success fw-bold">
                <i class="fas fa-money-bill-wave me-1"></i> Dashboard de Cobros
            </a>
            <a href="/eventos/<%= evento.id %>/dj-consola" class="btn btn-outline-primary fw-bold">
                <i class="fas fa-music me-1"></i> Consola DJ
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- SECCIÓN A: ESTADO DEL SHOW (LOGÍSTICA) -->
        <div class="col-lg-3">
            <div class="card shadow-sm border-0 h-100" style="border-radius: 15px;">
                <div class="card-header bg-dark text-white fw-bold">⚙️ Logística y Mesa Técnica</div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="/eventos/preparacion-evento/<%= evento.id %>" class="btn btn-outline-primary text-start">
                            <i class="fas fa-users-cog me-2"></i> Configurar Panel y Sillas
                        </a>
                        <a href="/inscripcion?evento=<%= evento.id %>" class="btn btn-outline-primary text-start">
                            <i class="fas fa-weight me-2"></i> Registro y Pesaje (Dorsales)
                        </a>
                        <a href="/admin/registro_staff" class="btn btn-outline-dark text-start">
                            <i class="fas fa-user-shield me-2"></i> Administrar Staff / Jueces
                        </a>
                        <!-- Botón duplicado eliminado para mayor limpieza visual -->
                        <a href="/estadisticas/<%= evento.id %>/imprimir-boletas" class="btn btn-outline-dark text-start" target="_blank">
                            <i class="fas fa-print me-2"></i> Boletas Físicas (Respaldo PDF)
                        </a>
                        <a href="/social/admin-noticias" class="btn btn-outline-info text-start">
                            <i class="fas fa-bullhorn me-2"></i> Publicar Comunicado Oficial
                        </a>
                        <a href="/eventos/editar/<%= evento.id %>" class="btn btn-sm btn-warning">
                            <i class="fas fa-edit"></i> Corregir Datos/Afiches
                        </a>
                    </div>
                    <hr>
                    <div class="text-center">
                        <small class="text-muted d-block mb-2">Presidente de Mesa Activo:</small>
                        <span class="badge bg-warning text-dark fs-6" id="nombrePresidente">
                            <%= presidente || 'No asignado' %>
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- SECCIÓN B: PRODUCCIÓN AUDIOVISUAL (DJ & LED) -->
        <div class="col-lg-6">
            <div class="card shadow-lg border-0 h-100" style="border-radius: 15px;">
                <div class="card-header bg-primary text-white fw-bold text-center">🎭 Producción de Espectáculo (Show en Vivo)</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="p-3 border rounded bg-light text-center">
                                <i class="fas fa-music fa-2x mb-2 text-info"></i>
                                <h6 class="fw-bold">DJ VIRTUAL</h6>
                                <p class="small text-muted">Gestión de MP3 y Playlist de pasarelas.</p>
                                <a href="/eventos/<%= evento.id %>/dj-consola" class="btn btn-info btn-sm w-100">Abrir Consola</a>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 border rounded bg-light text-center">
                                <i class="fas fa-desktop fa-2x mb-2 text-danger"></i>
                                <h6 class="fw-bold">VIDEO & BROADCAST</h6>
                                <p class="small text-muted">Efectos LED, Lower Thirds y Transmisión.</p>
                                <a href="/eventos/<%= evento.id %>/broadcast-live" class="btn btn-danger btn-sm w-100">Panel VMD</a>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 border rounded bg-light text-center">
                                <i class="fas fa-door-open fa-2x mb-2 text-secondary"></i>
                                <h6 class="fw-bold">CONTROL BACKSTAGE</h6>
                                <p class="small text-muted">Orden de llamado a atletas.</p>
                                <a href="/eventos/<%= evento.id %>/backstage" class="btn btn-secondary btn-sm w-100">Abrir Panel</a>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="p-3 border rounded bg-dark text-white text-center">
                                <i class="fas fa-microphone-alt fa-2x mb-2 text-warning"></i>
                                <h6 class="fw-bold">MONITOR DEL MC</h6>
                                <p class="small text-muted">Programa dinámico y canto de podios.</p>
                                <a href="/eventos/<%= evento.id %>/monitor-mc" class="btn btn-warning btn-sm w-100 fw-bold">Monitor de Tarima</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- SECCIÓN C: ARBITRAJE Y FOTOGRAFÍA -->
        <div class="col-lg-3">
            <div class="card shadow-sm border-0 h-100" style="border-radius: 15px;">
                <div class="card-header bg-secondary text-white fw-bold">📸 Resultados y Media</div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="/fotografia/upload?evento=<%= evento.id %>" class="btn btn-outline-dark text-start">
                            <i class="fas fa-camera me-2"></i> Subir Fotos (Social/Muro)
                        </a>
                        <a href="/eventos/<%= evento.id %>/mesa-tecnica-actual" class="btn btn-danger fw-bold text-start">
                            <i class="fas fa-gavel me-2"></i> MESA TÉCNICA (EN VIVO)
                        </a>
                        <a href="/eventos/<%= evento.id %>/reporte-oficial" class="btn btn-outline-dark text-start">
                            <i class="fas fa-file-invoice me-2"></i> Reporte Oficial de Resultados
                        </a>
                        <a href="/estadisticas/<%= evento.id %>/absolutos" class="btn btn-outline-dark text-start">
                            <i class="fas fa-trophy me-2"></i> Gestión de Absolutos (Overall)
                        </a>
                        <a href="/estadisticas/imprimir-certificados/<%= evento.id %>" class="btn btn-outline-dark text-start" target="_blank">
                            <i class="fas fa-certificate me-2"></i> Impresión Masiva Diplomas
                        </a>
                        <hr>
                        <button onclick="cerrarEvento()" class="btn btn-danger fw-bold">
                            <i class="fas fa-flag-checkered me-2"></i> CERRAR COMPETENCIA
                        </button>
                    </div>
                    <!-- SECCIÓN: CONTROL DE EFECTIVO -->
                    <div class="mt-3 p-3 bg-light rounded border">
                        <h6 class="fw-bold small text-muted text-uppercase mb-2"><i class="fas fa-coins text-warning me-1"></i> Control de Efectivo</h6>
                        <div class="d-grid gap-2">
                            <a href="/admin/recaudacion" class="btn btn-sm btn-dark">
                                Registrar Cobro Manual
                            </a>
                            <a href="/admin/reporte-caja" class="btn btn-sm btn-outline-dark fw-bold">
                                Ver Cierre de Caja (Hoy)
                            </a>
                            <a href="/admin/auditoria-pagos" class="btn btn-sm btn-outline-success fw-bold">
                                <i class="fas fa-search-dollar me-1"></i> Localizador de Pagos
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- PANEL DE PRUEBA DE NOTIFICACIONES PUSH -->
    <div class="card border-warning mt-4 shadow-sm" style="border-radius: 15px;">
        <div class="card-header bg-warning text-dark fw-bold">🚀 Prueba de Notificaciones Push</div>
        <div class="card-body">
            <p class="small text-muted">Usa esto para verificar que el Service Worker está activo en los dispositivos suscritos.</p>
            <div class="input-group">
                <input type="text" id="mensajePrueba" class="form-control" placeholder="Escribe un mensaje de prueba...">
                <button onclick="enviarPruebaPush()" class="btn btn-dark fw-bold">Enviar a Todos</button>
            </div>
            <div id="statusPush" class="mt-2 small fw-bold text-muted"></div>
        </div>
    </div>
</div>

<script>
    async function enviarPruebaPush() {
        const msg = document.getElementById('mensajePrueba').value;
        if(!msg) return alert("Escribe un mensaje para enviar.");
        
        document.getElementById('statusPush').innerText = "Enviando notificaciones...";
        
        const res = await fetch('/admin/test-push', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ mensaje: msg })
        });
        
        const data = await res.json();
        if (data.ok) {
            document.getElementById('statusPush').innerText = `✅ Éxito: ${data.enviados} notificaciones procesadas.`;
        } else {
            document.getElementById('statusPush').innerText = `❌ Error: ${data.error}`;
        }
    }

    function cerrarEvento() {
        if(confirm("¿Estás seguro de cerrar la competencia? Se publicarán los resultados finales y se desactivarán las votaciones.")) {
            // Lógica para llamar al endpoint de cierre
        }
    }
</script>

<%- include("../template/footer") %>