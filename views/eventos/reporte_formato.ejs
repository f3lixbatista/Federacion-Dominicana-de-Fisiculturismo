<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reporte Oficial - <%= evento.nombre %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { font-family: 'Arial', sans-serif; background-color: #f8f9fa; }
        .table { margin-bottom: 0; }
        .table th { border: 2px solid #000; }
        .table td { border: 2px solid #000; }
        .bg-dark { background-color: #000 !important; }
        .border-dark { border-color: #000 !important; }
        .table-primary { background-color: #cfe2ff !important; }
        @media print {
            body { background-color: white !important; }
            .shadow-sm { box-shadow: none !important; }
        }
    </style>
</head>
<body>
    <%- include('../template/cabecera') %>

    <div class="container my-5">
        <div class="text-center mb-5">
            <img src="/img/logo-fdff.png" style="width: 120px;">
            <h2 class="fw-bold mt-3"><%= evento.nombre %></h2>
            <h4 class="text-muted text-uppercase">
                <%= evento.estado === 'finalizado' ? 'Reporte Oficial de Resultados' : 'Listado Oficial de Competencia' %>
            </h4>
        </div>

        <% reporte.forEach(bloque => { %>
            <div class="mb-5">
                <h5 class="bg-dark text-white p-2 fw-bold text-center mb-0">
                    <%= bloque.nombreCat %> — <%= bloque.modalidad %>
                </h5>
                <table class="table table-bordered border-dark text-center align-middle shadow-sm">
                    <thead class="table-light small fw-bold">
                        <tr>
                            <th style="width: 8%;">No.</th>
                            <th class="text-start ps-3">Nombre</th>
                            <th>Ciudad / País</th>
                            <th>Team</th>
                            <!-- COLUMNA DINÁMICA -->
                            <th class="table-primary" style="width: 15%;">
                                <%= evento.estado === 'finalizado' ? 'POSICIÓN' : 'PESO / TALLA' %>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        <% bloque.atletas.forEach(comp => { %>
                            <tr>
                                <td class="fw-bold fs-5"><%= comp.numero_atleta %></td>
                                <td class="text-start ps-3 fw-bold"><%= comp.atletas.nombre %></td>
                                <td><%= comp.atletas.provincia %></td>
                                <td><%= comp.atletas.gimnasio || 'Independiente' %></td>

                                <!-- CONTENIDO DINÁMICO -->
                                <td class="fw-bold fs-5">
                                    <% if (evento.estado === 'finalizado') { %>
                                        <span class="text-success"><%= comp.posicion_final %>° Lugar</span>
                                    <% } else { %>
                                        <small><%= comp.atletas.peso %>kg / <%= comp.atletas.estatura %>cm</small>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% }) %>

        <!-- Firma oficial de la Federación -->
        <div class="row mt-5 pt-4 text-center">
            <div class="col-4 border-top border-dark mx-auto">
                <small class="fw-bold">Comité Ejecutivo FDFF</small>
            </div>
        </div>
    </div>

    <%- include('../template/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>