<%- include("../template/cabecera", {tituloWeb: "Historial de Resultados FDFF"}) %>

<div class="fdff-page-header">
    <div class="container">
        <div>
            <div class="fdff-ph-eyebrow">Federación Dominicana de Fisiculturismo · IFBB</div>
            <h1 class="fdff-ph-title">Salón de la Fama</h1>
            <p class="fdff-ph-subtitle">Resultados oficiales y estadísticas de eventos anteriores</p>
        </div>
    </div>
</div>

<div class="container my-4">
    <% if (!eventos || eventos.length === 0) { %>
        <div class="fdff-empty-state">
            <div class="fdff-empty-icon"><i class="fas fa-trophy"></i></div>
            <div class="fdff-empty-title">Aún no hay resultados registrados</div>
            <p class="fdff-empty-body">Los resultados oficiales de cada competencia aparecerán aquí una vez que el evento sea cerrado por el administrador.</p>
            <a href="/eventos/competencias" class="btn btn-fdff fw-bold mt-2">
                <i class="fas fa-calendar-alt me-2"></i> Ver competencias activas
            </a>
        </div>
    <% } else { %>
        <div class="row g-4">
            <% eventos.forEach(ev => { %>
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm" style="border-radius:20px;">
                        <div class="card-body p-4">
                            <div class="badge bg-secondary mb-2">Finalizado: <%= new Date(ev.fecha_inicio).getFullYear() %></div>
                            <h4 class="fw-bold mb-3"><%= ev.nombre %></h4>
                            <p class="small text-muted mb-4"><i class="fas fa-calendar-alt me-1"></i> <%= new Date(ev.fecha_inicio).toLocaleDateString('es-DO') %></p>
                            <div class="d-grid gap-2">
                                <a href="/eventos/<%= ev.id %>/resultados-publicos" class="btn btn-fdff fw-bold">
                                    <i class="fas fa-trophy me-2"></i> Ver Resultados
                                </a>
                                <a href="/social/muro?evento=<%= ev.id %>" class="btn btn-outline-secondary">
                                    <i class="fas fa-camera me-2"></i> Ver Galería
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>

<%- include("../template/footer") %>
