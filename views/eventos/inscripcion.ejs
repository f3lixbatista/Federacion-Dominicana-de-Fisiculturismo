<%- include("../template/cabecera", {tituloWeb: "Inscripción y Pesaje"}) %>

<div class="container my-5">
    <!-- PANEL DE ESTADO DEL EVENTO -->
    <div class="card border-0 mb-4 shadow-sm">
        <div class="card-body d-flex justify-content-between align-items-center bg-light flex-wrap gap-3">
            <div>
                <h4 class="fw-bold mb-0"><i class="fas fa-weight me-2 text-primary"></i> Pesaje Asistido — <%= eventoActual.nombre %></h4>
                <p class="small text-muted mb-0">
                    Estado: <strong><%= eventoActual.estado?.toUpperCase() %></strong>
                    <% if (eventoActual.estado === 'inscripcion') { %>
                        &nbsp;·&nbsp;<span class="text-success fw-bold">Inscripciones web abiertas</span>
                        — el pesaje puede realizarse simultáneamente.
                    <% } %>
                </p>
            </div>
            <% if (eventoActual.estado === 'inscripcion') { %>
                <button class="btn btn-outline-danger fw-bold" onclick="cerrarInscripcionesWeb('<%= eventoActual.id %>')">
                    <i class="fas fa-lock me-1"></i> Cerrar inscripciones web
                </button>
            <% } else if (eventoActual.estado === 'pesaje') { %>
                <span class="badge bg-secondary p-2 fs-6"><i class="fas fa-lock me-1"></i> Inscripciones web cerradas</span>
            <% } %>
        </div>
    </div>

    <!-- SECCIÓN 1: BUSCADOR DE ATLETAS (ESTACIÓN DE REGISTRO) -->
    <div class="card shadow-sm mb-4 border-0" style="border-radius: 15px;">
        <div class="card-body p-4">
            <h5 class="fw-bold mb-3"><i class="fas fa-search me-2"></i> Localizar Atleta para Pesaje</h5>
            
            <div class="row g-2">
                <div class="col-md-8">
                    <div class="input-group input-group-lg">
                        <!-- <span class="input-group-text bg-white border-end-0"><i class="fas fa-user text-muted"></i></span> -->
                        <input type="text" id="busquedaAtleta" class="form-control border-1 border-dark ps-0" 
                               placeholder=" Escriba Nombre, Cédula o escanee con lector de mano..." onkeyup="filtrarTablaAtletas()">
                    </div>
                </div>
                <div class="col-md-4">
                    <button class="btn btn-dark btn-lg w-100 fw-bold" onclick="iniciarEscaneoCamara()">
                        <i class="fas fa-camera me-2"></i> USAR CÁMARA
                    </button>
                </div>
            </div>
            <div id="reader" class="mt-3 mx-auto" style="width: 300px; display: none;"></div>
        </div>
    </div>

    <div class="container divGeneral border border-1 border-dark p-4 col-12 shadow-sm bg-white" style="border-radius: 15px;">
        <h2 class="mb-4 fw-bold text-primary border-bottom pb-2">Estación de Inscripción Asistida</h2>
        <div class="table-responsive">     
            <table class="table table-striped table-bordered border-dark table-hover" id="mydatatable">
                <thead>
                    <tr class="table-dark text-white"> 
                        <th scope="col" class="text-white">Cédula</th>
                        <th scope="col" class="text-white">Nombre del Atleta</th>  
                        <th scope="col" class="text-white">ID-FDFF</th>
                        <th scope="col" class="text-white">Acción</th>
                    </tr>
                </thead>
                <tbody id="bodyAtletas">
                    <% arrayAtletas.forEach(atleta => { %>
                        <tr>
                            <td><%= atleta.cedula %></td>
                            <td class="fw-bold fs-5"><%= atleta.nombre %></td>
                            <td><%= atleta.idfdff || 'Sin ID' %></td>
                            <td>
                                <button class="btn btn-warning btn-sm fw-bold px-3" 
                                        onclick="abrirModalDesdeBoton(this)"
                                        data-id="<%= atleta.id %>"
                                        data-nombre="<%= atleta.nombre %>"
                                        data-sexo="<%= atleta.sexo %>"
                                        data-nacimiento="<%= atleta.fecha_nacimiento %>"
                                        data-estatura="<%= atleta.estatura %>"
                                        data-peso="<%= atleta.peso %>"
                                        data-cedula="<%= atleta.cedula %>">
                                    <i class="fas fa-edit"></i> Inscribir
                                </button>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- BOTÓN HACIA LA SIGUIENTE ETAPA -->
    <div class="text-center mt-5 pt-3">
        <a href="/eventos/<%= eventoActual.id %>/preparacion" class="btn btn-outline-dark btn-lg px-5 fw-bold shadow-sm">
            IR A PREPARACIÓN DE EVENTO <i class="fas fa-chevron-right ms-2"></i>
        </a>
    </div>
</div>

<!-- VENTANA FLOTANTE (MODAL): SELECCIÓN DINÁMICA DE CATEGORÍAS -->
<div class="modal fade" id="modalInscripcion" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header bg-primary text-white py-3">
                <h5 class="modal-title fw-bold"><i class="fas fa-clipboard-list me-2"></i> Selección para: <span id="spanNombreAtleta"></span></h5>
                <button type="button" class="btn-close btn-close-white" onclick="cerrarModal()"></button>
            </div>
            <div class="modal-body p-4">
                <div class="alert alert-warning small mb-3">
                    <i class="fas fa-exclamation-triangle"></i> Al elegir una categoría, el sistema bloqueará automáticamente las modalidades no afines.
                </div>
                
                <form id="formInscripcionAsistida">
                    <input type="hidden" id="atletaIdIns">

                    <div class="mb-4">
                        <label class="form-label fw-bold">Team / Preparador Oficial</label>
                        <select name="preparador_id" id="selectPreparador" class="form-select border-primary select2">
                            <option value="">-- Atleta Independiente --</option>
                            <% (arrayPreparadores || []).forEach(prep => { %>
                                <option value="<%= prep.id %>"><%= prep.nombre_completo %> (<%= prep.gimnasio_labora %>)</option>
                            <% }) %>
                        </select>
                        <small class="text-muted">Si su preparador no aparece, debe registrarse primero en el módulo de Preparadores.</small>
                    </div>
                    
                    <div id="listaCategoriasAfines" class="list-group shadow-sm">
                        <!-- Se inyecta vía JavaScript -->
                    </div>

                    <!-- Componente de Carga de Audio (DJ Virtual) -->
                    <div class="card border-primary mt-4 mb-3">
                        <div class="card-header bg-primary text-white fw-bold">
                            <i class="fas fa-music me-2"></i> Audio de Presentación (DJ Virtual)
                        </div>
                        <div class="card-body">
                            <div id="playerAudio" class="mb-3" style="display:none">
                                <audio id="audioElement" controls class="w-100"></audio>
                            </div>
                            <div id="sinMusica" class="alert alert-secondary py-2 small mb-3">
                                <i class="fas fa-music me-1"></i> Este atleta aún no ha subido su música.
                            </div>

                            <div class="input-group">
                                <input type="file" id="fileMusica" class="form-control" accept=".mp3,.wav">
                                <button type="button" onclick="subirMusicaAsistida()" class="btn btn-dark" id="btnSubirMusica">
                                    <i class="fas fa-upload"></i> Cargar
                                </button>
                            </div>
                            <small class="text-muted mt-2 d-block">Límite: 90 segundos. Solo se permite un archivo por evento.</small>
                        </div>
                    </div>

                    <!-- RESUMEN DE COBRO -->
                    <div class="mt-4 p-4 bg-light rounded-4 d-flex justify-content-between align-items-center border border-2 border-success">
                        <div>
                            <h5 class="mb-0 fw-bold">Monto Total a Pagar</h5>
                            <small class="text-muted" id="detallePrecios"></small>
                        </div>
                        <h3 class="mb-0 fw-bold text-success" id="totalMonto">RD$ 0.00</h3>
                    </div>

                    <!-- DOCUMENTO DE DESCARGO Y CONSENTIMIENTO - FDFF -->
                    <div class="card bg-light border-dark mb-3 mt-4">
                        <div class="card-header bg-dark text-white fw-bold small text-center">
                            DOCUMENTO DE DESCARGO Y CONSENTIMIENTO - FDFF
                        </div>
                        <div class="card-body p-4 bg-white" style="max-height: 350px; overflow-y: auto; font-size: 0.85rem; line-height: 1.4;">
                            <p class="text-center fw-bold text-uppercase mb-3">Convenio de participación - FDFF / IFBB</p>
                            
                            <p>Para poder participar como competidor en este evento, afirmo que entiendo y estoy de acuerdo con la constitución y las reglas de la IFBB/FDFF, el código de ética y las reglas antidopajes. Entiendo y concuerdo con las siguientes condiciones:</p>
                            
                            <ol class="ps-3">
                                <li class="mb-2"><strong>Voluntariedad:</strong> Participo de manera totalmente voluntaria y acepto todas las partes de este documento.</li>
                                <li class="mb-2"><strong>Descargo de Responsabilidad:</strong> Exonero a la federación, organizadores, jueces, patrocinadores y staff de cualquier reclamación por daños personales, muerte, pérdida de propiedad o gastos durante mi participación.</li>
                                <li class="mb-2"><strong>Salud y Gastos Médicos:</strong> Confirmo buen estado de salud física y mental. Cualquier daño médico es mi responsabilidad, incluyendo el pago de asistencia médica, liberando a la federación de cobertura económica.</li>
                                <li class="mb-2"><strong>No Coacción:</strong> Afirmo que nadie me obligó a participar.</li>
                                <li class="mb-2"><strong>Reglas y Dopaje:</strong> Acepto ser sometido a pruebas de dopaje sin previo aviso si participo en eventos no avalados, costeando yo mismo dicha prueba.</li>
                                <li class="mb-2"><strong>Derechos de Imagen:</strong> Autorizo el uso de fotos y videos capturados durante el evento para fines de la federación sin requerir pago por derechos.</li>
                                <li class="mb-2"><strong>Mayoría de Edad:</strong> Confirmo ser mayor de edad y haber leído y entendido este convenio.</li>
                            </ol>

                            <div class="bg-light p-2 border rounded mt-3">
                                <p class="mb-1"><strong>Datos del Firmante:</strong></p>
                                <div class="row">
                                    <div class="col-6">Atleta: <span id="signNombre" class="fw-bold"></span></div>
                                    <div class="col-6">Cédula: <span id="signCedula" class="fw-bold"></span></div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-warning bg-opacity-10 border-top d-flex justify-content-between align-items-center">
                            <div class="form-check mb-0">
                                <input class="form-check-input border-dark" type="checkbox" id="checkDescargo" style="width: 1.4rem; height: 1.4rem;">
                                <label class="form-check-label fw-bold ms-2 mt-1" for="checkDescargo" style="cursor: pointer;">
                                    EL ATLETA ACEPTA Y FIRMA ESTE CONVENIO DIGITALMENTE
                                </label>
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-dark fw-bold" onclick="imprimirDescargoFisico()">
                                <i class="fas fa-print me-1"></i> Imprimir Copia Física
                            </button>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light py-3">
                <button type="button" class="btn btn-secondary fw-bold" onclick="cerrarModal()">Cancelar</button>
                <button type="button" class="btn btn-primary btn-lg fw-bold px-4" onclick="guardarInscripcionOficial()">
                    OFICIALIZAR Y GUARDAR
                </button>
            </div>
        </div>
    </div>
</div>

<!-- SECCIÓN DE INYECCIÓN DE DATOS (Para evitar errores de sintaxis en el editor) -->
<div id="config-evento" class="d-none"
     data-url="<%= SUPABASE_URL %>"
     data-anon="<%= SUPABASE_ANON_KEY %>"
     data-id="<%= eventoActual?.id || '' %>"
     data-nombre="<%= eventoActual?.nombre || '' %>"
     data-costo1="<%= precioEfectivoPrimera || 0 %>"
     data-costo-adic="<%= precioEfectivoAdicional || 0 %>"
     data-es-oferta="<%= esPrecioOferta ? '1' : '0' %>">
</div>
<script id="data-categorias" type="application/json"><%- JSON.stringify(arrayCategorias || []) %></script>
<script id="data-atletas" type="application/json"><%- JSON.stringify(arrayAtletas || []) %></script>

<script src="/js/supabase.js"></script>
<script>
    // 1. Recuperación de Configuración desde el DOM
    const configEl = document.getElementById('config-evento').dataset;
    const categoriasDelEvento = JSON.parse(document.getElementById('data-categorias').textContent);
    const listaAtletasGlobal = JSON.parse(document.getElementById('data-atletas').textContent);

    // 2. Inicialización de Supabase
    const _supabase = supabase.createClient(configEl.url, configEl.anon);
    
    const costos = { 
        primera: Number(configEl.costo1), 
        adicional: Number(configEl.costoAdic) 
    };

    // 3. Inicialización del Modal
    let myModal;
    document.addEventListener('DOMContentLoaded', () => {
        const modalEl = document.getElementById('modalInscripcion');
        if (modalEl && typeof bootstrap !== 'undefined') {
            myModal = new bootstrap.Modal(modalEl, { backdrop: 'static' });
        } else if (typeof bootstrap === 'undefined') {
            console.error("Bootstrap no se cargó correctamente. Verifique su conexión o use una copia local.");
        }
    });

    function cerrarModal() {
        if (myModal) myModal.hide();
    }

    // Función puente para manejar los datos del botón
    function abrirModalDesdeBoton(btn) {
        const d = btn.dataset;
        abrirModalInscripcion(d.id, d.nombre, d.sexo, d.nacimiento, d.estatura, d.peso, d.cedula);
    }

async function abrirModalInscripcion(id, nombre, sexo, fechaNac, estatura, peso, cedula) {
        if (!nombre) return alert("Falta Nombre");
        if (!sexo) return alert("Falta Sexo");
        if (!fechaNac) return alert("Falta Fecha Nacimiento");

        const sexoNormalizado = sexo.toLowerCase();
        if (sexoNormalizado !== 'm' && sexoNormalizado !== 'f') {
            return alert("Sexo Incorrecto");
        }

        if (!estatura || estatura <= 0) return alert("Falta estatura");
        if (sexoNormalizado === 'm' && (!peso || peso <= 0)) return alert("Falta Peso");

        document.getElementById('atletaIdIns').value = id;
        document.getElementById('spanNombreAtleta').innerText = nombre;
        document.getElementById('signNombre').innerText = nombre;
        document.getElementById('signCedula').innerText = cedula || 'Sin especificar';
        document.getElementById('checkDescargo').checked = false;

        const player = document.getElementById('playerAudio');
        const audio = document.getElementById('audioElement');
        const fileMusica = document.getElementById('fileMusica');
        const selectPrep = document.getElementById('selectPreparador');

        const sinMusica = document.getElementById('sinMusica');
        if (player) player.style.display = 'none';
        if (sinMusica) sinMusica.style.display = 'block';
        if (audio) { audio.pause(); audio.src = ''; }
        if (fileMusica) fileMusica.value = '';
        if (selectPrep) selectPrep.value = '';

        const esOferta = configEl.esOferta === '1';
        document.getElementById('detallePrecios').innerText =
            `${esOferta ? '🏷️ PRECIO OFERTA — ' : ''}1ra Cat: RD$ ${costos.primera.toLocaleString()} | Adic: RD$ ${costos.adicional.toLocaleString()}`;

        // Cargamos datos del atleta desde el servidor (evita bloqueo RLS del cliente anónimo)
        let yaInscritosIds = [];
        try {
            const resp = await fetch(`/inscripcion/ficha-atleta?atletaId=${id}&eventoId=${configEl.id}`);
            if (resp.ok) {
                const ficha = await resp.json();
                yaInscritosIds = ficha.categoriasInscritas || [];

                if (ficha.preparador_id && selectPrep) {
                    selectPrep.value = ficha.preparador_id;
                }
                if (ficha.musicaUrl && player && audio) {
                    audio.src = ficha.musicaUrl;
                    player.style.display = 'block';
                    if (sinMusica) sinMusica.style.display = 'none';
                }
            }
        } catch (e) {
            console.error('Error cargando ficha atleta:', e);
        }

        // Calcular edad precisa del atleta
        const _hoy = new Date();
        const _nac = new Date(fechaNac);
        let _edad = _hoy.getFullYear() - _nac.getFullYear();
        const _mDiff = _hoy.getMonth() - _nac.getMonth();
        if (_mDiff < 0 || (_mDiff === 0 && _hoy.getDate() < _nac.getDate())) _edad--;

        renderizarCategorias(sexoNormalizado, yaInscritosIds, _edad);

        if (myModal) {
            myModal.show();
        } else {
            console.error("Error: El objeto del modal no está inicializado.");
        }
    }

    let _sexoAtletaActual = 'm';

    function renderizarCategorias(sexoAtleta, yaInscritosIds = [], edadAtleta = null) {
        _sexoAtletaActual = (sexoAtleta || 'm').toLowerCase();
        const contenedor = document.getElementById('listaCategoriasAfines');
        if (!contenedor) return;
        contenedor.innerHTML = '';

        // Banner si el atleta ya pre-inscribió categorías vía web
        if (yaInscritosIds.length > 0) {
            contenedor.insertAdjacentHTML('beforeend', `
                <div class="alert alert-info py-2 small mb-2 d-flex align-items-center gap-2">
                    <i class="fas fa-globe fa-lg"></i>
                    <span>Pre-seleccionó <strong>${yaInscritosIds.length}</strong> categoría(s) vía web. Puedes añadir o quitar.</span>
                </div>`);
        }

        // Filtrado por sexo y edad
        const sexoUp = sexoAtleta.toUpperCase();
        const filtradas = categoriasDelEvento.filter(rel => {
            const cat = rel.categorias || {};
            const sexoCat = (cat.sexo || '').toUpperCase();

            // Filtro sexo
            if (sexoCat !== sexoUp && sexoCat !== 'F-M' && sexoCat !== '' && sexoCat !== 'UNISEX') return false;

            // Filtro edad
            if (edadAtleta !== null && !isNaN(edadAtleta)) {
                const modalidad = (cat.modalidad || '').toLowerCase();
                const emin = (cat.edad_min != null && cat.edad_min > 0) ? cat.edad_min : null;
                const emax = (cat.edad_max != null) ? cat.edad_max : null;

                // Reglas FDFF por modalidad (se aplican siempre, edad_min de la BD refina si existe)
                if (modalidad === 'master') {
                    const piso = emin ?? (sexoCat === 'F' ? 35 : 40);
                    if (edadAtleta < piso) return false;
                } else if (modalidad === 'junior') {
                    const piso = emin ?? 16;
                    const techo = (emax != null && emax < 200) ? emax : 23;
                    if (edadAtleta < piso || edadAtleta > techo) return false;
                } else if (modalidad === 'children') {
                    const techo = (emax != null && emax < 200) ? emax : 15;
                    if (edadAtleta > techo) return false;
                } else {
                    // Senior / Open: si tiene edad_min/max en BD los respetamos
                    if (emin != null && edadAtleta < emin) return false;
                    if (emax != null && emax < 200 && edadAtleta > emax) return false;
                }
            }

            return true;
        });

        if (filtradas.length === 0) {
            contenedor.insertAdjacentHTML('beforeend', '<div class="alert alert-warning">No hay categorías disponibles para este perfil.</div>');
            return;
        }

        filtradas.forEach(rel => {
            const yaInscrito = yaInscritosIds.includes(rel.id);
            const item = `
                <div class="list-group-item d-flex justify-content-between align-items-center cat-item py-3 ${yaInscrito ? 'border-start border-3 border-primary bg-primary bg-opacity-10' : ''}"
                     data-modalidad="${rel.categorias?.modalidad || ''}"
                     data-disciplina="${rel.categorias?.disciplina || ''}"
                     data-division="${rel.categorias?.division || ''}"
                     id="item-${rel.id}">
                    <div class="form-check w-100 cursor-pointer">
                        <input class="form-check-input check-cat me-3" type="checkbox"
                               value="${rel.id}" id="check-${rel.id}"
                               ${yaInscrito ? 'checked' : ''}
                               onchange="validarAfinidad(this)">
                        <label class="form-check-label w-100" for="check-${rel.id}">
                            <span class="fw-bold d-block">
                                ${rel.categorias?.nombre || 'S/N'}
                                ${yaInscrito ? '<span class="badge bg-primary ms-2 fw-normal" style="font-size:0.65rem;">WEB</span>' : ''}
                            </span>
                            <span class="small text-muted">${rel.categorias?.disciplina || ''} | ${rel.categorias?.modalidad || ''} | ${rel.categorias?.division || ''}</span>
                        </label>
                    </div>
                </div>`;
            contenedor.insertAdjacentHTML('beforeend', item);
        });

        // Aplicar reglas de afinidad si ya hay categorías pre-marcadas
        if (yaInscritosIds.length > 0) {
            const primeroChecked = contenedor.querySelector('.check-cat:checked');
            if (primeroChecked) validarAfinidad(primeroChecked);
        }

        calcularCobro();
    }

    // ── Grupos de afinidad FDFF ─────────────────────────────────────────────────
    // Wellness va antes que Bikini para que Women’s Fit Model (presente en ambos)
    // resuelva al grupo Bikini por defecto (el último en escribir al mapa gana).
    // Pairs (Fit Pairs / Mixed Pairs) son sex-aware: se manejan fuera del mapa.
    const GRUPOS_AFINIDAD = {
        "culturismo_m":  ["Men’s Bodybuilding", "Men’s Classic Bodybuilding", "Men’s Classic Physique", "Men’s Games Classic"],
        "physique_m":    ["Men’s Physique", "Men’s Fit Model", "Men’s Fitness"],
        "muscular_m":    ["Muscular Men’s Physique"],
        "wellness_f":    ["Women’s Wellness", "Women’s Fit Model"],
        "bikini_f":      ["Women’s Bikini", "Women’s Fit Model", "Women’s Artistic Fitness"],
        "bodyfitness_f": ["Women’s Bodyfitness", "Women’s Acrobatic Fitness"],
        "physique_f":    ["Women’s Physique"],
        "children_m":    ["Male Children Fitness"],
        "children_f":    ["Female Children Fitness"]
    };

    // Normaliza strings: minúsculas + apóstrofes uniformes
    function _normDisc(s) {
        return (s || ‘’).toLowerCase()
            .replace(/[‘’ʼ`´]/g, "’")
            .trim();
    }

    // Mapa normalizado: _normDisc(disciplina) → lista normalizada de su grupo
    const _AFINIDAD_NORM = {};
    for (const discs of Object.values(GRUPOS_AFINIDAD)) {
        const normas = discs.map(_normDisc);
        for (const nd of normas) {
            _AFINIDAD_NORM[nd] = normas;
        }
    }

    const _FIT_PAIRS_N   = _normDisc("Fit Pairs");
    const _MIXED_PAIRS_N = _normDisc("Mixed Pairs");

    // Devuelve la lista de disciplinas normalizadas permitidas para la disciplina
    // principal, incluyendo los Pairs correctos según el sexo del atleta.
    function _getPermitidas(normPrincipal) {
        const sexo = _sexoAtletaActual;

        // Pairs como punto de partida: buscar su grupo natural según sexo
        if (normPrincipal === _FIT_PAIRS_N) {
            const grupoKey = sexo === ‘f’ ? "bikini_f" : "physique_m";
            const base = _AFINIDAD_NORM[_normDisc(GRUPOS_AFINIDAD[grupoKey][0])] || [normPrincipal];
            return [...base, _FIT_PAIRS_N];
        }
        if (normPrincipal === _MIXED_PAIRS_N) {
            const grupoKey = sexo === ‘f’ ? "physique_f" : "culturismo_m";
            const base = _AFINIDAD_NORM[_normDisc(GRUPOS_AFINIDAD[grupoKey][0])] || [normPrincipal];
            return [...base, _MIXED_PAIRS_N];
        }

        const grupo = _AFINIDAD_NORM[normPrincipal] || [normPrincipal];

        // Agregar Pairs si el grupo del atleta los habilita
        const extra = [];
        if (sexo === ‘m’) {
            if (grupo.includes(_normDisc("Men’s Physique")))     extra.push(_FIT_PAIRS_N);
            if (grupo.includes(_normDisc("Men’s Bodybuilding"))) extra.push(_MIXED_PAIRS_N);
        } else {
            if (grupo.includes(_normDisc("Women’s Bikini")))    extra.push(_FIT_PAIRS_N);
            if (grupo.includes(_normDisc("Women’s Physique"))) extra.push(_MIXED_PAIRS_N);
        }
        return [...grupo, ...extra];
    }

    function validarAfinidad(checkbox) {
        const todosLosChecks = document.querySelectorAll(‘.check-cat’);
        const marcados       = Array.from(document.querySelectorAll(‘.check-cat:checked’));

        if (marcados.length > 0) {
            const normPrincipal  = _normDisc(marcados[0].closest(‘.cat-item’).dataset.disciplina || ‘’);
            const permitidasNorm = _getPermitidas(normPrincipal);

            // Modalidades ya marcadas (Junior/Master)
            const modalidadesMarcadas = new Set(
                marcados.map(cb => (cb.closest(‘.cat-item’).dataset.modalidad || ‘’).toLowerCase())
            );
            const tieneJunior = modalidadesMarcadas.has(‘junior’);
            const tieneMaster = modalidadesMarcadas.has(‘master’);

            // División seleccionada por (disciplina + modalidad): bloquea divisiones
            // hermanas solo dentro de la misma modalidad, no entre Junior y Senior.
            const divPorDiscModal = {};
            marcados.forEach(cb => {
                const item = cb.closest(‘.cat-item’);
                const key = _normDisc(item.dataset.disciplina || ‘’) + ‘|’ + (item.dataset.modalidad || ‘’).toLowerCase();
                const div = (item.dataset.division || ‘’).toLowerCase();
                if (!divPorDiscModal[key]) divPorDiscModal[key] = new Set();
                divPorDiscModal[key].add(div);
            });

            todosLosChecks.forEach(cb => {
                const item          = cb.closest(‘.cat-item’);
                const normItem      = _normDisc(item.dataset.disciplina || ‘’);
                const modalidadItem = (item.dataset.modalidad || ‘’).toLowerCase();
                const divItem       = (item.dataset.division || ‘’).toLowerCase();

                if (cb.checked) {
                    cb.disabled = false;
                    item.classList.remove(‘opacity-50’, ‘bg-light’);
                    item.style.order = ‘0’;
                    return;
                }

                // Regla 1: grupo de disciplina
                const esGrupoValido = permitidasNorm.includes(normItem);

                // Regla 2: modalidad (solo 1 Junior, solo 1 Master, nunca ambos)
                let esModalidadValida = true;
                if (modalidadItem === ‘junior’)     esModalidadValida = !tieneJunior && !tieneMaster;
                else if (modalidadItem === ‘master’) esModalidadValida = !tieneMaster && !tieneJunior;
                else if (modalidadItem === ‘children’) esModalidadValida = false;

                // Regla 3: división — dentro de la misma disciplina y modalidad, solo una división
                const _divKey = normItem + '|' + modalidadItem;
                let esDivisionValida = true;
                if (divPorDiscModal[_divKey]) {
                    esDivisionValida = divPorDiscModal[_divKey].has(divItem);
                }

                const esValida = esGrupoValido && esModalidadValida && esDivisionValida;
                cb.disabled = !esValida;
                item.classList.toggle(‘opacity-50’, !esValida);
                item.classList.toggle(‘bg-light’,   !esValida);
                // Agrupación visual: disponibles arriba, bloqueadas abajo
                item.style.order = esValida ? ‘0’ : ‘1’;
            });
        } else {
            todosLosChecks.forEach(cb => {
                const item = cb.closest(‘.cat-item’);
                cb.disabled = false;
                item.classList.remove(‘opacity-50’, ‘bg-light’);
                item.style.order = ‘’;
            });
        }
        calcularCobro();
    }

    function liberarFormulario() {
        const todosLosItems = document.querySelectorAll('.cat-item');
        todosLosItems.forEach(item => {
            const cb = item.querySelector('.check-cat');
            cb.disabled = false;
            item.classList.remove('opacity-50', 'bg-light');
        });
    }

    function calcularCobro() {
        const cantidad = document.querySelectorAll('.check-cat:checked').length;
        let total = 0;
        
        if (cantidad > 0) {
            // Costos definidos a nivel de evento
            total = costos.primera + ((cantidad - 1) * costos.adicional);
        }
        
        document.getElementById('totalMonto').innerText = `RD$ ${total.toLocaleString('es-DO')}`;
    }

    async function guardarInscripcionOficial() {
        const atletaId = document.getElementById('atletaIdIns').value;
        const firmado = document.getElementById('checkDescargo').checked;
        const preparadorId = document.getElementById('selectPreparador')?.value || null;
        
        if (!firmado) {
            return alert("❌ ¡ATENCIÓN!\n\nNo se puede oficializar la inscripción sin la aceptación de la Hoja de Descargo.\n\nPor favor, lea y acepte las políticas FDFF para continuar.");
        }

        // Captura los valores de los checkboxes seleccionados (los IDs de eventos_categorias)
        const categoriasElegidas = Array.from(document.querySelectorAll('.check-cat:checked')).map(cb => cb.value);

        if (categoriasElegidas.length === 0) {
            return alert("Debe seleccionar al menos una categoría para oficializar.");
        }

        try {
            // Hacemos la petición POST al servidor que creamos en el Paso 1
            const respuesta = await fetch('/inscripcion/guardar-asistida', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    atleta_id: atletaId,
                    id_evento: configEl.id,
                    categoriasElegidas: categoriasElegidas,
                    preparador_id: preparadorId
                })
            });

            const resultado = await respuesta.json();

            if (resultado.estado) {
                alert('✅ ' + resultado.mensaje + '\n📝 Firma digital registrada.');
                myModal.hide();
                window.location.reload();
            } else {
                alert('❌ Error: ' + resultado.mensaje);
            }
        } catch (error) {
            console.error("Error en envío:", error);
            alert("Hubo un problema de conexión con el servidor.");
        }
    }

