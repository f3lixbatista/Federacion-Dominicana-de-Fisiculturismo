<%- include("../template/cabecera", {tituloWeb: "Inscripción y Pesaje"}) %>

<div class="container my-5">
    <!-- PANEL DE CONTROL: CIERRE DE INSCRIPCIONES WEB -->
    <div class="card border-danger mb-5 shadow-sm">
        <div class="card-body d-flex justify-content-between align-items-center bg-light">
            <div>
                <h4 class="fw-bold mb-0 text-danger"><i class="fas fa-lock"></i> Fase de Evento: <%= eventoActual.nombre %></h4>
                <p class="small text-muted mb-0">Estado actual: <strong><%= eventoActual.estado.toUpperCase() %></strong></p>
            </div>
            <% if (eventoActual.estado === 'inscripcion') { %>
                <button class="btn btn-danger btn-lg fw-bold" onclick="cerrarInscripcionesWeb('<%= eventoActual.id %>')">
                    CERRAR INSCRIPCIONES WEB
                </button>
            <% } else { %>
                <span class="badge bg-dark p-3 fs-6">INSCRIPCIONES WEB CERRADAS</span>
            <% } %>
        </div>
    </div>

    <!-- SECCIÓN 1: BUSCADOR DE ATLETAS (ESTACIÓN DE REGISTRO) -->
    <div class="card shadow-sm mb-4 border-0" style="border-radius: 15px;">
        <div class="card-body p-4">
            <h5 class="fw-bold mb-3"><i class="fas fa-search me-2"></i> Localizar Atleta para Pesaje</h5>
            
            <div class="row g-2">
                <div class="col-md-8">
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-white border-end-0"><i class="fas fa-user text-muted"></i></span>
                        <input type="text" id="busquedaAtleta" class="form-control border-start-0 ps-0" 
                               placeholder="Escriba Nombre, Cédula o escanee con lector de mano..." onkeyup="filtrarTablaAtletas()">
                    </div>
                </div>
                <div class="col-md-4">
                    <button class="btn btn-dark btn-lg w-100 fw-bold" onclick="iniciarEscaneoCamara()">
                        <i class="fas fa-camera me-2"></i> USAR CÁMARA
                    </button>
                </div>
            </div>
            <div id="reader" class="mt-3 mx-auto" style="width: 300px; display: none;"></div>
        </div>
    </div>

    <div class="container divGeneral border border-1 border-dark p-4 col-12 shadow-sm bg-white" style="border-radius: 15px;">
        <h2 class="mb-4 fw-bold text-primary border-bottom pb-2">Estación de Inscripción Asistida</h2>
        <div class="table-responsive">     
            <table class="table table-striped table-bordered border-dark table-hover" id="mydatatable">
                <thead>
                    <tr class="table-dark text-white"> 
                        <th scope="col" class="text-white">Cédula</th>
                        <th scope="col" class="text-white">Nombre del Atleta</th>  
                        <th scope="col" class="text-white">ID-FDFF</th>
                        <th scope="col" class="text-white">Acción</th>
                    </tr>
                </thead>
                <tbody id="bodyAtletas">
                    <% arrayAtletas.forEach(atleta => { %>
                        <tr>
                            <td><%= atleta.cedula %></td>
                            <td class="fw-bold fs-5"><%= atleta.nombre %></td>
                            <td><%= atleta.idfdff || 'Sin ID' %></td>
                            <td>
                                <button class="btn btn-warning btn-sm fw-bold px-3" 
                                        onclick="abrirModalInscripcion('<%= atleta.id %>', '<%= atleta.nombre.replace(/'/g, "\\'") %>', '<%= atleta.sexo %>', '<%= atleta.fecha_nacimiento %>', '<%= atleta.estatura %>', '<%= atleta.peso %>', '<%= atleta.cedula %>')">
                                    <i class="fas fa-edit"></i> Inscribir
                                </button>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- BOTÓN HACIA LA SIGUIENTE ETAPA -->
    <div class="text-center mt-5 pt-3">
        <a href="/eventos/<%= eventoActual.id %>/preparacion" class="btn btn-outline-dark btn-lg px-5 fw-bold shadow-sm">
            IR A PREPARACIÓN DE EVENTO <i class="fas fa-chevron-right ms-2"></i>
        </a>
    </div>
</div>

<!-- VENTANA FLOTANTE (MODAL): SELECCIÓN DINÁMICA DE CATEGORÍAS -->
<div class="modal fade" id="modalInscripcion" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header bg-primary text-white py-3">
                <h5 class="modal-title fw-bold"><i class="fas fa-clipboard-list me-2"></i> Selección para: <span id="spanNombreAtleta"></span></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="alert alert-warning small mb-3">
                    <i class="fas fa-exclamation-triangle"></i> Al elegir una categoría, el sistema bloqueará automáticamente las modalidades no afines.
                </div>
                
                <form id="formInscripcionAsistida">
                    <input type="hidden" id="atletaIdIns">

                    <div class="mb-4">
                        <label class="form-label fw-bold">Team / Preparador Oficial</label>
                        <select name="preparador_id" id="selectPreparador" class="form-select border-primary select2">
                            <option value="">-- Atleta Independiente --</option>
                            <% (arrayPreparadores || []).forEach(prep => { %>
                                <option value="<%= prep.id %>"><%= prep.nombre_completo %> (<%= prep.gimnasio_labora %>)</option>
                            <% }) %>
                        </select>
                        <small class="text-muted">Si su preparador no aparece, debe registrarse primero en el módulo de Preparadores.</small>
                    </div>
                    
                    <div id="listaCategoriasAfines" class="list-group shadow-sm">
                        <!-- Se inyecta vía JavaScript -->
                    </div>

                    <!-- Componente de Carga de Audio (DJ Virtual) -->
                    <div class="card border-primary mt-4 mb-3">
                        <div class="card-header bg-primary text-white fw-bold">
                            <i class="fas fa-music me-2"></i> Audio de Presentación (DJ Virtual)
                        </div>
                        <div class="card-body">
                            <div id="playerAudio" class="mb-3 d-none">
                                <audio id="audioElement" controls class="w-100"></audio>
                            </div>
                            
                            <div class="input-group">
                                <input type="file" id="fileMusica" class="form-control" accept=".mp3,.wav">
                                <button type="button" onclick="subirMusicaAsistida()" class="btn btn-dark" id="btnSubirMusica">
                                    <i class="fas fa-upload"></i> Cargar
                                </button>
                            </div>
                            <small class="text-muted mt-2 d-block">Límite: 90 segundos. Solo se permite un archivo por evento.</small>
                        </div>
                    </div>

                    <!-- RESUMEN DE COBRO -->
                    <div class="mt-4 p-4 bg-light rounded-4 d-flex justify-content-between align-items-center border border-2 border-success">
                        <div>
                            <h5 class="mb-0 fw-bold">Monto Total a Pagar</h5>
                            <small class="text-muted" id="detallePrecios"></small>
                        </div>
                        <h3 class="mb-0 fw-bold text-success" id="totalMonto">RD$ 0.00</h3>
                    </div>

                    <!-- DOCUMENTO DE DESCARGO Y CONSENTIMIENTO - FDFF -->
                    <div class="card bg-light border-dark mb-3 mt-4">
                        <div class="card-header bg-dark text-white fw-bold small text-center">
                            DOCUMENTO DE DESCARGO Y CONSENTIMIENTO - FDFF
                        </div>
                        <div class="card-body p-4 bg-white" style="max-height: 350px; overflow-y: auto; font-size: 0.85rem; line-height: 1.4;">
                            <p class="text-center fw-bold text-uppercase mb-3">Convenio de participación - FDFF / IFBB</p>
                            
                            <p>Para poder participar como competidor en este evento, afirmo que entiendo y estoy de acuerdo con la constitución y las reglas de la IFBB/FDFF, el código de ética y las reglas antidopajes. Entiendo y concuerdo con las siguientes condiciones:</p>
                            
                            <ol class="ps-3">
                                <li class="mb-2"><strong>Voluntariedad:</strong> Participo de manera totalmente voluntaria y acepto todas las partes de este documento.</li>
                                <li class="mb-2"><strong>Descargo de Responsabilidad:</strong> Exonero a la federación, organizadores, jueces, patrocinadores y staff de cualquier reclamación por daños personales, muerte, pérdida de propiedad o gastos durante mi participación.</li>
                                <li class="mb-2"><strong>Salud y Gastos Médicos:</strong> Confirmo buen estado de salud física y mental. Cualquier daño médico es mi responsabilidad, incluyendo el pago de asistencia médica, liberando a la federación de cobertura económica.</li>
                                <li class="mb-2"><strong>No Coacción:</strong> Afirmo que nadie me obligó a participar.</li>
                                <li class="mb-2"><strong>Reglas y Dopaje:</strong> Acepto ser sometido a pruebas de dopaje sin previo aviso si participo en eventos no avalados, costeando yo mismo dicha prueba.</li>
                                <li class="mb-2"><strong>Derechos de Imagen:</strong> Autorizo el uso de fotos y videos capturados durante el evento para fines de la federación sin requerir pago por derechos.</li>
                                <li class="mb-2"><strong>Mayoría de Edad:</strong> Confirmo ser mayor de edad y haber leído y entendido este convenio.</li>
                            </ol>

                            <div class="bg-light p-2 border rounded mt-3">
                                <p class="mb-1"><strong>Datos del Firmante:</strong></p>
                                <div class="row">
                                    <div class="col-6">Atleta: <span id="signNombre" class="fw-bold"></span></div>
                                    <div class="col-6">Cédula: <span id="signCedula" class="fw-bold"></span></div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-warning bg-opacity-10 border-top d-flex justify-content-between align-items-center">
                            <div class="form-check mb-0">
                                <input class="form-check-input border-dark" type="checkbox" id="checkDescargo" style="width: 1.4rem; height: 1.4rem;">
                                <label class="form-check-label fw-bold ms-2 mt-1" for="checkDescargo" style="cursor: pointer;">
                                    EL ATLETA ACEPTA Y FIRMA ESTE CONVENIO DIGITALMENTE
                                </label>
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-dark fw-bold" onclick="imprimirDescargoFisico()">
                                <i class="fas fa-print me-1"></i> Imprimir Copia Física
                            </button>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light py-3">
                <button type="button" class="btn btn-secondary fw-bold" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary btn-lg fw-bold px-4" onclick="guardarInscripcionOficial()">
                    OFICIALIZAR Y GUARDAR
                </button>
            </div>
        </div>
    </div>
</div>

<script src="/js/supabase.js"></script>
<script>
    // 1. Inicialización de Supabase (usamos las variables inyectadas por app.js)
    const _supabase = supabase.createClient("<%= SUPABASE_URL %>", "<%= SUPABASE_ANON_KEY %>");
    
    // 2. Variables del Servidor (Inyectamos el objeto directo para evitar errores de comillas)
    const categoriasDelEvento = <%- JSON.stringify(arrayCategorias || []) %>;
    const costos = { 
        primera: Number("<%= eventoActual.costo_primera_cat || 0 %>"), 
        adicional: Number("<%= eventoActual.costo_adicional || 0 %>") 
    };

    // 3. Inicialización del Modal
    let myModal;
    document.addEventListener('DOMContentLoaded', () => {
        const modalEl = document.getElementById('modalInscripcion');
        if (modalEl && typeof bootstrap !== 'undefined') {
            myModal = new bootstrap.Modal(modalEl);
        } else if (typeof bootstrap === 'undefined') {
            console.error("Bootstrap no se cargó correctamente. Verifique su conexión o use una copia local.");
        }
    });

async function abrirModalInscripcion(id, nombre, sexo, fechaNac, estatura, peso, cedula) {
        // TRADUCCIÓN DE LA LÓGICA VBA [Páginas 22-26]
        if (!nombre) return alert("Falta Nombre");
        if (!sexo) return alert("Falta Sexo");
        if (!fechaNac) return alert("Falta Fecha Nacimiento");
        
        // Validamos el formato de sexo como lo hacía el Excel
        const sexoNormalizado = sexo.toLowerCase();
        if (sexoNormalizado !== 'm' && sexoNormalizado !== 'f') {
            return alert("Sexo Incorrecto");
        }

        if (!estatura || estatura <= 0) return alert("Falta estatura");
        if (sexoNormalizado === 'm' && (!peso || peso <= 0)) return alert("Falta Peso");

        // Si pasa las validaciones del "Viejo Código", procedemos
        document.getElementById('atletaIdIns').value = id;
        document.getElementById('spanNombreAtleta').innerText = nombre;
        document.getElementById('signNombre').innerText = nombre;
        document.getElementById('signCedula').innerText = cedula || 'Sin especificar';
        document.getElementById('checkDescargo').checked = false; // Reset del checkbox para cada atleta

        // Reset de Música con comprobación de existencia de elementos
        const player = document.getElementById('playerAudio');
        const audio = document.getElementById('audioElement');
        const fileMusica = document.getElementById('fileMusica');

        if (player) player.classList.add('d-none');
        if (audio) {
            audio.pause();
            audio.src = '';
        }
        if (fileMusica) fileMusica.value = '';

        const { data: compData } = await _supabase
            .from('competidores')
            .select('musica_url')
            .eq('atleta_id', id)
            .eq('id_evento', configEl.id)
            .limit(1);

        if (compData && compData.length > 0 && compData[0].musica_url && player && audio) {
            audio.src = compData[0].musica_url;
            player.classList.remove('d-none');
        }
        
        // Inyectamos el costo desde el evento actual
        document.getElementById('detallePrecios').innerText = 
            `1ra Cat: RD$ ${costos.primera.toLocaleString()} | Adic: RD$ ${costos.adicional.toLocaleString()}`;
        
        renderizarCategorias(sexoNormalizado); // Aquí aplicaremos el bloqueo de afinidad
        
        if (myModal) {
            myModal.show();
        } else {
            console.error("Error: El objeto del modal no está inicializado.");
        }
    }

    function renderizarCategorias(sexoAtleta) {
        const contenedor = document.getElementById('listaCategoriasAfines');
        if (!contenedor) return;
        contenedor.innerHTML = '';

        // Filtrado por Sexo con protección contra nulos
        const filtradas = categoriasDelEvento.filter(rel => {
            const sexoCat = rel.categorias?.sexo || 'Unisex';
            return sexoCat === sexoAtleta || sexoCat === 'Unisex';
        });

        if (filtradas.length === 0) {
            contenedor.innerHTML = '<div class="alert alert-warning">No hay categorías disponibles.</div>';
            return;
        }

        filtradas.forEach(rel => {
            const item = `
                <div class="list-group-item d-flex justify-content-between align-items-center cat-item py-3" 
                     data-modalidad="${rel.categorias?.modalidad || ''}" id="item-${rel.id}">
                    <div class="form-check w-100 cursor-pointer">
                        <input class="form-check-input check-cat me-3" type="checkbox" 
                               value="${rel.id}" id="check-${rel.id}" onchange="validarAfinidad(this)">
                        <label class="form-check-label w-100" for="check-${rel.id}">
                            <span class="fw-bold d-block">${rel.categorias?.nombre || 'S/N'}</span>
                            <span class="small text-muted">${rel.categorias?.disciplina || ''} | ${rel.categorias?.modalidad || ''} | ${rel.categorias?.division || ''}</span>
                        </label>
                    </div>
                </div>`;
            contenedor.insertAdjacentHTML('beforeend', item);
        });
        calcularCobro();
    }

    // 1. EL CEREBRO DE REGLAS (Los 7 grupos oficiales de la FDFF)
    const GRUPOS_AFINIDAD = {
        "Bikini": ["Bikini", "Womans Fitmodel", "Fit Pairs", "Woman's Artistic Fitness"],
        "Wellness": ["Wellness", "Woman's Fit Model", "Woman's Acrobatic Fitness"],
        "Bodyfitness": ["Bodyfitness"],
        "Woman's Physique": ["Woman's Physique"],
        "Men's Physique": ["Men's Physique", "Mens Fitmodel", "Fit Pair"], // No incluimos "Clasico" aquí para evitar choque con el Grupo 7
        "Muscular Men's Physique": ["Muscular Men's Physique"],
        "Culturismo": ["Fisiculturismo", "Culturismo", "Classic Physique", "Game's Classic"] 
        // Nota: He agrupado "Fisiculturismo" y "Culturismo" como sinónimos técnicos
    };

    // 2. FUNCIÓN DE BLOQUEO DINÁMICO MEJORADA
    function validarAfinidad(checkbox) {
        const todosLosChecks = document.querySelectorAll('.check-cat');
        const marcados = document.querySelectorAll('.check-cat:checked');
        
        if (marcados.length > 0) {
            // 1. Identificamos el grupo de la PRIMERA categoría que se marcó
            const nombrePrimeraCat = marcados[0].closest('.cat-item').querySelector('.fw-bold').innerText;
            
            let grupoActivoKey = null;
            
            // Buscamos a qué "familia" pertenece según las palabras clave
            for (const familia in GRUPOS_AFINIDAD) {
                const coincidencias = GRUPOS_AFINIDAD[familia];
                if (coincidencias.some(palabra => nombrePrimeraCat.toLowerCase().includes(palabra.toLowerCase()))) {
                    grupoActivoKey = familia;
                    break;
                }
            }

            const permitidos = grupoActivoKey ? GRUPOS_AFINIDAD[grupoActivoKey] : [nombrePrimeraCat];

            // 2. EJECUTAMOS EL BLOQUEO
            todosLosChecks.forEach(cb => {
                const item = cb.closest('.cat-item');
                const nombreItem = item.querySelector('.fw-bold').innerText;

                // REGLA: Si el nombre del item no contiene ninguna de las palabras permitidas del grupo
                const esValida = permitidos.some(p => nombreItem.toLowerCase().includes(p.toLowerCase()));
                
                if (!esValida && !cb.checked) {
                    cb.disabled = true;
                    item.classList.add('opacity-50', 'bg-light');
                } else {
                    cb.disabled = false;
                    item.classList.remove('opacity-50', 'bg-light');
                }
            });
        } else {
            // RESET: Si desmarcan todo, habilitamos todas las opciones
            todosLosChecks.forEach(cb => {
                cb.disabled = false;
                cb.closest('.cat-item').classList.remove('opacity-50', 'bg-light');
            });
        }
        calcularCobro();
    }

    function liberarFormulario() {
        const todosLosItems = document.querySelectorAll('.cat-item');
        todosLosItems.forEach(item => {
            const cb = item.querySelector('.check-cat');
            cb.disabled = false;
            item.classList.remove('opacity-50', 'bg-light');
        });
    }

    function calcularCobro() {
        const cantidad = document.querySelectorAll('.check-cat:checked').length;
        let total = 0;
        
        if (cantidad > 0) {
            // Costos definidos a nivel de evento
            total = costos.primera + ((cantidad - 1) * costos.adicional);
        }
        
        document.getElementById('totalMonto').innerText = `RD$ ${total.toLocaleString('es-DO')}`;
    }

    async function guardarInscripcionOficial() {
        const atletaId = document.getElementById('atletaIdIns').value;
        const firmado = document.getElementById('checkDescargo').checked;
        const preparadorId = document.getElementById('selectPreparador')?.value || null;
        
        if (!firmado) {
            return alert("❌ ¡ATENCIÓN!\n\nNo se puede oficializar la inscripción sin la aceptación de la Hoja de Descargo.\n\nPor favor, lea y acepte las políticas FDFF para continuar.");
        }

        // Captura los valores de los checkboxes seleccionados (los IDs de eventos_categorias)
        const categoriasElegidas = Array.from(document.querySelectorAll('.check-cat:checked')).map(cb => cb.value);

        if (categoriasElegidas.length === 0) {
            return alert("Debe seleccionar al menos una categoría para oficializar.");
        }

        try {
            // Hacemos la petición POST al servidor que creamos en el Paso 1
            const respuesta = await fetch('/inscripcion/guardar-asistida', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    atleta_id: atletaId,
                    id_evento: configEl.id,
                    categoriasElegidas: categoriasElegidas,
                    preparador_id: preparadorId
                })
            });

            const resultado = await respuesta.json();

            if (resultado.estado) {
                // Capturamos la información del juez/estadístico actual (si está disponible)
                const sesionActual = await _supabase.auth.getSession();
                const juezId = sesionActual?.data?.session?.user?.id || null;
                
                // Al guardar, actualizamos la tabla atletas con información completa de firma
                const { error: updateError } = await _supabase.from('atletas')
                    .update({ 
                        descargo_firmado: true,
                        fecha_firma_descargo: new Date().toISOString(),
                        juez_firma_id: juezId
                    })
                    .eq('id', atletaId);
                
                if (updateError) {
                    console.error('Error actualizando descargo:', updateError);
                    alert('⚠️ Inscripción guardada pero hubo un error registrando la firma digital.');
                } else {
                    alert('✅ ' + resultado.mensaje + '\n📝 Firma digital registrada en timestamp.');
                }
                
                myModal.hide();
                window.location.reload(); // Recargamos para actualizar las tablas
            } else {
                alert('❌ Error: ' + resultado.mensaje);
            }
        } catch (error) {
            console.error("Error en envío:", error);
            alert("Hubo un problema de conexión con el servidor.");
        }
    }

    function imprimirDescargoFisico() {
        const nombreAtleta = document.getElementById('signNombre').innerText || 'Nombre del Atleta';
        const cedulaAtleta = document.getElementById('signCedula').innerText || 'Cédula/Pasaporte';
        const categoriasMarc = Array.from(document.querySelectorAll('.check-cat:checked'))
            .map(cb => cb.closest('.cat-item').querySelector('.fw-bold').innerText)
            .join(', ') || 'Categoría';
        const fechaActual = new Date().toLocaleDateString('es-DO');
        
        const printWindow = window.open('', '_blank');
        const content = `
            <!DOCTYPE html>
            <html lang="es">
            <head>
                <meta charset="UTF-8">
                <title>Descargo FDFF - ${nombreAtleta}</title>
                <style>
                    body {
                        font-family: Arial, sans-serif;
                        padding: 40px;
                        line-height: 1.6;
                        max-width: 800px;
                        margin: 0 auto;
                    }
                    .header {
                        text-align: center;
                        border-bottom: 3px solid #000;
                        padding-bottom: 15px;
                        margin-bottom: 20px;
                    }
                    .header h2 { margin: 5px 0; font-size: 18px; }
                    .header p { margin: 3px 0; font-size: 12px; }
                    .content {
                        font-size: 13px;
                        margin: 20px 0;
                    }
                    .content ol li {
                        margin-bottom: 10px;
                        text-align: justify;
                    }
                    .datos-box {
                        border: 2px solid #000;
                        padding: 15px;
                        margin: 20px 0;
                        font-size: 12px;
                    }
                    .datos-box p { margin: 8px 0; }
                    .firma-section {
                        margin-top: 30px;
                        text-align: center;
                    }
                    .firma-linea {
                        display: inline-block;
                        width: 40%;
                        margin: 0 5%;
                        text-align: center;
                    }
                    .firma-linea hr { margin: 40px 0 5px 0; }
                    .firma-linea p { margin: 5px 0; font-size: 11px; }
                    @media print {
                        body { padding: 20px; }
                    }
                </style>
            </head>
            <body>
                <div class="header">
                    <h2>FEDERACIÓN DOMINICANA DE FISICULTURISMO Y FITNESS</h2>
                    <h3>DOCUMENTO DE DESCARGO Y CONSENTIMIENTO</h3>
                    <p><strong>Evento:</strong> <%= eventoActual.nombre %></p>
                    <p><strong>Fecha:</strong> ${fechaActual}</p>
                </div>

                <div class="content">
                    <p><strong>CONVENIO DE PARTICIPACIÓN - FDFF / IFBB</strong></p>
                    <p style="text-align: justify;">Para poder participar como competidor en este evento, afirmo que entiendo y estoy de acuerdo con la constitución y las reglas de la IFBB/FDFF, el código de ética y las reglas antidopajes. Entiendo y concuerdo con las siguientes condiciones:</p>
                    
                    <ol>
                        <li><strong>Voluntariedad:</strong> Participo de manera totalmente voluntaria y acepto todas las partes de este documento.</li>
                        <li><strong>Descargo de Responsabilidad:</strong> Exonero a la federación, organizadores, jueces, patrocinadores y staff de cualquier reclamación por daños personales, muerte, pérdida de propiedad o gastos durante mi participación.</li>
                        <li><strong>Salud y Gastos Médicos:</strong> Confirmo buen estado de salud física y mental. Cualquier daño médico es mi responsabilidad, incluyendo el pago de asistencia médica, liberando a la federación de cobertura económica.</li>
                        <li><strong>No Coacción:</strong> Afirmo que nadie me obligó a participar.</li>
                        <li><strong>Reglas y Dopaje:</strong> Acepto ser sometido a pruebas de dopaje sin previo aviso si participo en eventos no avalados, costeando yo mismo dicha prueba.</li>
                        <li><strong>Derechos de Imagen:</strong> Autorizo el uso de fotos y videos capturados durante el evento para fines de la federación sin requerir pago por derechos.</li>
                        <li><strong>Mayoría de Edad:</strong> Confirmo ser mayor de edad y haber leído y entendido este convenio.</li>
                    </ol>
                </div>

                <div class="datos-box">
                    <p><strong>DATOS DEL COMPETIDOR:</strong></p>
                    <p>Nombre: <strong>${nombreAtleta}</strong></p>
                    <p>Cédula/Pasaporte: <strong>${cedulaAtleta}</strong></p>
                    <p>Categoría: <strong>${categoriasMarc}</strong></p>
                    <p>Fecha de Registro: <strong>${fechaActual}</strong></p>
                </div>

                <div class="firma-section">
                    <p><strong>FIRMAS DE ACEPTACIÓN</strong></p>
                    <div class="firma-linea">
                        <hr>
                        <p>Firma del Atleta</p>
                    </div>
                    <div class="firma-linea">
                        <hr>
                        <p>Juez/Estadístico FDFF</p>
                    </div>
                </div>
            </body>
            </html>
        `;
        
        printWindow.document.write(content);
        printWindow.document.close();
        
        // Esperar a que el contenido se cargue antes de imprimir
        printWindow.onload = function() {
            printWindow.focus();
            printWindow.print();
        };
    }

    
    async function cerrarInscripcionesWeb(eventoId) {
        if (!confirm("¿Cerrar autoinscripciones web?")) return;
        const { error } = await _supabase.from('eventos').update({ estado: 'pesaje' }).eq('id', eventoId);
        if (error) alert(error.message);
        else location.reload();
    }

    async function subirMusicaAsistida() {
        const atletaId = document.getElementById('atletaIdIns').value;
        const file = document.getElementById('fileMusica').files[0];
        const idEvento = configEl.id;
        
        if(!file) return alert("Elija un archivo de audio.");
        
        const btn = document.getElementById('btnSubirMusica');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

        const filePath = `${atletaId}/pose_${Date.now()}.mp3`;
        
        try {
            const { data, error } = await _supabase.storage
                .from('musica_atletas')
                .upload(filePath, file, { upsert: true });

            if(error) throw error;

            const { data: { publicUrl } } = _supabase.storage.from('musica_atletas').getPublicUrl(filePath);
            
            await _supabase.from('competidores')
                .update({ musica_url: publicUrl })
                .eq('atleta_id', atletaId)
                .eq('id_evento', idEvento);
                
            alert("Música vinculada al dorsal correctamente.");
            
            const player = document.getElementById('playerAudio');
            const audio = document.getElementById('audioElement');
            audio.src = publicUrl;
            player.classList.remove('d-none');
        } catch (err) {
            alert("Error al procesar audio: " + err.message);
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-upload"></i> Cargar';
        }
    }

    // --- Lógica de Búsqueda y QR ---
    const listaAtletasGlobal = <%- JSON.stringify(arrayAtletas || []) %>;

    function filtrarTablaAtletas() {
        const input = document.getElementById('busquedaAtleta').value;
        // Usamos la API de DataTables para filtrar la tabla existente
        $('#mydatatable').DataTable().search(input).draw();
    }

    async function iniciarEscaneoCamara() {
        const readerDiv = document.getElementById('reader');
        readerDiv.style.display = 'block';
        
        if (typeof Html5Qrcode === 'undefined') {
            return alert("La librería de escaneo QR no se ha cargado. Verifique su conexión a internet.");
        }
        const html5QrCode = new Html5Qrcode("reader");
        
        html5QrCode.start(
            { facingMode: "environment" }, 
            { fps: 10, qrbox: 250 },
            (decodedText) => {
                // El QR del ticket lleva la URL completa o solo el ID.
                // Extraemos el ID del atleta (última parte de la URL o el texto directo)
                const atletaId = decodedText.split('/').pop();
                
                if(atletaId) {
                    html5QrCode.stop().then(() => {
                        readerDiv.style.display = 'none';
                        seleccionarAtleta(atletaId);
                    });
                }
            }
        ).catch(err => alert("Error de cámara: " + err));
    }

    function seleccionarAtleta(id) {
        // Buscamos el atleta en la lista cargada para abrir su modal
        const atl = listaAtletasGlobal.find(a => a.id === id);
        if(atl) {
            abrirModalInscripcion(atl.id, atl.nombre, atl.sexo, atl.fecha_nacimiento, atl.estatura, atl.peso, atl.cedula);
        } else {
            alert("Atleta no encontrado en el listado de atletas habilitados.");
        }
    }

