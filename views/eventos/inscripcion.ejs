    async function cerrarInscripcionesWeb(eventoId) {
        if (!confirm("¿Cerrar autoinscripciones web?")) return;
        const r = await fetch('/inscripcion/cerrar-web', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ eventoId })
        });
        const d = await r.json();
        if (!d.ok) alert('Error: ' + d.mensaje);
        else location.reload();
    }

    async function subirMusicaAsistida() {
        const atletaId = document.getElementById('atletaIdIns').value;
        const file = document.getElementById('fileMusica').files[0];
        const idEvento = configEl.id;

        if (!file) return alert("Elija un archivo de audio.");
        if (!atletaId) return alert("No hay atleta seleccionado.");

        const btn = document.getElementById('btnSubirMusica');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

        try {
            const formData = new FormData();
            formData.append('musica', file);
            formData.append('atletaId', atletaId);
            formData.append('eventoId', idEvento);

            const resp = await fetch('/inscripcion/subir-musica', { method: 'POST', body: formData });
            const result = await resp.json();

            if (!resp.ok || result.error) throw new Error(result.error || 'Error desconocido');

            const player = document.getElementById('playerAudio');
            const audio = document.getElementById('audioElement');
            const sinMusica = document.getElementById('sinMusica');
            audio.src = result.url;
            player.style.display = 'block';
            if (sinMusica) sinMusica.style.display = 'none';
            alert("Música vinculada al dorsal correctamente.");
        } catch (err) {
            alert("Error al procesar audio: " + err.message);
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-upload"></i> Cargar';
        }
    }

