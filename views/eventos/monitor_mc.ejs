<%- include("../template/cabecera", {tituloWeb: "Monitor de Tarima - MC"}) %>

<div class="container-fluid my-4 px-4">
    <div class="row g-4">
        <!-- COLUMNA IZQUIERDA: EL PROGRAMA DE COMPETENCIA (CON CHECKS) -->
        <div class="col-lg-7">
            <div class="card border-0 shadow p-4 bg-white" style="border-radius: 15px;">
                <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
                    <div>
                        <h2 class="fw-bold text-dark mb-0"><i class="fas fa-play-circle text-success"></i> Programa Oficial</h2>
                        <p class="text-muted small mb-0">Marque las actividades completadas para llevar el control del show.</p>
                    </div>
                    <span class="badge bg-danger p-2 fs-6">EN VIVO</span>
                </div>

                <div class="list-group gap-2" id="listaProgramaMC">
                    <% if(evento.cronograma_mc && evento.cronograma_mc.length > 0) { %>
                        <% evento.cronograma_mc.forEach((bloque, index) => { %>
                            <div class="list-group-item d-flex justify-content-between align-items-center py-3 border-start border-4 
                                <%= bloque.tipo === 'Categoría' ? 'border-primary bg-light' : '' %>
                                <%= bloque.tipo === 'Protocolo' ? 'border-info' : '' %>
                                <%= bloque.tipo === 'Premiación' ? 'border-warning' : '' %>
                                <%= bloque.tipo === 'Receso' ? 'border-danger' : '' %>" 
                                id="item-mc-<%= index %>">
                                
                                <div class="form-check d-flex align-items-center gap-3">
                                    <input class="form-check-input check-progreso-mc" type="checkbox" style="width: 1.5rem; height: 1.5rem;"
                                           onchange="marcarProgresoMc('item-mc-<%= index %>', this.checked)">
                                    <label class="form-check-label fw-bold text-dark fs-5 mb-0">
                                        <%= bloque.nombre %>
                                        <% if(bloque.tipo === 'Categoría') { %>
                                            <span class="d-block small text-muted font-monospace" style="font-size:0.8rem;">Próxima categoría a la expectativa</span>
                                        <% } %>
                                    </label>
                                </div>
                                <span class="badge bg-secondary text-uppercase small" style="font-size:0.65rem;"><%= bloque.tipo %></span>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="alert alert-warning text-center">El programa general no ha sido oficializado por la mesa técnica.</div>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- COLUMNA DERECHA: MICRÓFONO EN VIVO (RESULTADOS DESDE ESTADÍSTICA) -->
        <div class="col-lg-5">
            <div class="card border-0 shadow p-4 bg-dark text-white sticky-top" style="top: 20px; border-radius: 15px; min-height: 80vh;">
                <div class="border-bottom border-secondary pb-2 mb-3 d-flex justify-content-between align-items-center">
                    <h3 class="fw-bold text-warning mb-0"><i class="fas fa-broadcast-tower"></i> Audio / Micrófono</h3>
                    <button class="btn btn-sm btn-outline-warning" onclick="sincronizarResultadosMc()"><i class="fas fa-sync-alt"></i></button>
                </div>
                
                <p class="text-light small opacity-75">Los listados de Semifinalistas, Finalistas y Pódiums aprobados por los jueces aparecerán aquí automáticamente.</p>

                <!-- CONTENEDOR DINÁMICO DE REPORTES -->
                <div id="pantallaResultadosMC" class="mt-4">
                    <div class="text-center py-5 text-muted italic" id="txtEsperando">
                        <i class="fas fa-clock fs-1 mb-3 text-secondary animate-pulse"></i>
                        <p class="mb-0">Esperando reportes oficiales desde la mesa estadística...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="/js/supabase.js"></script>
<script>
    const _supabase = supabase.createClient("<%= supabaseUrl %>", "<%= supabaseKey %>");
    const idEvento = "<%= evento.id %>";

    function marcarProgresoMc(idElemento, completado) {
        const fila = document.getElementById(idElemento);
        if (completado) {
            fila.classList.add('opacity-50', 'bg-light');
            fila.style.textDecoration = 'line-through';
        } else {
            fila.classList.remove('opacity-50', 'bg-light');
            fila.style.textDecoration = 'none';
        }
    }

    async function sincronizarResultadosMc() {
        const { data, error } = await _supabase
            .from('eventos')
            .select('resultados_en_vivo')
            .eq('id', idEvento)
            .single();

        if (error) {
            console.error('Error sincronizando MC:', error.message || error);
            return;
        }

        if (data && data.resultados_en_vivo && Object.keys(data.resultados_en_vivo).length > 0) {
            document.getElementById('txtEsperando').classList.add('d-none');
            const res = data.resultados_en_vivo;
            
            let htmlResultados = `
                <div class="card bg-secondary bg-opacity-25 border-warning p-3 mb-3">
                    <h5 class="fw-bold text-warning border-bottom pb-1 mb-2"><i class="fas fa-trophy"></i> ${res.categoria_nombre}</h5>
                    <h6 class="text-uppercase fw-bold text-info fs-6">${res.fase_competencia}</h6>
                    <ol class="fs-4 fw-bold mt-3 text-white">
            `;

            (res.atletas || []).forEach(atleta => {
                htmlResultados += `<li class="mb-2">Dorsal [${atleta.dorsal}] — ${atleta.nombre}</li>`;
            });

            htmlResultados += `</ol></div>`;
            document.getElementById('pantallaResultadosMC').innerHTML = htmlResultados;
            
            const audio = new Audio('https://assets.mixkit.co/sfx/preview/mixkit-notification-bing-615.mp3');
            audio.play().catch(() => {});
        }
    }

    _supabase
        .channel('cambios-mc')
        .on('postgres_changes', { event: 'UPDATE', schema: 'public', table: 'eventos', filter: `id=eq.${idEvento}` }, payload => {
            console.log('Nuevos resultados inyectados desde estadística');
            sincronizarResultadosMc();
        })
        .subscribe();

    sincronizarResultadosMc();
</script>

<%- include("../template/footer") %>
