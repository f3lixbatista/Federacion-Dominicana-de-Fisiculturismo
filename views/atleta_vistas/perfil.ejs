<%- include("../template/cabecera", {tituloWeb: "Mi Perfil de Atleta"}) %>

<div class="container my-5">
    <div class="row g-4">
        <!-- COLUMNA IZQUIERDA: CARNET DIGITAL Y AFILIACIÓN -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm text-center p-4 bg-white mb-4" style="border-radius: 15px;">
                <div class="mx-auto mb-3 shadow-sm" style="width: 100px; height: 125px; overflow: hidden; border-radius: 10px; border: 3px solid #f8f9fa;">
                    <% if (atleta.foto_url) { %>
                        <img src="<%= atleta.foto_url %>" class="w-100 h-100" style="object-fit: cover;" alt="Foto Carnet">
                    <% } else { %>
                        <div class="bg-primary text-white w-100 h-100 d-flex align-items-center justify-content-center">
                            <i class="fas fa-user-tie display-4"></i>
                        </div>
                    <% } %>
                </div>
                <h6 class="fw-bold mb-1"><%= atleta.nombre %></h6>
                <p class="text-muted small mb-3"><%= user.email %></p>
                
                <!-- En lugar de buscar un ID en la tabla atletas, usamos el del perfil -->
                <p class="small mb-2 text-warning fw-bold">
                    ID OFICIAL: <%= user.idfdff %>
                </p>
                
                <!-- ESTADO DE AFILIACIÓN -->
                <div class="p-2 rounded mb-3 <%= atleta.estatus_afiliacion === 'habilitado' ? 'bg-success bg-opacity-10 text-success' : 'bg-danger bg-opacity-10 text-danger' %>">
                    <span class="small fw-bold text-uppercase">Membresía FDFF</span>
                    <h5 class="fw-bold mb-0 mt-1">
                        <i class="fas <%= atleta.estatus_afiliacion === 'habilitado' ? 'fa-check-circle' : 'fa-times-circle' %>"></i>
                        <%= atleta.estatus_afiliacion ? atleta.estatus_afiliacion.toUpperCase() : 'PENDIENTE' %>
                    </h5>
                </div>
                
                <div class="text-start small text-muted border-top pt-3">
                    <p class="mb-1"><strong>Cédula:</strong> <%= atleta.cedula || '--' %></p>
                    <p class="mb-1"><strong>Sexo:</strong> <%= atleta.sexo || '--' %></p>
                    <p class="mb-0"><strong>Última Renovación:</strong> <%= atleta.fecha_ultima_renovacion || 'No registrada' %></p>
                </div>
            </div>

            <!-- FORMULARIO CARGA FOTO CARNET -->
            <div class="card border-0 shadow-sm p-3 mt-3 bg-light" style="border-radius: 15px;">
                <label class="form-label small fw-bold text-dark text-uppercase">
                    <i class="fas fa-id-badge me-1"></i> Actualizar Foto Oficial
                </label>
                <div class="input-group input-group-sm">
                    <input type="file" id="inputFotoCarnet" class="form-control" accept="image/*">
                    <button class="btn btn-primary fw-bold" type="button" id="btnSubirFoto" onclick="actualizarFotoCarnet()">
                        SUBIR
                    </button>
                </div>
                <p class="text-muted mt-1 mb-0" style="font-size: 0.65rem;">
                    * Se recomienda fondo liso. Al subir una nueva, se borrará la anterior.
                </p>
            </div>

            <!-- GESTIÓN DE PREPARADOR / TEAM -->
            <div class="card border-0 shadow-sm p-4 bg-white" style="border-radius: 15px;">
                <h5 class="fw-bold mb-3 text-dark"><i class="fas fa-user-tie text-secondary me-2"></i> Mi Preparador / Team</h5>
                <form id="formActualizarTeam">
                    <div class="mb-3">
                        <select id="selectPrepPerfil" class="form-select border-primary font-monospace small">
                            <option value="">-- Atleta Independiente --</option>
                            <% preparadores.forEach(prep => { %>
                                <option value="<%= prep.id %>" <%= atleta.preparador_id === prep.id ? 'selected' : '' %>>
                                    <%= prep.nombre_completo %> (<%= prep.gimnasio_labora %>)
                                </option>
                            <% }) %>
                        </select>
                    </div>
                    <button type="button" onclick="modificarTeamAtleta()" class="btn btn-primary btn-sm w-100 fw-bold shadow-sm">
                        ACTUALIZAR MI COACH
                    </button>
                </form>
                <% if (atleta.preparador_id) { %>
                <div class="mt-2">
                    <a href="/preparadores/team/<%= atleta.preparador_id %>" target="_blank" class="btn btn-outline-dark btn-sm w-100">
                        <i class="fas fa-users me-1"></i> Ver Perfil del Team
                    </a>
                </div>
                <% } %>
            </div>
        </div>

        <!-- COLUMNA DERECHA: HISTORIAL DE COMPETENCIA FDFF -->
        <div class="col-lg-8">
            <!-- CENTRO DE SEGUIMIENTO DE INSCRIPCIÓN -->
            <% if (locals.evento) { %>
                <div class="card shadow-sm border-0 mb-4" style="border-radius: 15px;">
                    <div class="card-header bg-dark text-white fw-bold">
                        <i class="fas fa-tasks me-2"></i> Estatus de mi Inscripción: <%= evento.nombre %>
                    </div>
                    <div class="card-body">
                        <% if (inscripcion && inscripcion.observaciones_pago && !inscripcion.pago_validado) { %>
                            <div class="alert alert-danger border-2 shadow-sm mb-3">
                                <h6 class="fw-bold"><i class="fas fa-exclamation-triangle"></i> ATENCIÓN: Tu pago fue rechazado</h6>
                                <p class="mb-2"><strong>Motivo:</strong> <%= inscripcion.observaciones_pago %></p>
                                <hr>
                                <p class="small mb-0">Por favor, sube un nuevo comprobante corregido para continuar.</p>
                            </div>
                        <% } %>

                        <% if (!inscripcion) { %>
                            <!-- FASE 0: No ha empezado -->
                            <p class="text-muted">Aún no te has inscrito en este evento.</p>
                            <a href="/inscripcion/InscripcionAtleta?evento=<%= evento.id %>" class="btn btn-primary w-100 fw-bold">
                                INICIAR INSCRIPCIÓN
                            </a>
                        <% } else if (!inscripcion.url_comprobante_pago) { %>
                            <!-- FASE 1: Inscrito pero sin comprobante -->
                            <div class="alert alert-warning border-0 mb-3 shadow-sm">
                                <strong><i class="fas fa-clock"></i> Pendiente de Pago</strong><br>
                                Ya elegiste tus categorías, pero falta el comprobante para activar tu ticket.
                            </div>
                            
                            <div class="bg-light p-3 rounded mb-3 border">
                                <small class="text-muted d-block fw-bold">Monto a depositar:</small>
                                <h4 class="fw-bold text-primary">RD$ <%= inscripcion.monto_total.toLocaleString() %></h4>
                                <p class="small mb-0">Cuenta Corriente: 123456789 (Banreservas)</p>
                            </div>

                            <label class="form-label small fw-bold">Subir Comprobante de Depósito/Transferencia:</label>
                            <div class="input-group">
                                <input type="file" id="inputRetomaPago" class="form-control" accept="image/*">
                                <button onclick="subirPagoDiferido('<%= inscripcion.id %>')" class="btn btn-dark fw-bold">SUBIR</button>
                            </div>
                        <% } else if (!inscripcion.pago_validado) { %>
                            <!-- FASE 2: Esperando al Staff -->
                            <div class="text-center py-3">
                                <i class="fas fa-hourglass-half fa-2x text-warning mb-2"></i>
                                <h6 class="fw-bold text-uppercase">Comprobante en Revisión</h6>
                                <p class="small text-muted">Subiste tu pago el <%= new Date(inscripcion.fecha_subida_pago).toLocaleDateString('es-DO') %>. Estamos validando con el banco.</p>
                            </div>
                        <% } else { %>
                            <!-- FASE 3: Todo listo -->
                            <div class="text-center py-3">
                                <i class="fas fa-check-circle fa-2x text-success mb-2"></i>
                                <h6 class="fw-bold text-uppercase">¡Todo listo para el pesaje!</h6>
                                <a href="/atletas/mi-comprobante/<%= evento.id %>" class="btn btn-success fw-bold shadow-sm px-4">
                                    <i class="fas fa-qrcode me-2"></i> DESCARGAR TICKET QR
                                </a>
                            </div>
                        <% } %>
                    </div>
                </div>
            <% } %>

            <!-- SECCIÓN DE MÚSICA -->
            <%
                var _compActivo = null;
                if (historial && historial.length > 0) {
                    _compActivo = historial.find(function(h) {
                        return h.eventos && (h.eventos.estado === 'inscripcion' || h.eventos.estado === 'pesaje');
                    });
                }
            %>
            <% if (_compActivo) { %>
            <div class="card border-0 shadow-sm mb-4" style="border-radius: 15px;">
                <div class="card-header bg-dark text-white fw-bold py-3">
                    <i class="fas fa-music me-2 text-warning"></i> Mi Música de Poses / Pasarela
                </div>
                <div class="card-body">
                    <% if (_compActivo.musica_url) { %>
                        <p class="small text-muted mb-1">Tu música actual:</p>
                        <audio controls class="w-100 mb-2">
                            <source src="<%= _compActivo.musica_url.split('?')[0] %>">
                            Tu navegador no soporta audio.
                        </audio>
                        <p class="small text-success mb-3">
                            <i class="fas fa-check-circle me-1"></i> El DJ ya tiene tu música para <strong><%= _compActivo.eventos.nombre %></strong>.
                        </p>
                    <% } else { %>
                        <div class="alert alert-warning py-2 small mb-3">
                            <i class="fas fa-exclamation-triangle me-1"></i>
                            Aún no has subido tu música para <strong><%= _compActivo.eventos.nombre %></strong>. El DJ usará una canción genérica.
                        </div>
                    <% } %>
                    <label class="form-label small fw-bold">
                        <%= _compActivo.musica_url ? 'Cambiar música:' : 'Subir mi música:' %>
                    </label>
                    <div class="input-group">
                        <input type="file" id="inputMusica" class="form-control" accept="audio/mp3,audio/wav,audio/ogg,audio/x-m4a,audio/*">
                        <button onclick="subirMusica('<%= _compActivo.eventos.id %>')" id="btnSubirMusica" class="btn btn-dark fw-bold">
                            <i class="fas fa-upload me-1"></i> SUBIR
                        </button>
                    </div>
                    <p class="text-muted mt-1 mb-0" style="font-size: 0.65rem;">
                        * Formatos: MP3, WAV, M4A. Máx 20MB. Esta música se reproducirá cuando salgas a escena.
                    </p>
                </div>
            </div>
            <% } %>

            <div class="card border-0 shadow-sm p-4 bg-white" style="border-radius: 15px; min-height: 550px;">
                <h3 class="fw-bold text-dark mb-4 border-bottom pb-2"><i class="fas fa-history text-primary"></i> Mi Historial de Competencias</h3>
                
                <div class="table-responsive">
                    <table class="table table-hover align-middle text-center small">
                        <thead class="table-light">
                            <tr>
                                <th class="text-start">Evento / Competencia</th>
                                <th>Categoría Evaluada</th>
                                <th>Dorsal</th>
                                <th>Pódium Final</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (historial && historial.length > 0) { %>
                                <% historial.forEach(row => { %>
                                    <tr>
                                        <td class="text-start">
                                            <div class="fw-bold text-dark"><%= row.eventos?.nombre %></div>
                                            <div class="text-muted" style="font-size:0.75rem;"><%= row.eventos?.fecha_inicio %></div>
                                        </td>
                                        <td class="fw-bold"><%= row.eventos_categorias?.categorias?.nombre %></td>
                                        <td>
                                            <span class="badge bg-secondary p-2 fs-6"><%= row.numero_atleta || '---' %></span>
                                        </td>
                                        <td class="fw-bold fs-5">
                                            <% if (row.eventos?.estado === 'finalizado') { %>
                                                <div class="d-flex flex-column align-items-center">
                                                    <span class="<%= row.posicion_final <= 3 ? 'text-warning' : 'text-success' %>">
                                                        <%= row.posicion_final %>° Lugar
                                                    </span>
                                                    <a href="/eventos/atleta/<%= atleta.id %>/evento/<%= row.eventos.id %>/diploma" 
                                                       target="_blank" class="btn btn-outline-danger btn-sm mt-1" style="font-size: 0.7rem;">
                                                        <i class="fas fa-certificate"></i> DIPLOMA
                                                    </a>
                                                    <a href="/eventos/atleta/<%= atleta.id %>/evento/<%= row.eventos.id %>/certificado-oficial" 
                                                       target="_blank" class="btn btn-outline-primary btn-sm mt-1" style="font-size: 0.7rem;">
                                                        <i class="fas fa-file-contract"></i> CERTIFICADO
                                                    </a>
                                                </div>
                                            <% } else { %>
                                                <span class="text-muted font-monospace" style="font-size:0.8rem;">En progreso...</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="4" class="text-center py-5 text-muted italic">
                                        <i class="fas fa-award display-6 text-light mb-3 d-block"></i>
                                        Aún no registras participaciones oficiales en eventos FDFF.
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- SECCIÓN SOCIAL: MURO DEL ATLETA -->
            <div class="card border-0 shadow-sm p-4 bg-white mt-4" style="border-radius: 15px;">
                <h3 class="fw-bold text-dark mb-4 border-bottom pb-2">
                    <i class="fas fa-camera-retro text-primary"></i> Mi Galería y Muro
                </h3>
                
                <!-- Formulario de Subida (Integrado de perfil.ejs) -->
                <div class="bg-light p-3 rounded mb-4">
                    <form action="/atletas/perfil/subir-foto" method="POST" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Subir nueva foto al muro</label>
                            <input type="file" name="imagen" class="form-control form-control-sm" accept="image/*" required>
                        </div>
                        <div class="mb-3">
                            <textarea name="descripcion" class="form-control form-control-sm" placeholder="¿Qué estás entrenando hoy?" rows="2"></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm fw-bold">PUBLICAR</button>
                    </form>
                </div>

                <!-- Feed de Publicaciones -->
                <div class="d-flex flex-column align-items-center gap-5">
                    <% if (publicaciones && publicaciones.length > 0) { %>
                        <% publicaciones.forEach(post => { %>
                            <div class="w-100" style="max-width: 550px;">
                                <div class="card border-0 shadow-sm" style="border-radius: 15px; overflow: hidden;">
                                    <!-- Cabecera del Post -->
                                    <div class="card-header bg-white border-0 py-3 d-flex align-items-center px-3">
                                        <div class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center me-2 shadow-sm" style="width: 35px; height: 35px; overflow: hidden;">
                                            <% if (post.atletas && post.atletas.foto_url) { %>
                                                <img src="<%= post.atletas.foto_url %>" class="w-100 h-100" style="object-fit: cover;">
                                            <% } else { %>
                                                <i class="fas fa-user small"></i>
                                            <% } %>
                                        </div>
                                        <h6 class="fw-bold mb-0 text-dark small"><%= post.profiles?.nombre || post.atletas?.nombre || 'Mi Perfil' %></h6>
                                    </div>
                                    <img src="<%= post.imagen_url %>" class="card-img-top" style="height: 550px; object-fit: cover;">
                                    <div class="card-body p-3">
                                        <p class="mb-2 text-dark"><strong><%= (post.profiles?.nombre || post.atletas?.nombre || 'Atleta').split(' ')[0] %>:</strong> <%= post.descripcion %></p>
                                        
                                        <!-- Like e Interacción (Solo Autenticados) -->
                                        <div class="d-flex align-items-center mb-3">
                                            <button class="btn btn-sm btn-link p-0 text-decoration-none me-3" onclick="toggleLike('<%= post.id %>')">
                                                <i class="<%= post.userLiked ? 'fas' : 'far' %> fa-heart text-danger fs-4"></i>
                                            </button>
                                            <span class="small fw-bold" id="like-count-<%= post.id %>">
                                                <%= post.likesCount %> me gusta
                                            </span>
                                        </div>
                                        
                                        <!-- Comentarios -->
                                        <div class="comentarios-box mb-3" style="max-height: 200px; overflow-y: auto;">
                                            <% if (post.publicacion_comentarios && post.publicacion_comentarios.length > 0) { %>
                                                <% post.publicacion_comentarios.forEach(c => { %>
                                                    <div class="small bg-light p-1 mb-1 rounded border-start border-primary border-3">
                                                        <strong class="text-primary"><%= c.profiles?.nombre || 'Usuario' %>:</strong> <%= c.comentario %>
                                                    </div>
                                                <% }) %>
                                            <% } %>
                                        </div>
                                        
                                        <!-- Input Comentar -->
                                        <% if (locals.user) { %>
                                            <div class="input-group input-group-sm position-relative">
                                                <button class="btn btn-link p-1 text-decoration-none" type="button" onclick="toggleEmojiPicker('<%= post.id %>')">
                                                    <i class="far fa-smile fs-5"></i>
                                                </button>
                                                <input type="text" class="form-control input-comentario-<%= post.id %>" placeholder="Escribe un comentario...">
                                                <button class="btn btn-outline-primary" type="button" onclick="enviarComentario('<%= post.id %>')">
                                                    <i class="fas fa-paper-plane"></i>
                                                </button>
                                            </div>
                                            <div id="emoji-container-<%= post.id %>" class="d-none position-absolute" style="bottom: 45px; left: 0; z-index: 1000; border-radius: 10px; overflow: hidden; box-shadow: 0 5px 15px rgba(0,0,0,0.2);"></div>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="col-12 text-center py-4 text-muted">
                            <p>Aún no has compartido fotos en tu muro.</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Botón Flotante de Ayuda -->
<button type="button" class="btn btn-primary rounded-circle shadow-lg" 
        style="position: fixed; bottom: 20px; right: 20px; width: 60px; height: 60px; z-index: 1000;"
        data-bs-toggle="modal" data-bs-target="#modalManual">
    <i class="fas fa-question fa-lg"></i>
</button>

<!-- Modal del Manual -->
<div class="modal fade" id="modalManual" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0" style="border-radius: 20px;">
            <div class="modal-header bg-dark text-white border-0" style="border-radius: 20px 20px 0 0;">
                <h5 class="modal-title fw-bold"><i class="fas fa-book-reader me-2 text-warning"></i> Pasos para tu Inscripción</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="d-flex mb-3">
                    <div class="me-3"><span class="badge bg-primary rounded-circle">1</span></div>
                    <div><strong>Selecciona tus categorías:</strong> Elige las modalidades donde competirás. Recuerda los bloqueos por afinidad.</div>
                </div>
                <div class="d-flex mb-3">
                    <div class="me-3"><span class="badge bg-primary rounded-circle">2</span></div>
                    <div><strong>Realiza el Pago:</strong> Transfiere a la cuenta de la FDFF. Si estás en fecha de oferta, el sistema calculará el descuento automáticamente.</div>
                </div>
                <div class="d-flex mb-3">
                    <div class="me-3"><span class="badge bg-primary rounded-circle">3</span></div>
                    <div><strong>Sube el Comprobante:</strong> Hazle una foto clara a tu recibo y súbela desde tu perfil.</div>
                </div>
                <div class="d-flex mb-3">
                    <div class="me-3"><span class="badge bg-primary rounded-circle">4</span></div>
                    <div><strong>Validación y Ticket:</strong> El Staff revisará tu pago. Una vez aprobado, se activará tu <strong>Ticket QR</strong> para el pesaje.</div>
                </div>
                <div class="alert alert-info small mb-0">
                    <i class="fas fa-info-circle"></i> Si tu pago es rechazado, verás el motivo en la sección "Observaciones" de tu perfil.
                </div>
            </div>
        </div>
    </div>
</div>

<script src="/js/supabase.js"></script>
<script>
    const userId = "<%= user.id %>";
    const idEventoActual = "<%= locals.evento?.id || '' %>";
    window._supabase = supabase.createClient("<%= SUPABASE_URL %>", "<%= SUPABASE_ANON_KEY %>");

    async function actualizarFotoCarnet() {
        const input = document.getElementById('inputFotoCarnet');
        if (input.files.length === 0) return alert("Selecciona una foto primero.");

        const file = input.files[0];
        const btn = document.getElementById('btnSubirFoto');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Procesando...';

        try {
            // 1. Compresión y redimensionamiento (400x500px)
            const optimizedBlob = await optimizarParaCarnet(file, 400, 500);

            // 2. Enviamos el archivo optimizado al servidor (Backend Proxy)
            const formData = new FormData();
            formData.append('foto', optimizedBlob, 'perfil.jpg');

            const response = await fetch('/atletas/perfil/foto-oficial', {
                method: 'POST',
                body: formData
            });

            const result = await response.json();

            if (!result.estado) {
                throw new Error(result.mensaje);
            }

            alert("¡Foto de Carnet Oficial actualizada con éxito!");
            location.reload();
        } catch (err) {
            alert("Error: " + err.message);
        } finally {
            btn.disabled = false;
            btn.innerHTML = 'SUBIR';
        }
    }

    async function toggleLike(postId) {
        try {
            const res = await fetch('/atletas/perfil/like', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ publicacion_id: postId })
            });
            const data = await res.json();
            if (data.estado) {
                const icon = document.querySelector(`[onclick="toggleLike('${postId}')"] i`);
                const countSpan = document.getElementById(`like-count-${postId}`);
                let count = parseInt(countSpan.innerText);
                
                icon.classList.toggle('fas');
                icon.classList.toggle('far');
                countSpan.innerText = `${data.operacion === 'dar' ? count + 1 : count - 1} me gusta`;
            }
        } catch (e) { console.error("Error al dar like:", e); }
    }

    function toggleEmojiPicker(postId) {
        const container = document.getElementById(`emoji-container-${postId}`);
        if (container.innerHTML === "") {
            const picker = document.createElement('emoji-picker');
            picker.classList.add('light');
            picker.style.width = "100%";
            picker.style.maxWidth = "300px";
            picker.style.height = "350px";
            picker.addEventListener('emoji-click', event => {
                const input = document.querySelector(`.input-comentario-${postId}`);
                input.value += event.detail.unicode;
                container.classList.add('d-none');
            });
            container.appendChild(picker);
        }
        container.classList.toggle('d-none');
    }

    function optimizarParaCarnet(file, maxWidth, maxHeight) {
        return new Promise((resolve) => {
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = (e) => {
                const img = new Image();
                img.src = e.target.result;
                img.onload = () => {
                    const canvas = document.createElement('canvas');
                    canvas.width = maxWidth;
                    canvas.height = maxHeight;
                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(img, 0, 0, maxWidth, maxHeight);
                    canvas.toBlob((blob) => resolve(blob), 'image/jpeg', 0.8);
                };
            };
        });
    }

    async function modificarTeamAtleta() {
        const prepId = document.getElementById('selectPrepPerfil').value;
        try {
            const res = await fetch('/atletas/perfil/actualizar-team', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ preparador_id: prepId })
            });
            const data = await res.json();
            if (data.estado) {
                alert("✅ " + data.mensaje);
                window.location.reload();
            } else {
                alert("❌ Error: " + data.mensaje);
            }
        } catch (e) {
            alert("Error de red al actualizar el team.");
        }
    }

    async function subirPagoDiferido(inscripcionId) {
        const fileInput = document.getElementById('inputRetomaPago');
        if (fileInput.files.length === 0) return alert("Por favor, selecciona la imagen de tu recibo.");

        const file = fileInput.files[0];
        const path = `comprobantes/${inscripcionId}_${Date.now()}.jpg`;

        try {
            // 1. Subir al Storage (Bucket: comprobantes_atletas)
            const { data: uploadData, error: uploadError } = await _supabase.storage
                .from('comprobantes_atletas')
                .upload(path, file);

            if (uploadError) throw uploadError;

            // 2. Obtener URL y actualizar registros existentes en la tabla competidores
            const { data: { publicUrl } } = _supabase.storage.from('comprobantes_atletas').getPublicUrl(path);

            const { error: dbError } = await _supabase
                .from('competidores')
                .update({ 
                    url_comprobante_pago: publicUrl, 
                    fecha_subida_pago: new Date().toISOString() 
                })
                .eq('atleta_id', userId)
                .eq('id_evento', idEventoActual);

            if (dbError) throw dbError;

            alert("✅ Comprobante enviado con éxito. El staff lo revisará pronto.");
            location.reload();
        } catch (err) {
            console.error("Error en subida diferida:", err.message);
            alert("Error al procesar el pago: " + err.message);
        }
    }

    async function subirMusica(eventoId) {
        const fileInput = document.getElementById('inputMusica');
        if (!fileInput || fileInput.files.length === 0) return alert('Selecciona un archivo de audio primero.');

        const file = fileInput.files[0];
        if (file.size > 20 * 1024 * 1024) return alert('El archivo no puede superar 20MB.');

        const btn = document.getElementById('btnSubirMusica');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Subiendo...';

        const formData = new FormData();
        formData.append('musica', file);
        formData.append('id_evento', eventoId);

        try {
            const resp = await fetch('/atletas/perfil/subir-musica', { method: 'POST', body: formData });
            const result = await resp.json();
            if (!result.estado) throw new Error(result.mensaje);
            alert(result.mensaje);
            location.reload();
        } catch (err) {
            alert('Error: ' + err.message);
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-upload me-1"></i> SUBIR';
        }
    }

    async function enviarComentario(postId) {
        const input = document.querySelector(`.input-comentario-${postId}`);
        const comentario = input.value;
        if (!comentario) return;

        try {
            const res = await fetch('/atletas/perfil/comentar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ publicacion_id: postId, comentario })
            });
            const data = await res.json();
            if (data.estado) window.location.reload();
        } catch (e) {
            alert("Error al enviar el comentario.");
        }
    }
</script>
