<%- include("template/cabecera", {tituloWeb: "Nueva Membresía"}) %>
<div class="container ml-auto mr-auto caja pb-5">
    <h1 id="titulo" class="mx-4 my-4">Nuevo Miembro</h1>
        
    <div class="container border border-primary border-3 p-4">
        <!-- El action apunta a la ruta POST que configuramos en router/Atletas.js -->
        <form id="fomMembresia" action="/atletas/crear" method="POST" class="row g-3 needs-validation was-validated">

            <h6 class="position-relative mt-5 opacity-25">Del Atleta</h6>
            
            <div class="col-md-3 py-0 pt-0 m-0">
                <label for="idfdff" class="form-label">ID-FDFF</label>
                <input type="number" class="form-control" id="idfdff" name="idfdff" autocomplete="off" required>
                <div class="invalid-feedback">ID de la Federación (FDFF) requerido.</div>
            </div>

            <div class="col-md-3 py-0 pt-0 m-0 invisible">
                    <!--   <label for="validationTooltip05" class="form-label">Fecha de Inscripcion</label>
                      <input class="form-control" name="invi" id="validationTooltip05">
                      <div class="invalid-tooltip">
                        Fecha de Hoy...
                      </div> -->
            </div>

            <div class="col-md-3 py-0 pt-0 m-0 invisible">
                      <!--   <label for="validationTooltip05" class="form-label">Pasaporte</label>
                        <input type="text" class="form-control" name="invi" id="validationTooltip05" required="">
                        <div class="invalid-tooltip">
                            Pasaporte
                        </div> -->
            </div>

            <div class="col-md-3 py-0 pt-0 m-0">
                <label for="fecha_inscripcion" class="form-label">Fecha de Inscripción</label>
                <input type="date" class="form-control" name="fecha_inscripcion" id="fecha_inscripcion" value="<%= new Date().toISOString().split('T')[0] %>" required>
            </div>

            <div class="col-md-6 pt-0 mt-4">
                <label for="nombre" class="form-label">Nombre(s) y Apellido(s)</label>
                <input type="text" class="form-control" name="nombre" id="nombre" autocomplete="name" required>
                <div class="invalid-feedback">Nombre obligatorio según documento.</div>
            </div>

            <div class="col-md-3 py-0 pt-0 mt-4">
                <label for="cedula" class="form-label">Cédula</label>
                <input type="number" class="form-control" name="cedula" id="cedula" autocomplete="off" required>
            </div>

            <div class="col-md-3 py-0 pt-0 mt-4">
                <label for="pasaporte" class="form-label">Pasaporte</label>
                <input type="text" class="form-control" name="pasaporte" id="pasaporte" autocomplete="off" required>
            </div>

            <div class="col-md-4 py-0 pt-0 my-4">
                <label for="nacionalidad" class="form-label">Nacionalidad</label>     
                <input type="text" value="Dominicana" class="form-control" name="nacionalidad" id="nacionalidad" required>
            </div>

            <div class="col-md-3 py-0 pt-0 my-4">
                <label for="fecha_nacimiento" class="form-label">Fecha de Nacimiento</label>
                <input type="date" class="form-control" name="fecha_nacimiento" id="fecha_nacimiento" required>
            </div>

             <div class="col-md-2 py-0 pt-0 my-4">
                <label for="sexo" class="form-label">Sexo</label>
                <select class="form-control" name="sexo" id="sexo" required>
                    <option value="" selected disabled>Elija...</option>
                    <option value="F">F</option>
                    <option value="M">M</option>
                </select>
            </div>

            <div class="col-md-3 py-0 pt-0 my-4">
                <label for="ocupacion" class="form-label">Ocupación</label>
                <input type="text" class="form-control" name="ocupacion" id="ocupacion" required>
            </div>

            <h6 class="position-relative mt-5 opacity-25">De la Residencia</h6>
            
            <div class="col-md-6 py-0 pt-0 m-0">
                <label for="calle" class="form-label">Calle y Numero de Residencia</label>
                <input type="text" class="form-control" name="calle" id="calle" required>
            </div>

            <div class="col-md-3 py-0 pt-0 m-0">
                <label for="sector" class="form-label">Sector/Barrio</label>
                <input type="text" class="form-control" name="sector"  id="sector" required>
            </div>

            <div class="col-md-3 py-0 pt-0 m-0">
                <label for="municipio" class="form-label">Municipio/Distrito</label>
                <input type="text" class="form-control" name="municipio" id="municipio" required>
            </div>

            <div class="col-md-4 py-0 pt-0 my-4">
                <label for="provincia" class="form-label">Provincia/Estado</label>
                <input type="text" class="form-control" name="provincia" id="provincia" required>
            </div>

            <div class="col-md-4 py-0 pt-0 my-4">
                <label for="pais" class="form-label">País</label>
                <input type="text" class="form-control" name="pais" value="Republica Dominicana" id="pais" required>
            </div>

            <div class="col-md-3 py-0 pt-0 my-4">
                <label for="postal" class="form-label">Codigo Postal</label>
                <input type="number" class="form-control" name="postal" id="postal" required>
            </div>

            <h6 class="position-relative mt-5 opacity-25">Credenciales y Contactos</h6>

            <div class="col-md-4 py-0 pt-0 mb-4">
                <label for="email" class="form-label fw-bold text-primary">Email (Usuario)</label>
                <input type="email" class="form-control border-primary" name="email" id="email" autocomplete="email" required>
            </div>

            <div class="col-md-4 py-0 pt-0 mb-4">
                <label for="password" class="form-label fw-bold text-primary">Contraseña Temporal</label>
                <input type="text" class="form-control border-primary" name="password" id="password" value="FDFF2024" required>
                <small class="text-muted">El atleta podrá cambiarla luego.</small>
            </div>

             <div class="col-md-3 py-0 pt-0 mb-4">
                <label for="celular" class="form-label">Celular</label>
                <input type="tel" class="form-control" name="celular" id="celular" required>
            </div>

            <div class="col-md-3 py-0 pt-0  mb-4">
                <label for="telfijo" class="form-label">Telefono Residencial</label>
                <input type="tel" class="form-control" name="telfijo" id="telfijo" required>
            </div>

             <div class="col-md-3 py-0 pt-0  mb-4">
                <label for="instagram" class="form-label">Instagram</label>
                <input type="text" class="form-control" name="instagram" id="instagram" required>
            </div>

            <h6 class="position-relative mt-5 opacity-25">Del Deporte</h6>
                    <div class="col-md-3 py-0 pt-0  mb-4">
                        <label for="categoria" class="form-label">Categoria</label>
                        <input type="text" class="form-control" name="categoria" id="categoria" required>
                    </div>

            <div class="col-md-3 py-0 pt-0  mb-4">
                        <label for="estatura" class="form-label">Estatura (cm)</label>
                        <input type="number" step="0.01" min="0" class="form-control" name="estatura" id="estatura" required>
                    </div>

           <div class="col-md-3 py-0 pt-0  mb-4">
                        <label for="peso" class="form-label">Peso (Kg)</label>
                        <input type="number" step="0.01" min="0" class="form-control" name="peso" id="peso" required>
                    </div>

            <div class="col-md-3 py-0 pt-0  mb-4">
                        <label for="gimnasio" class="form-label">Gimnasio</label>
                        <input type="text" class="form-control" name="gimnasio" id="gimnasio" required>
                    </div>

            <div class="col-md-3 py-0 pt-0  mb-4">
                        <label for="preparador" class="form-label">Preparador</label>
                        <input type="text" class="form-control" name="preparador" id="preparador" required>
                    </div>

            <div class="col-md-3 py-0 pt-0  mb-4">
                        <label for="celular_preparador" class="form-label">Celular del Preparador</label>
                        <input type="tel" class="form-control" name="celular_preparador" id="celular_preparador" required>
                    </div>


            <div class="col-md-3 py-0 pt-0  mb-4">
                        <label for="email_preparador" class="form-label">Email del Preparador</label>
                        <input type="email" class="form-control" name="email_preparador" id="email_preparador" required>
                    </div>

            <button 
                type="submit"
                class="btn btn-primary btn-lg my-5 col-4 shadow-sm fw-bold" 
                id="btnImprimirGuardar"
            >
                <i class="fas fa-print me-2"></i> IMPRIMIR Y GUARDAR
            </button> 

        </form>

        <H4 class="firma">
            Firma de Atleta_______________________________________<span class="fs-6">Con esta firma certifico que no tengo antecedentes penales ni asuntos pendientes con la justicia</span>
        </H4>

    </div>
</div>

<script>
    document.getElementById('fomMembresia').addEventListener('submit', async function(e) {
        e.preventDefault(); // Evitamos la redirección automática

        // 1. Confirmación de seguridad para proceder
        const confirmar = confirm("¿Desea imprimir la ficha y registrar este atleta en el sistema?");
        if (!confirmar) return;

        // 2. Disparar cuadro de impresión del sistema
        window.print();

        // 3. Proceder al guardado mediante AJAX (Fetch)
        // Usamos FormData para que sea compatible con el middleware Multer (upload.none)
        const formData = new FormData(this);
        const btn = document.getElementById('btnImprimirGuardar');
        
        try {
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> GUARDANDO EN SUPABASE...';

            const response = await fetch('/atletas/crear', {
                method: 'POST',
                body: formData
            });

            const result = await response.json();

            if (result.estado) {
                alert("✅ Atleta registrado correctamente.");
                this.reset(); // Limpia los datos solo si fue exitoso
                this.classList.remove('was-validated');
            } else {
                alert("❌ ERROR DE SUPABASE: " + result.mensaje);
                // NO se limpia el formulario para que el usuario corrija
            }
        } catch (error) {
            alert("⚠️ Error de conexión: No se pudo contactar con el servidor.");
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-print me-2"></i> IMPRIMIR Y GUARDAR';
        }
    });
</script>
<%- include("template/footer") %>
