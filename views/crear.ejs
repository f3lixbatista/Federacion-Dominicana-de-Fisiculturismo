<%- include("template/cabecera", {tituloWeb: "Nueva Membresía"}) %>

<div class="container ml-auto mr-auto caja pb-5">
    <h1 id="titulo" class="mx-4 my-4">Nuevo Miembro</h1>
        
    <div class="container border border-primary border-3 p-4">
        <!-- El action apunta a la ruta POST que configuramos en router/Atletas.js -->
        <form id="fomMembresia" action="/atletas/crear" method="POST" class="row g-3 needs-validation was-validated">

            <h6 class="position-relative mt-4 opacity-50">Datos del Atleta</h6>
            
            <div class="col-md-3">
                <label class="form-label">ID-FDFF</label>
                <!-- CAMBIO: name="idfdff" (minúsculas) -->
                <input type="number" class="form-control" name="idfdff" required>
                <div class="invalid-tooltip">ID de la Federación (FDFF)</div>
            </div>

            <div class="col-md-3">
                <label class="form-label">Fecha de Inscripción</label>
                <!-- CAMBIO: type="date" y nombre minúsculas. Usamos el helper de JS para la fecha de hoy -->
                <input type="date" class="form-control" name="fecha_inscripcion" value="<%= new Date().toISOString().split('T')[0] %>" required>
            </div>

            <div class="col-md-6">
                <label class="form-label">Nombre(s) y Apellido(s)</label>
                <input type="text" class="form-control" name="nombre" placeholder="Según documento" required>
            </div>

            <div class="col-md-3">
                <label class="form-label">Cédula</label>
                <input type="number" class="form-control" name="cedula" required>
            </div>

            <div class="col-md-3">
                <label class="form-label">Pasaporte</label>
                <input type="text" class="form-control" name="pasaporte">
            </div>

            <div class="col-md-3">
                <label class="form-label">Nacionalidad</label>
                <input type="text" value="Dominicana" class="form-control" name="nacionalidad" required>
            </div>

            <div class="col-md-3">
                <label class="form-label">Fecha de Nacimiento</label>
                <input type="date" class="form-control" name="nacimiento" required>
            </div>

            <div class="col-md-3">
                <label class="form-label">Edad</label>
                <input type="number" class="form-control" name="edad" required>
            </div>

            <div class="col-md-2">
                <label class="form-label">Sexo</label>
                <select class="form-control" name="sexo" required>
                    <option value="" selected disabled>Elija...</option>
                    <option value="F">Femenino (F)</option>
                    <option value="M">Masculino (M)</option>
                </select>
            </div>

            <div class="col-md-5">
                <label class="form-label">Ocupación</label>
                <input type="text" class="form-control" name="ocupacion">
            </div>

            <h6 class="position-relative mt-5 opacity-50">De la Residencia</h6>
            
            <div class="col-md-6">
                <label class="form-label">Calle y Número</label>
                <input type="text" class="form-control" name="calle" required>
            </div>

            <div class="col-md-3">
                <label class="form-label">Sector/Barrio</label>
                <input type="text" class="form-control" name="sector" required>
            </div>

            <div class="col-md-3">
                <label class="form-label">Ciudad</label>
                <input type="text" class="form-control" name="ciudad" required>
            </div>

            <div class="col-md-3">
                <label class="form-label">Municipio</label>
                <input type="text" class="form-control" name="municipio" required>
            </div>

            <div class="col-md-4">
                <label class="form-label">Provincia</label>
                <input type="text" class="form-control" name="provincia" required>
            </div>

            <div class="col-md-4">
                <label class="form-label">País</label>
                <input type="text" class="form-control" name="pais" value="Republica Dominicana" required>
            </div>

            <div class="col-md-4">
                <label class="form-label">Código Postal</label>
                <input type="number" class="form-control" name="postal">
            </div>

            <div class="col-md-4">
                <label class="form-label">Celular</label>
                <input type="tel" class="form-control" name="celular">
            </div>

            <div class="col-md-4">
                <label class="form-label">Correo Electronico</label>
                <input type="email" class="form-control" name="email">
            </div>

            <div class="col-md-4">
                <label class="form-label">Instagram</label>
                <input type="text" class="form-control" name="instagram">
            </div>

            <div class="col-md-4">
                <label class="form-label">Categoria</label>
                <input type="text" class="form-control" name="categoria" id="validationTooltip05" required>
            </div>

            <div class="col-md-4">
                <label class="form-label">Estatura en Centimetros</label>
                <input type="number" step="0.01" min="0" class="form-control" name="estatura" id="validationTooltip05" required>
            </div>

            <div class="col-md-4">
                <label class="form-label">Peso en Kilos</label>
                <input type="number" step="0.01" min="0" class="form-control" name="peso" id="validationTooltip05" required>
            </div>

            <div class="col-md-4">
                <label class="form-label">Gimnasio</label>
                <input type="text" class="form-control" name="gimnasio" id="validationTooltip05" required>
            </div>

            <div class="col-md-4">
                <label class="form-label">Preparador</label>
                <input type="text" class="form-control" name="preparador" id="validationTooltip05" required>
            </div>

            <div class="col-md-4">
                <label class="form-label">Celular del Preparador</label>
                <input type="tel" class="form-control" name="celular_preparador">
            </div>

            <div class="col-md-4">
                <label class="form-label">Email del Preparador</label>
                <input type="email" class="form-control" name="email_preparador">
            </div>


            <div class="col-12 mt-5">
                <button class="btn btn-primary btn-lg w-100" type="submit">Registrar Nueva Membresía</button>
            </div>
        </form>
    </div>
</div>

<%- include("template/footer") %>
