<%- include("template/cabecera", {tituloWeb: "Nueva Membresía"}) %>
<div class="container ml-auto mr-auto caja pb-5">
    <h1 id="titulo" class="mx-4 my-4">Nuevo Miembro</h1>
        
    <div class="container border border-primary border-3 p-4">
        <!-- El action apunta a la ruta POST que configuramos en router/Atletas.js -->
        <form id="fomMembresia" action="/atletas/crear" method="POST" class="row g-3 needs-validation was-validated">

            <h6 class="position-relative mt-5 opacity-25">Del Atleta</h6>
            
            <div class="col-md-3 py-0 pt-0 m-0">
                <label for="validationTooltip05" class="form-label">ID-FDFF</label>
                <!-- CAMBIO: name="idfdff" (minúsculas) -->
                <input type="number" class="form-control" id="validationTooltip05" name="idfdff" required="true">
                <div class="invalid-tooltip">ID de la Federación (FDFF)</div>
            </div>

            <div class="col-md-3 py-0 pt-0 m-0 invisible">
                    <!--   <label for="validationTooltip05" class="form-label">Fecha de Inscripcion</label>
                      <input class="form-control" name="invi" id="validationTooltip05">
                      <div class="invalid-tooltip">
                        Fecha de Hoy...
                      </div> -->
            </div>

            <div class="col-md-3 py-0 pt-0 m-0 invisible">
                      <!--   <label for="validationTooltip05" class="form-label">Pasaporte</label>
                        <input type="text" class="form-control" name="invi" id="validationTooltip05" required="">
                        <div class="invalid-tooltip">
                            Pasaporte
                        </div> -->
            </div>

            <div class="col-md-3 py-0 pt-0 m-0">
                <label for="validationTooltip05" class="form-label">Fecha de Inscripción</label>
                <!-- CAMBIO: type="date" y nombre minúsculas. Usamos el helper de JS para la fecha de hoy -->
                <input type="date" class="form-control" name="fecha_inscripcion" id="validationTooltip05" value="<%= new Date().toISOString().split('T')[0] %>" required>
                <div class="invalid-tooltip">Fecha de Hoy</div>
            </div>

            <div class="col-md-6 pt-0 mt-4">
                <label for="validationTooltip03" class="form-label">Nombre(s) y Apellido(s)</label>
                <input type="text" class="form-control" name="nombre" id="validationTooltip03" required="">
            <div class="invalid-tooltip">Segun Documento de Identidad</div>
            </div>

            <div class="col-md-3 py-0 pt-0 mt-4">
                <label for="validationTooltip05" class="form-label">Cédula</label>
                <input type="number" class="form-control" name="cedula" id="validationTooltip05" required="true">
            </div>

            <div class="col-md-3 py-0 pt-0 mt-4">
                <label for="validationTooltip05" class="form-label">Pasaporte</label>
                <input type="text" class="form-control" name="pasaporte" id="validationTooltip05" required="">
            </div>

            <div class="col-md-4 py-0 pt-0 my-4">
                <label for="validationTooltip05" class="form-label">Nacionalidad</label>     
                <input type="text" value="Dominicana" class="form-control" name="nacionalidad" id="validationTooltip05" required="true">
                <div class="invalid-tooltip">
                          Nacionalidad
                </div>
            </div>

            <div class="col-md-3 py-0 pt-0 my-4">
                <label for="validationTooltip05" class="form-label">Fecha de Nacimiento</label>
                <input type="date" class="form-control" name="nacimiento" id="validationTooltip05" required="true">
                <div class="invalid-tooltip">
                    Fecha de Nacimiento
                </div>
            </div>
  <!--
            <div class="col-md-3">
                <label class="form-label">Edad</label>
                <input type="number" class="form-control" name="edad" required>
            </div>
-->
             <div class="col-md-1 py-0 pt-0 my-4">
                <label for="validationTooltip05" class="form-label">Sexo</label>
                <select class="form-control" name="sexo" required="true">
                    <option value="" selected disabled>Elija...</option>
                    <option value="F">F</option>
                    <option value="M">M</option>
                </select>
                <div class="invalid-tooltip">
                    Sexo
                </div> 
            </div>

            <div class="col-md-4 py-0 pt-0 my-4">
                <label for="validationTooltip05" class="form-label">Ocupación</label>
                <input type="text" class="form-control" name="ocupacion" id="validationTooltip05" required="true">
            </div>

            <h6 class="position-relative mt-5 opacity-25">De la Residencia</h6>
            
            <div class="col-md-6 py-0 pt-0 m-0">
                <label for="validationTooltip05" class="form-label">Calle y Numero de Residencia</label>
                <input type="text" class="form-control" name="calle" id="validationTooltip05" required="true">
                <div class="invalid-tooltip">
                    Nombre de la Calle y Numero de la Casa o Apartamento
                </div>
            </div>

            <div class="col-md-3 py-0 pt-0 m-0">
                <label for="validationTooltip05" class="form-label">Sector/Barrio</label>
                <input type="text" class="form-control" name="sector"  id="validationTooltip05" required="true">
            </div>

          <!--   <div class="col-md-3">
                <label class="form-label">Ciudad</label>
                <input type="text" class="form-control" name="ciudad" required>
            </div> -->

            <div class="col-md-3 py-0 pt-0 m-0">
                <label for="validationTooltip05" class="form-label">Municipio/Distrito</label>
                <input type="text" class="form-control" name="municipio"  id="validationTooltip05" required="true">
                <div class="invalid-tooltip">
                    Municipio o Distrito de Residencia
                </div>
            </div>

            <div class="col-md-4 py-0 pt-0 my-4">
                <label for="validationTooltip05" class="form-label">Provincia/Estado</label>
                <input type="text" class="form-control" name="provincia" id="validationTooltip05" required="true">
                <div class="invalid-tooltip">
                    Provincia o Estado de Residencia
                </div>
            </div>

            <div class="col-md-4 py-0 pt-0 my-4">
                <label for="validationTooltip05" class="form-label">País</label>
                <input type="text" class="form-control" name="pais" value="Republica Dominicana" id="validationTooltip05" required="true">
                <div class="invalid-tooltip">
                    Pais de Residencia
                </div>
            </div>

            <<div class="col-md-3 py-0 pt-0 my-4">
                <label for="validationTooltip05" class="form-label">Codigo Postal</label>
                <input type="number" class="form-control" name="postal" id="validationTooltip05" required="true">
                <div class="invalid-tooltip">
                    Codigo Postal
                </div>
            </div>

            <h6 class="position-relative mt-5 opacity-25">Contactos</h6>

             <div class="col-md-3 py-0 pt-0 mb-4">
                <label for="validationTooltip05" class="form-label">Celular</label>
                <input type="tel" class="form-control" name="celular" id="validationTooltip05" required="true">
                  <div class="invalid-tooltip">
                            Celular
                        </div>
            </div>

            <div class="col-md-3 py-0 pt-0  mb-4">
                        <label for="validationTooltip05" class="form-label">Telefono Residencial</label>
                        <input type="tel" class="form-control" name="telfijo" id="validationTooltip05" required="true">
                        <div class="invalid-tooltip">
                            Telefono Alterno
                        </div>
                    </div>

            <div class="col-md-3 py-0 pt-0  mb-4">
                        <label for="validationTooltip05" class="form-label">Email</label>
                        <input type="email" class="form-control" name="email" id="validationTooltip05" required="true">
                        <div class="invalid-tooltip">
                            Correo Electronico
                        </div>
                    </div>

             <div class="col-md-3 py-0 pt-0  mb-4">
                        <label for="validationTooltip05" class="form-label">Instagram</label>
                        <input type="text" class="form-control" name="instagram" id="validationTooltip05" required="true">
                        <div class="invalid-tooltip">
                            Usuario de Instagram
                        </div>
                    </div>

            <h6 class="position-relative mt-5 opacity-25">Del Deporte</h6>
                    <div class="col-md-3 py-0 pt-0  mb-4">
                        <label for="validationTooltip05" class="form-label">Categoria</label>
                        <input type="text" class="form-control" name="categoria" id="validationTooltip05" required="true">
                        <div class="invalid-tooltip">
                            Categoria
                        </div>
                    </div>

            <div class="col-md-3 py-0 pt-0  mb-4">
                        <label for="validationTooltip05" class="form-label">Estatura en Centimetros</label>
                        <input type="number" step="0.01" min="0" class="form-control" name="estatura" id="validationTooltip05" required="true">
                        <div class="invalid-tooltip">
                            Estatura en Centimetros
                        </div>
                    </div>

           <div class="col-md-3 py-0 pt-0  mb-4">
                        <label for="validationTooltip05" class="form-label">Peso en Kilos</label>
                        <input type="number" step="0.01" min="0" class="form-control" name="peso" id="validationTooltip05" required="true">
                        <div class="invalid-tooltip">
                            Peso en Kilos
                        </div>
                    </div>

            <div class="col-md-3 py-0 pt-0  mb-4">
                        <label for="validationTooltip05" class="form-label">Gimnasio</label>
                        <input type="text" class="form-control" name="gimnasio" id="validationTooltip05" required="true">
                        <div class="invalid-tooltip">
                            Gimnasio en que Practica
                        </div>
                    </div>

            <div class="col-md-3 py-0 pt-0  mb-4">
                        <label for="validationTooltip05" class="form-label">Preparador</label>
                        <input type="text" class="form-control" name="preparador" id="validationTooltip05" required="true">
                        <div class="invalid-tooltip">
                            Entrendor o Coach
                        </div>
                    </div>

            <div class="col-md-3 py-0 pt-0  mb-4">
                        <label for="validationTooltip05" class="form-label">Celular del Preparador</label>
                        <input type="tel" class="form-control" name="celular_preparador" id="validationTooltip05" required="true">
                        <div class="invalid-tooltip">
                            Cel/Whatsapp
                        </div>
                    </div>


            <div class="col-md-3 py-0 pt-0  mb-4">
                        <label for="validationTooltip05" class="form-label">Email del Preparador</label>
                        <input type="email" class="form-control" name="email_preparador" id="validationTooltip05" required="true">
                        <div class="invalid-tooltip">
                            Correo Electronico de su Preparador
                        </div>
                    </div>


           <!--  <div class="col-12 mt-5">
                <button class="btn btn-primary btn-lg w-100" type="submit">Registrar Nueva Membresía</button>
            </div> -->

            <button 
                type="submit"
                class="btn btn-danger btn-lg my-5 col-4" 
                id="print"
            >
                Agregar
            </button> 

        </form>

        <H4 class="firma">
            Firma de Atleta_______________________________________<span class="fs-6">Con esta firma certifico que no tengo antecedentes penales ni asuntos pendientes con la justicia</span>
        </H4>

    </div>
</div>

 <script>
       
        const printBtn = document.getElementById('print');
    
        printBtn.addEventListener('click', function() {
            print();
            
        })
    </script>

<%- include("template/footer") %>
