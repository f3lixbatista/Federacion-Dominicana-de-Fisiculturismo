<%- include("template/cabecera", {tituloWeb: "Sincronizando..."}) %>

<div class="container text-center my-5" style="min-height: 70vh;">
    <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
    <h2 class="mt-4 fw-bold">Sincronizando con el Servidor...</h2>
    <p class="text-muted">Estableciendo credenciales de acceso seguro.</p>
</div>

<script>
    (function() {
        // 1. Extraer el token del HASH (#) de la URL que recibiste
        const hash = window.location.hash.substring(1);
        const params = new URLSearchParams(hash);
        const accessToken = params.get('access_token');
        const expiresIn = params.get('expires_in');

        if (accessToken) {
            // 2. CREAR LA COOKIE (Usamos el nombre que el servidor ya reconoce)
            const nombreCookie = "sb-access-token";
            document.cookie = `${nombreCookie}=${accessToken}; path=/; SameSite=Lax; max-age=${expiresIn || 3600}`;

            console.log("✅ Cookie inyectada. Saltando al Dashboard...");

            // 3. RETARDO CRÍTICO: 1 segundo para que el navegador asiente la cookie
            // antes de que el servidor reciba la siguiente petición.
            setTimeout(() => {
                window.location.replace('/eventos'); 
            }, 1000);
        } else {
            console.error("No se detectó token en la URL.");
            window.location.href = '/login';
        }
    })();
</script>
<%- include("template/footer") %>
