<%- include("template/cabecera", {tituloWeb: "Finalizando Autenticación"}) %>

<div class="container text-center mt-5">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Cargando...</span>
    </div>
    <h2 class="mt-3">Procesando inicio de sesión...</h2>
    <p class="text-muted">Por favor, no cierres esta ventana.</p>
</div>

<!-- 1. Cargamos el archivo local (el mismo que usamos en login) -->
<script src="/js/supabase.js"></script>

<script>
    (function() {
        const supabaseUrl = "<%= process.env.SUPABASE_URL %>";
        const supabaseKey = "<%= process.env.SUPABASE_KEY %>";

        // Inicializamos el cliente localmente
        const _supabase = supabase.createClient(supabaseUrl, supabaseKey);

        // Esta función escucha cuando Supabase termina de validar el token de Google
        _supabase.auth.onAuthStateChange((event, session) => {
            if (event === 'SIGNED_IN' && session) {
                console.log("✅ Sesión iniciada con éxito");
                // Redirigimos al inicio de la aplicación
                window.location.href = '/'; 
            }
        });

        // Seguridad: Si en 8 segundos no ha redirigido, algo falló o el token expiró
        setTimeout(() => {
            if (window.location.pathname.includes('callback')) {
                alert("La sesión tardó demasiado en responder. Volviendo al login.");
                window.location.href = '/login';
            }
        }, 8000);
    })();
</script>

<%- include("template/footer") %>

