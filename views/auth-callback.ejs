<%- include("template/cabecera", {tituloWeb: "Autenticando..."}) %>

<div class="container text-center mt-5">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Cargando...</span>
    </div>
    <h2 class="mt-3">Finalizando inicio de sesión...</h2>
</div>

<script src="https://jsdelivr.net"></script>
<script>
    const supabaseUrl = "<%= process.env.SUPABASE_URL %>";
    const supabaseKey = "<%= process.env.SUPABASE_KEY %>";
    const supabase = supabasejs.createClient(supabaseUrl, supabaseKey);

    // Esta función detecta el cambio de sesión y redirige
    supabase.auth.onAuthStateChange((event, session) => {
        if (event === 'SIGNED_IN') {
            // Guardamos la sesión en el cliente y redirigimos al inicio
            window.location.href = '/'; 
        }
    });

    // Seguridad: Si después de 5 segundos no pasa nada, volver al login
    setTimeout(() => {
        window.location.href = '/login';
    }, 5000);
</script>

<%- include("template/footer") %>
