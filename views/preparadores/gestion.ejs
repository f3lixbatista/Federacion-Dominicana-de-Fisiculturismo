<%- include('../template/cabecera', { tituloWeb: 'Gestión de Coaches - FDFF' }) %>

<div class="container my-4">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h4 class="fw-bold mb-0"><i class="fas fa-user-tie text-primary me-2"></i> Coaches y Preparadores</h4>
            <small class="text-muted">Gestión de afiliación y estatus de coaches oficiales FDFF</small>
        </div>
        <div class="d-flex gap-2">
            <a href="/preparadores/ranking-teams" class="btn btn-outline-warning fw-bold">
                <i class="fas fa-trophy me-1"></i> Ranking Teams
            </a>
            <% if (locals.user && (user.role === 'admin' || user.role === 'ejecutivo')) { %>
                <a href="/preparadores/registrar" class="btn btn-primary fw-bold">
                    <i class="fas fa-plus-circle me-1"></i> Nuevo Coach
                </a>
            <% } %>
        </div>
    </div>

    <%
    const pendientes = preparadores.filter(p => p.estatus_afiliacion !== 'habilitado');
    const habilitados = preparadores.filter(p => p.estatus_afiliacion === 'habilitado');
    %>

    <% if (pendientes.length > 0) { %>
        <div class="alert alert-warning border-0 shadow-sm mb-4" style="border-radius:12px;">
            <i class="fas fa-clock me-2"></i>
            <strong><%= pendientes.length %> coach<%= pendientes.length > 1 ? 'es' : '' %> pendiente<%= pendientes.length > 1 ? 's' : '' %> de habilitación.</strong>
        </div>
    <% } %>

    <div class="card shadow-sm border-0" style="border-radius:15px;overflow:hidden;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="tablaPrep">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-3">Coach</th>
                        <th>Cédula</th>
                        <th>Gimnasio / Team</th>
                        <th>Contacto</th>
                        <th class="text-center">Estatus</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (preparadores.length === 0) { %>
                        <tr><td colspan="6" class="text-center py-5 text-muted">No hay coaches registrados.</td></tr>
                    <% } %>
                    <% preparadores.forEach(prep => {
                        const habilitado = prep.estatus_afiliacion === 'habilitado';
                        const suspendido = prep.estatus_afiliacion === 'suspendido';
                    %>
                        <tr class="<%= !habilitado ? 'table-warning bg-opacity-25' : '' %>">
                            <td class="ps-3">
                                <div class="fw-bold"><%= prep.nombre_completo %></div>
                                <small class="text-muted"><%= prep.email || '—' %></small>
                            </td>
                            <td class="small"><%= prep.cedula || '—' %></td>
                            <td>
                                <span class="badge bg-light text-dark border">
                                    <i class="fas fa-dumbbell me-1 text-secondary"></i><%= prep.gimnasio_labora || 'Independiente' %>
                                </span>
                            </td>
                            <td class="small"><%= prep.telefono || '—' %></td>
                            <td class="text-center">
                                <span class="badge px-3 py-1
                                    <%= habilitado ? 'bg-success' : suspendido ? 'bg-danger' : 'bg-warning text-dark' %>">
                                    <%= (prep.estatus_afiliacion || 'pendiente').toUpperCase() %>
                                </span>
                            </td>
                            <td class="text-center">
                                <% if (!habilitado) { %>
                                    <button class="btn btn-success btn-sm fw-bold"
                                            onclick="cambiarEstatus('<%= prep.id %>', 'habilitar', '<%= prep.nombre_completo %>')">
                                        <i class="fas fa-check me-1"></i> HABILITAR
                                    </button>
                                <% } else { %>
                                    <button class="btn btn-outline-danger btn-sm"
                                            onclick="cambiarEstatus('<%= prep.id %>', 'suspender', '<%= prep.nombre_completo %>')">
                                        <i class="fas fa-ban me-1"></i> Suspender
                                    </button>
                                <% } %>
                                <a href="/preparadores/panel?id=<%= prep.id %>" class="btn btn-outline-primary btn-sm ms-1" title="Ver panel">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <div class="text-muted small mt-3">
        <i class="fas fa-info-circle me-1"></i>
        Total: <strong><%= preparadores.length %></strong> coaches —
        Habilitados: <strong class="text-success"><%= habilitados.length %></strong> —
        Pendientes: <strong class="text-warning"><%= pendientes.length %></strong>
    </div>
</div>

<script>
async function cambiarEstatus(id, accion, nombre) {
    const verbo = accion === 'habilitar' ? 'habilitar' : 'suspender';
    if (!confirm(`¿Confirmas ${verbo} al coach ${nombre}?`)) return;

    try {
        const res = await fetch(`/preparadores/habilitar/${id}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ accion })
        });
        const data = await res.json();
        if (data.estado) {
            location.reload();
        } else {
            alert('Error: ' + data.mensaje);
        }
    } catch (err) {
        alert('Error de red: ' + err.message);
    }
}
</script>

<%- include('../template/footer') %>
