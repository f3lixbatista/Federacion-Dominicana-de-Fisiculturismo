<%- include('../template/cabecera', { tituloWeb: 'Ranking de Equipos - FDFF' }) %>

<div class="container my-4">

    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
        <div>
            <h4 class="fw-bold mb-0"><i class="fas fa-trophy text-warning me-2"></i> Ranking de Equipos</h4>
            <small class="text-muted">Clasificación acumulada de teams FDFF según sistema de puntos IFBB</small>
        </div>
        <a href="/preparadores" class="btn btn-outline-secondary btn-sm fw-bold">
            <i class="fas fa-arrow-left me-1"></i> Coaches
        </a>
    </div>

    <!-- Filtro de evento -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius:14px;">
        <div class="card-body p-3">
            <form action="/preparadores/ranking-teams" method="GET" class="row g-2 align-items-end">
                <div class="col-md-8">
                    <label class="form-label small fw-bold text-muted text-uppercase mb-1">Filtrar por evento</label>
                    <select name="evento_id" class="form-select">
                        <option value="">— Todos los eventos (acumulado) —</option>
                        <% eventos.forEach(ev => { %>
                            <option value="<%= ev.id %>" <%= ev.id === evento_id ? 'selected' : '' %>>
                                <%= ev.nombre %>
                                <%= ev.estado === 'cerrado' || ev.estado === 'finalizado' ? '✓' : '' %>
                            </option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-md-4">
                    <button class="btn btn-warning fw-bold w-100">
                        <i class="fas fa-filter me-1"></i> Aplicar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <% if (eventoSeleccionado) { %>
        <div class="alert alert-primary border-0 mb-3 fw-bold">
            <i class="fas fa-calendar-check me-2"></i> Mostrando resultados de: <strong><%= eventoSeleccionado.nombre %></strong>
        </div>
    <% } else if (eventos.length > 0) { %>
        <div class="alert alert-info border-0 mb-3">
            <i class="fas fa-layer-group me-2"></i> Puntos acumulados de <strong>todos los eventos</strong>.
        </div>
    <% } %>

    <!-- Sistema de puntos -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius:14px;background:#f8f9fa;">
        <div class="card-body p-3">
            <p class="small fw-bold text-uppercase text-muted mb-2"><i class="fas fa-info-circle me-1"></i> Sistema de puntos IFBB</p>
            <div class="d-flex flex-wrap gap-2">
                <span class="badge bg-warning text-dark">1° Lugar = 7 pts</span>
                <span class="badge bg-secondary">2° Lugar = 5 pts</span>
                <span class="badge" style="background:#cd7f32;">3° Lugar = 4 pts</span>
                <span class="badge bg-light text-dark border">4° = 3 pts</span>
                <span class="badge bg-light text-dark border">5° = 2 pts</span>
                <span class="badge bg-light text-dark border">6° = 1 pt</span>
                <span class="badge bg-danger">Campeón Absoluto = +11 pts</span>
            </div>
        </div>
    </div>

    <% if (ranking.length === 0) { %>
        <div class="text-center py-5 text-muted">
            <i class="fas fa-trophy fa-3x mb-3 d-block opacity-25"></i>
            <h5>No hay resultados oficializados todavía.</h5>
            <p class="small">Los puntos se calculan cuando la Mesa de Cómputo oficializa las categorías.</p>
        </div>
    <% } else { %>

        <!-- TOP 3 PODIO -->
        <% if (ranking.length >= 3) { %>
            <div class="row g-3 mb-4 justify-content-center">
                <!-- 2° -->
                <div class="col-4 col-md-3 order-1">
                    <div class="card border-0 shadow text-center p-3" style="border-radius:16px;background:linear-gradient(135deg,#9e9e9e,#757575);">
                        <div style="font-size:2rem;">🥈</div>
                        <div class="fw-bold text-white mt-1" style="font-size:.85rem;"><%= ranking[1].nombre %></div>
                        <div class="text-white opacity-75 small"><%= ranking[1].gimnasio %></div>
                        <div class="text-white fw-bold fs-4 mt-1"><%= ranking[1].puntos %> <small style="font-size:.6rem;">pts</small></div>
                    </div>
                </div>
                <!-- 1° -->
                <div class="col-4 col-md-3 order-0" style="margin-top:-12px;">
                    <div class="card border-0 shadow-lg text-center p-3" style="border-radius:16px;background:linear-gradient(135deg,#f9b233,#f57f17);">
                        <div style="font-size:2.5rem;">🏆</div>
                        <div class="fw-bold text-white mt-1" style="font-size:.9rem;"><%= ranking[0].nombre %></div>
                        <div class="text-white opacity-75 small"><%= ranking[0].gimnasio %></div>
                        <div class="text-white fw-bold fs-3 mt-1"><%= ranking[0].puntos %> <small style="font-size:.6rem;">pts</small></div>
                    </div>
                </div>
                <!-- 3° -->
                <div class="col-4 col-md-3 order-2">
                    <div class="card border-0 shadow text-center p-3" style="border-radius:16px;background:linear-gradient(135deg,#cd7f32,#a0522d);">
                        <div style="font-size:2rem;">🥉</div>
                        <div class="fw-bold text-white mt-1" style="font-size:.85rem;"><%= ranking[2].nombre %></div>
                        <div class="text-white opacity-75 small"><%= ranking[2].gimnasio %></div>
                        <div class="text-white fw-bold fs-4 mt-1"><%= ranking[2].puntos %> <small style="font-size:.6rem;">pts</small></div>
                    </div>
                </div>
            </div>
        <% } %>

        <!-- TABLA COMPLETA -->
        <div class="card border-0 shadow-sm" style="border-radius:15px;overflow:hidden;">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-3 text-center" style="width:60px;">#</th>
                            <th>Team / Coach</th>
                            <th>Gimnasio</th>
                            <th class="text-center">Participaciones</th>
                            <th class="text-center">Oros</th>
                            <th class="text-center">Podios</th>
                            <th class="text-end pe-3">Puntos</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% ranking.forEach((team, idx) => { %>
                            <tr class="<%= idx === 0 ? 'table-warning' : idx === 1 ? 'table-secondary' : '' %>">
                                <td class="ps-3 text-center">
                                    <% if (idx === 0) { %>
                                        <span class="fs-5">🥇</span>
                                    <% } else if (idx === 1) { %>
                                        <span class="fs-5">🥈</span>
                                    <% } else if (idx === 2) { %>
                                        <span class="fs-5">🥉</span>
                                    <% } else { %>
                                        <span class="fw-bold text-muted"><%= idx + 1 %></span>
                                    <% } %>
                                </td>
                                <td class="fw-bold"><%= team.nombre %></td>
                                <td class="small text-muted"><%= team.gimnasio %></td>
                                <td class="text-center"><%= team.participaciones %></td>
                                <td class="text-center text-warning fw-bold"><%= team.medallas_oro || 0 %></td>
                                <td class="text-center"><%= team.podios || 0 %></td>
                                <td class="text-end pe-3 fw-bold fs-5 text-primary"><%= team.puntos %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

    <% } %>
</div>

<%- include('../template/footer') %>
