<%- include('../template/cabecera', { tituloWeb: 'Equipos — FDFF' }) %>

<style>
.team-card {
    border-radius: 16px; overflow: hidden;
    transition: transform .2s, box-shadow .2s;
    text-decoration: none; color: inherit; display: block;
    background: #fff;
}
.team-card:hover { transform: translateY(-5px); box-shadow: 0 14px 36px rgba(0,0,0,.16) !important; }

.team-card-cover {
    height: 175px; background-size: cover; background-position: center top;
    background-color: #1a1a2e; position: relative;
}
.team-card-cover::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 35%, rgba(0,0,0,.72) 100%);
}
.team-card-cover-placeholder {
    position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
}
.team-coach-foto {
    width: 56px; height: 56px; object-fit: cover;
    border-radius: 50%; border: 3px solid #fff;
    position: absolute; bottom: -22px; left: 14px; z-index: 1;
    box-shadow: 0 3px 10px rgba(0,0,0,.35);
}
.team-coach-foto-ph {
    width: 56px; height: 56px; border-radius: 50%; border: 3px solid #fff;
    background: #343a40; position: absolute; bottom: -22px; left: 14px; z-index: 1;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.25rem; color: #adb5bd; box-shadow: 0 3px 10px rgba(0,0,0,.35);
}
.team-card-body { padding: 30px 14px 14px; }
.team-card-name { font-size: 1rem; font-weight: 700; line-height: 1.25; color: #212529; }
.team-card-gym  { font-size: .78rem; color: #6c757d; }
.team-card-badge { font-size: .7rem; }

/* dark mode */
@media (prefers-color-scheme: dark) {
    .team-card { background: #1e1e2e; }
    .team-card-name { color: #f1f1f1; }
}
</style>

<div class="container my-4">

    <!-- CABECERA -->
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
        <div>
            <h4 class="fw-bold mb-0">
                <i class="fas fa-users me-2 text-primary"></i>Equipos FDFF
            </h4>
            <small class="text-muted"><%= equipos.length %> equipo<%= equipos.length !== 1 ? 's' : '' %> registrado<%= equipos.length !== 1 ? 's' : '' %></small>
        </div>
        <input type="text" id="buscarTeam" class="form-control shadow-sm"
               style="max-width:260px;" placeholder="&#xf002; Buscar equipo..."
               oninput="filtrarEquipos(this.value)">
    </div>

    <!-- GRID -->
    <% if (equipos.length === 0) { %>
        <div class="text-center py-5 text-muted">
            <i class="fas fa-users fa-3x mb-3 d-block opacity-25"></i>
            <p class="mb-0">Aún no hay equipos registrados.</p>
            <small>Los coaches habilitados pueden crear su perfil de equipo desde su panel.</small>
        </div>
    <% } else { %>
    <div class="row row-cols-2 row-cols-sm-3 row-cols-lg-4 g-4" id="gridEquipos">
        <% equipos.forEach(eq => { %>
        <div class="col team-item">
            <a href="/preparadores/team/<%= eq.id %>" class="team-card shadow-sm">

                <!-- PORTADA -->
                <div class="team-card-cover"
                     <% if (eq.foto_portada_url) { %>style="background-image:url('<%= eq.foto_portada_url %>');"<% } %>>
                    <% if (!eq.foto_portada_url) { %>
                        <div class="team-card-cover-placeholder">
                            <i class="fas fa-dumbbell fa-2x text-white opacity-25"></i>
                        </div>
                    <% } %>
                    <!-- Foto circular del coach -->
                    <% if (eq.foto_perfil_url) { %>
                        <img src="<%= eq.foto_perfil_url %>" class="team-coach-foto" alt="<%= eq.nombre_completo %>">
                    <% } else { %>
                        <div class="team-coach-foto-ph"><i class="fas fa-user-tie"></i></div>
                    <% } %>
                </div>

                <!-- INFO -->
                <div class="team-card-body">
                    <p class="team-card-name mb-0 team-name">
                        <%= eq.displayName %>
                    </p>
                    <p class="team-card-gym mt-1 mb-2">
                        <i class="fas fa-dumbbell me-1 opacity-50"></i><%= eq.gimnasio_labora || 'Independiente' %>
                    </p>
                    <span class="badge bg-light text-dark border team-card-badge">
                        <i class="fas fa-user me-1 text-primary"></i><%= eq.totalAtletas %> atleta<%= eq.totalAtletas !== 1 ? 's' : '' %>
                    </span>
                </div>
            </a>
        </div>
        <% }) %>
    </div>

    <div id="sinResultados" style="display:none;" class="text-center py-5 text-muted">
        <i class="fas fa-search fa-2x mb-3 d-block opacity-25"></i>
        <p class="mb-0">No se encontró ningún equipo con ese nombre.</p>
    </div>
    <% } %>
</div>

<script>
function filtrarEquipos(q) {
    const termino = q.toLowerCase().trim();
    const items = document.querySelectorAll('.team-item');
    let visibles = 0;
    items.forEach(item => {
        const nombre = (item.querySelector('.team-name')?.textContent || '').toLowerCase();
        const visible = !termino || nombre.includes(termino);
        item.style.display = visible ? '' : 'none';
        if (visible) visibles++;
    });
    const sinRes = document.getElementById('sinResultados');
    if (sinRes) sinRes.style.display = visibles === 0 ? 'block' : 'none';
}
</script>

<%- include('../template/footer') %>
