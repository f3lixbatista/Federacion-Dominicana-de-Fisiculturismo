<%- include("../template/cabecera", {tituloWeb: "Gestión de Preparadores"}) %>

<div class="p-4 divGeneral">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold"><i class="fas fa-user-tie text-primary"></i> Panel de Preparadores / Coaches</h1>
        <a class="btn btn-success btn-lg fw-bold shadow-sm" href="/preparadores/registrar">
            <i class="fas fa-plus-circle me-1"></i> Registrar Nuevo Coach
        </a>
    </div>

    <div class="table-responsive bg-white p-3 rounded shadow-sm border">
        <table class="table table-striped table-hover align-middle border-dark" id="tablaPreparadores">
            <thead class="table-dark">
                <tr>
                    <th>ID FDFF</th>
                    <th>Nombre del Preparador</th>
                    <th>Cédula</th>
                    <th>Gimnasio / Team</th>
                    <th>Teléfono</th>
                    <th>Email</th>
                    <th>Estatus</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                <% if (arrayPreparadores.length > 0) { %>
                    <% arrayPreparadores.forEach(prep => { %>
                        <tr>
                            <td class="fw-bold text-primary"><%= prep.ID_Coach_FDFF %></td>
                            <td class="fw-bold"><%= prep.nombre_completo %></td>
                            <td><%= prep.cedula || '---' %></td>
                            <td><%= prep.gimnasio_labora || 'Independiente' %></td>
                            <td><%= prep.telefono || '---' %></td>
                            <td class="small"><%= prep.email %></td>
                            <td>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" 
                                           id="switch-<%= prep.id %>" 
                                           <%= prep.estatus_afiliacion === 'habilitado' ? 'checked' : '' %>
                                           onchange="toggleEstatusCoach('<%= prep.id %>')">
                                    <label class="form-check-label small fw-bold" for="switch-<%= prep.id %>"><%= prep.estatus_afiliacion.toUpperCase() %></label>
                                </div>
                            </td>
                            <td class="text-center">
                                <a href="/preparadores/editar/<%= prep.id %>" class="btn btn-warning btn-sm">
                                    <i class="fas fa-edit"></i>
                                </a>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="8" class="text-center py-4 text-muted">No hay preparadores registrados.</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<script src="/js/supabase.js"></script>
<script>
    const _supabase = supabase.createClient("<%= SUPABASE_URL %>", "<%= SUPABASE_ANON_KEY %>");

    $(document).ready(function () {
        $('#tablaPreparadores').DataTable({
            "dom": 'Bfrtip',
            "language": { "url": "https://cdn.datatables.net/plug-ins/1.10.19/i18n/Spanish.json" },
            "buttons": ['excel', 'pdf', 'print']
        });
    });

    async function toggleEstatusCoach(id) {
        const checkbox = document.getElementById(`switch-${id}`);
        const nuevoEstatus = checkbox.checked ? 'habilitado' : 'pendiente';
        const label = checkbox.nextElementSibling;
        
        const { error } = await _supabase
            .from('preparadores')
            .update({ estatus_afiliacion: nuevoEstatus })
            .eq('id', id);

        if (error) {
            alert("No se pudo actualizar el estatus: " + error.message);
            checkbox.checked = !checkbox.checked;
        } else {
            label.innerText = nuevoEstatus.toUpperCase();
        }
    }
</script>

<%- include("../template/footer") %>