<%- include('../template/cabecera', { tituloWeb: 'Afiliación de Preparadores - FDFF' }) %>

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0" style="border-radius: 20px;">
                <div class="card-header bg-dark text-white text-center py-4" style="border-radius: 20px 20px 0 0;">
                    <img src="/img/fdff3.jpg" style="width: 70px;" class="mb-2">
                    <h2 class="fw-bold mb-0">Registro de Preparadores / Coach</h2>
                    <p class="small mb-0 opacity-75">Federación Dominicana de Fisicoculturismo y Fitness</p>
                </div>
                <div class="card-body p-5">
                    <form action="/preparadores/solicitar" method="POST">
                        <div class="row g-3">
                            <div class="col-md-12">
                                <label class="form-label fw-bold">Nombre Completo</label>
                                <input type="text" name="nombre_completo" class="form-control" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Cédula o Pasaporte</label>
                                <input type="text" name="cedula" class="form-control" placeholder="001-0000000-0" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Correo Electrónico</label>
                                <input type="email" name="email" class="form-control" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Teléfono / WhatsApp</label>
                                <input type="text" name="telefono" class="form-control" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Gimnasio donde labora</label>
                                <input type="text" name="gimnasio" class="form-control" placeholder="Nombre del Gym o Team">
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-bold">Dirección Residencial</label>
                                <textarea name="direccion" class="form-control" rows="2"></textarea>
                            </div>
                        </div>

                        <div class="alert alert-info mt-4 small">
                            <i class="fas fa-info-circle"></i> Al registrarte, los atletas podrán seleccionarte como su preparador oficial en los eventos FDFF. Tu afiliación será validada por el comité ejecutivo.
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-sm mt-3 py-3">
                            ENVIAR SOLICITUD DE AFILIACIÓN
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../template/footer') %>
