<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.1/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.2/dist/js/bootstrap.bundle.min.js"></script>
    <script type="module" src="https://cdn.jsdelivr.net/npm/emoji-picker-element@1/index.js"></script>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.3.1/jquery.min.js"></script>

    <!-- Datatables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/v/bs4-4.1.1/dt-1.10.18/datatables.min.css">
    <script src="https://cdn.datatables.net/v/bs4-4.1.1/dt-1.10.18/datatables.min.js"></script>
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/1.6.2/css/buttons.dataTables.min.css">
    <script src="https://cdn.datatables.net/buttons/1.6.2/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/1.6.2/js/buttons.html5.min.js"></script>
    <script src="https://cdn.rawgit.com/bpampuch/pdfmake/0.1.53/build/pdfmake.min.js"></script>
    <script src="https://cdn.rawgit.com/bpampuch/pdfmake/0.1.53/build/vfs_fonts.js"></script>
    <script src="https://cdn.datatables.net/buttons/1.6.2/js/buttons.flash.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/1.6.2/js/buttons.print.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js"></script>
    <script src="https://unpkg.com/xlsx@0.16.9/dist/xlsx.full.min.js"></script>
    <script src="https://unpkg.com/file-saverjs@latest/FileSaver.min.js"></script>
    <script src="https://unpkg.com/tableexport@latest/dist/js/tableexport.min.js"></script>

    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <script src="/js/kiosko-logic.js"></script>

    <title>FDFF - <%= tituloWeb %></title>

    <style>
        /* ── LAYOUT SIDEBAR ─────────────────────────────────────────── */
        :root {
            --sb-width: 240px;
            --sb-collapsed-width: 64px;
            --topbar-h: 52px;
            --sb-bg: #1a1d20;
            --sb-hover: rgba(255,255,255,.08);
            --sb-active: rgba(255,255,255,.14);
            --sb-text: #ced4da;
            --sb-muted: #6c757d;
        }

        body { margin: 0; background: #f0f2f5; }

        /* ── TOPBAR ─────────────────────────────────────────────────── */
        #topbar {
            position: fixed; top: 0; left: 0; right: 0;
            height: var(--topbar-h);
            background: #212529;
            border-bottom: 1px solid rgba(255,255,255,.08);
            display: flex; align-items: center;
            padding: 0 14px; gap: 10px;
            z-index: 1050;
        }
        #sb-toggle {
            background: none; border: none; color: #adb5bd;
            font-size: 1.2rem; cursor: pointer; padding: 6px 8px;
            border-radius: 6px; line-height: 1; flex-shrink: 0;
            transition: color .15s, background .15s;
        }
        #sb-toggle:hover { color: #fff; background: var(--sb-hover); }
        #topbar-brand {
            display: flex; align-items: center; gap: 8px;
            text-decoration: none;
        }
        #topbar-brand img { height: 32px; width: auto; }
        #topbar-brand span {
            color: #fff; font-weight: 700; font-size: .95rem;
            letter-spacing: .04em; white-space: nowrap;
        }
        #topbar-user {
            margin-left: auto; display: flex; align-items: center; gap: 8px;
        }
        #topbar-user .user-name {
            color: #fff; font-size: .85rem; font-weight: 600;
            white-space: nowrap;
        }
        #topbar-user .user-badge {
            font-size: .72rem; padding: 2px 7px;
        }
        #topbar-user a.logout {
            color: #dc3545; font-size: .82rem; text-decoration: none;
            padding: 5px 10px; border: 1px solid rgba(220,53,69,.4);
            border-radius: 6px; transition: all .15s;
        }
        #topbar-user a.logout:hover { background: #dc3545; color: #fff; }

        /* ── SIDEBAR ────────────────────────────────────────────────── */
        #sidebar {
            position: fixed;
            top: var(--topbar-h); left: 0; bottom: 0;
            width: var(--sb-width);
            background: var(--sb-bg);
            overflow-y: auto; overflow-x: hidden;
            transition: width .25s ease;
            z-index: 1040;
            border-right: 1px solid rgba(255,255,255,.06);
        }
        body.sb-collapsed #sidebar { width: var(--sb-collapsed-width); }

        .sb-logo {
            padding: 14px 12px 10px;
            border-bottom: 1px solid rgba(255,255,255,.06);
            display: flex; align-items: center; gap: 10px;
            overflow: hidden; white-space: nowrap;
        }
        .sb-logo img { height: 28px; width: auto; flex-shrink: 0; }
        .sb-logo-text { color: #fff; font-size: .78rem; font-weight: 600; line-height: 1.2; }
        .sb-logo-text small { display: block; color: var(--sb-muted); font-size: .68rem; font-weight: 400; }
        body.sb-collapsed .sb-logo-text { display: none; }

        .sb-section {
            padding: 14px 0 4px;
            overflow: hidden;
        }
        .sb-section-title {
            font-size: .66rem; font-weight: 700; letter-spacing: .1em;
            text-transform: uppercase; color: var(--sb-muted);
            padding: 0 16px 4px; white-space: nowrap;
            transition: opacity .2s;
        }
        body.sb-collapsed .sb-section-title { opacity: 0; height: 0; padding: 0; margin: 0; }

        .sb-link {
            display: flex; align-items: center; gap: 11px;
            padding: 8px 12px; margin: 1px 6px;
            color: var(--sb-text); text-decoration: none;
            border-radius: 7px; white-space: nowrap;
            font-size: .875rem; transition: background .15s, color .15s;
            overflow: hidden;
        }
        .sb-link:hover { background: var(--sb-hover); color: #fff; text-decoration: none; }
        .sb-link.sb-active { background: var(--sb-active); color: #fff; font-weight: 600; }
        .sb-link i { width: 20px; text-align: center; font-size: .95rem; flex-shrink: 0; }
        .sb-link-text { transition: opacity .2s; white-space: nowrap; }
        body.sb-collapsed .sb-link-text { opacity: 0; width: 0; overflow: hidden; }
        body.sb-collapsed .sb-link { padding: 8px; margin: 1px 6px; justify-content: center; gap: 0; }

        .sb-divider { border-top: 1px solid rgba(255,255,255,.07); margin: 4px 12px; }

        .sb-bottom {
            border-top: 1px solid rgba(255,255,255,.07);
            padding: 8px 0;
        }

        /* ── MAIN CONTENT ───────────────────────────────────────────── */
        #main-content {
            margin-top: var(--topbar-h);
            margin-left: var(--sb-width);
            transition: margin-left .25s ease;
            min-height: calc(100vh - var(--topbar-h));
        }
        body.sb-collapsed #main-content { margin-left: var(--sb-collapsed-width); }

        /* ── MOBILE ─────────────────────────────────────────────────── */
        @media (max-width: 991px) {
            #sidebar { width: 0; border: none; }
            #main-content { margin-left: 0; }
            body.sb-open #sidebar {
                width: var(--sb-width);
                box-shadow: 6px 0 28px rgba(0,0,0,.55);
            }
            #sb-overlay {
                display: none; position: fixed; inset: 0;
                background: rgba(0,0,0,.45); z-index: 1039;
            }
            body.sb-open #sb-overlay { display: block; }
        }

        /* ── LEGADO (tablas, impresión, etc.) ───────────────────────── */
        th.sorting_desc, th.sorting { color: rgb(0,0,0); }
        .divGeneral, .divGralDetIns { background-color: rgb(247,247,247); }
        table.dataTable { border: 2px solid #fff; border-spacing: 2px; border-collapse: collapse !important; }
        thead { background-color: rgb(0,0,255); }
        .table thead th { border: 2px solid #000; }
        input::placeholder { color: rgba(137,137,137,.5); }
        input:nth-of-type(1n+1) { background-color: rgb(193,255,118); }
        #campoSenior, #campoDivision { display: none; }

        /* Navbar Bootstrap overrides */
        .navbar .nav-link, .navbar .navbar-brand { color: #ffffff !important; }
        .navbar .nav-link:hover, .navbar .navbar-brand:hover {
            color: #fff !important;
            text-shadow: 0 0 15px rgba(255,255,255,1), 0 0 30px rgba(255,255,255,.8) !important;
        }

        @media print {
            #topbar, #sidebar, #sb-overlay { display: none !important; }
            #main-content { margin: 0 !important; }
            .imprimirDescargo, .imprInsc { display: block; }
        }

        /* ── MODO KIOSKO ──────────────────────────────────────────── */
        body.kiosko-active ::-webkit-scrollbar { width: 0; }
        body.kiosko-active #topbar { border-bottom-color: rgba(255,200,0,.25); }

        /* PIN Modal */
        .pin-dot {
            width: 14px; height: 14px; border-radius: 50%;
            border: 2px solid rgba(255,255,255,.3);
            transition: background .12s, border-color .12s;
        }
        .pin-dot.filled { background: #ffc107; border-color: #ffc107; }
        .pin-btn {
            background: #262626; color: #fff; border: 1px solid #3a3a3a;
            border-radius: 12px; width: 100%; padding: .7rem .5rem;
            font-size: 1.35rem; font-weight: 700; cursor: pointer;
            transition: background .1s, transform .07s; line-height: 1;
        }
        .pin-btn:hover { background: #333; }
        .pin-btn:active { transform: scale(.88); }
        .pin-btn.pin-del { font-size: .85rem; color: #ef5350; border-color: rgba(239,83,80,.3); }
        .pin-btn.pin-ok  { background: #2e7d32; border-color: #388e3c; font-size: .85rem; }
        @keyframes pin-shake {
            0%,100% { transform: translateX(0); }
            20%,60% { transform: translateX(-9px); }
            40%,80% { transform: translateX(9px); }
        }
        .pin-shake { animation: pin-shake .45s ease; }
    </style>
</head>
<body>

<!-- ── MODAL PIN KIOSKO ───────────────────────────────────────────────── -->
<div class="modal fade" id="modalPinKiosko" tabindex="-1"
     data-bs-backdrop="static" data-bs-keyboard="false" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg"
             style="background:#1a1a1a;color:#fff;border-radius:20px;overflow:hidden;">
            <div class="modal-body p-4 text-center">
                <i class="fas fa-lock fa-2x text-warning mb-2 d-block"></i>
                <h5 class="fw-bold mb-0">Salir del Modo Kiosko</h5>
                <p class="text-secondary small mt-1 mb-3">Introduce el PIN de operador</p>

                <!-- Dots -->
                <div id="pinDots" class="d-flex justify-content-center gap-3 mb-4"></div>

                <!-- Pad numérico 3×4 -->
                <div class="row g-2 mb-3">
                    <div class="col-4"><button class="pin-btn" onclick="_pinPresionar(1)">1</button></div>
                    <div class="col-4"><button class="pin-btn" onclick="_pinPresionar(2)">2</button></div>
                    <div class="col-4"><button class="pin-btn" onclick="_pinPresionar(3)">3</button></div>
                    <div class="col-4"><button class="pin-btn" onclick="_pinPresionar(4)">4</button></div>
                    <div class="col-4"><button class="pin-btn" onclick="_pinPresionar(5)">5</button></div>
                    <div class="col-4"><button class="pin-btn" onclick="_pinPresionar(6)">6</button></div>
                    <div class="col-4"><button class="pin-btn" onclick="_pinPresionar(7)">7</button></div>
                    <div class="col-4"><button class="pin-btn" onclick="_pinPresionar(8)">8</button></div>
                    <div class="col-4"><button class="pin-btn" onclick="_pinPresionar(9)">9</button></div>
                    <div class="col-4">
                        <button class="pin-btn pin-del" onclick="_pinBorrar()">
                            <i class="fas fa-backspace"></i>
                        </button>
                    </div>
                    <div class="col-4"><button class="pin-btn" onclick="_pinPresionar(0)">0</button></div>
                    <div class="col-4">
                        <button class="pin-btn pin-ok" onclick="_pinConfirmar()">
                            <i class="fas fa-check"></i>
                        </button>
                    </div>
                </div>

                <button class="btn btn-outline-secondary btn-sm w-100"
                        data-bs-dismiss="modal">Cancelar</button>
            </div>
        </div>
    </div>
</div>

<!-- ── TOPBAR ─────────────────────────────────────────────────────────── -->
<div id="topbar">
    <button id="sb-toggle" onclick="toggleSidebar()" title="Menú">
        <i class="fas fa-bars"></i>
    </button>

    <a id="topbar-brand" href="/">
        <img src="/img/fdff.svg" alt="FDFF" onerror="this.style.display='none'">
        <span>FDFF</span>
    </a>

    <div id="topbar-user">
        <% if (locals.user) {
            const _rol = locals.user.role || 'general';
            const _rolLabel = { admin:'Admin', ejecutivo:'Ejecutivo', juez:'Juez', estadistico:'Estadístico', atleta:'Atleta', preparador:'Coach', fotografo:'Fotógrafo', general:'General' }[_rol] || _rol;
            const _rolColor = { admin:'danger', ejecutivo:'warning', juez:'info', estadistico:'primary', atleta:'success', preparador:'secondary', fotografo:'light', general:'secondary' }[_rol] || 'secondary';
            const _primerNombre = (locals.user.nombre || locals.user.email || '').split(' ')[0];
        %>
            <% if (['admin','ejecutivo','estadistico'].includes(_rol)) { %>
            <button id="btnKiosko" onclick="toggleKiosko()"
                    class="btn btn-outline-warning btn-sm fw-bold d-flex align-items-center gap-1"
                    title="Activar / Salir del Modo Kiosko">
                <i class="fas fa-desktop"></i>
                <span class="d-none d-md-inline">Kiosko</span>
            </button>
            <% } %>
            <i class="fas fa-user-circle text-secondary d-none d-sm-inline"></i>
            <span class="user-name d-none d-sm-inline"><%= _primerNombre %></span>
            <span class="badge bg-<%= _rolColor %> user-badge text-<%= (_rolColor === 'warning' || _rolColor === 'light') ? 'dark' : 'white' %>">
                <%= _rolLabel %>
            </span>
            <a href="/logout" class="logout d-none d-sm-flex align-items-center gap-1">
                <i class="fas fa-sign-out-alt"></i> Salir
            </a>
        <% } else { %>
            <a href="/login" class="btn btn-outline-light btn-sm fw-bold">
                <i class="fas fa-sign-in-alt me-1"></i> Entrar
            </a>
        <% } %>
    </div>
</div>

<!-- ── OVERLAY MÓVIL ──────────────────────────────────────────────────── -->
<div id="sb-overlay" onclick="toggleSidebar()"></div>

<!-- ── SIDEBAR ────────────────────────────────────────────────────────── -->
<aside id="sidebar">
    <%- include("navbar") %>
</aside>

<!-- ── CONTENIDO PRINCIPAL ────────────────────────────────────────────── -->
<div id="main-content">

<script>
    const _KIOSKO_PIN = "<%= locals.KIOSKO_PIN || '2024FDFF' %>";

    // ── Sidebar toggle ────────────────────────────────────────────────
    function toggleSidebar() {
        const isMobile = window.innerWidth <= 991;
        if (isMobile) {
            document.body.classList.toggle('sb-open');
        } else {
            const collapsed = document.body.classList.toggle('sb-collapsed');
            localStorage.setItem('sb-collapsed', collapsed ? '1' : '0');
        }
    }

    // Restaurar estado al cargar
    (function() {
        if (window.innerWidth > 991 && localStorage.getItem('sb-collapsed') === '1') {
            document.body.classList.add('sb-collapsed');
        }
        // Marcar enlace activo
        const path = window.location.pathname;
        document.querySelectorAll('.sb-link').forEach(a => {
            if (a.getAttribute('href') === path || (a.getAttribute('href') !== '/' && path.startsWith(a.getAttribute('href')))) {
                a.classList.add('sb-active');
            }
        });
    })();

    // ── Kiosko ───────────────────────────────────────────────────────
    async function toggleKiosko() {
        const isKiosko = localStorage.getItem('modoKiosko') === 'true';
        isKiosko ? _pinAbrir() : await activarKiosko();
    }
    async function activarKiosko() {
        try { await document.documentElement.requestFullscreen(); }
        catch (e) { console.warn('Fullscreen no disponible:', e.message); }
        localStorage.setItem('modoKiosko', 'true');
        if (typeof activarInterfazKiosko === 'function') activarInterfazKiosko();
    }

    // ── PIN Modal ────────────────────────────────────────────────────
    let _pinActual = '';

    function _pinAbrir() {
        _pinActual = '';
        const len = _KIOSKO_PIN.length;
        const dots = document.getElementById('pinDots');
        dots.innerHTML = Array.from({ length: len }, () => '<div class="pin-dot"></div>').join('');
        new bootstrap.Modal(document.getElementById('modalPinKiosko')).show();
    }

    function _pinPresionar(d) {
        if (_pinActual.length >= _KIOSKO_PIN.length) return;
        _pinActual += String(d);
        document.querySelectorAll('.pin-dot').forEach((dot, i) => {
            dot.classList.toggle('filled', i < _pinActual.length);
        });
        if (_pinActual.length === _KIOSKO_PIN.length) _pinConfirmar();
    }

    function _pinBorrar() {
        _pinActual = _pinActual.slice(0, -1);
        document.querySelectorAll('.pin-dot').forEach((dot, i) => {
            dot.classList.toggle('filled', i < _pinActual.length);
        });
    }

    async function _pinConfirmar() {
        if (_pinActual === _KIOSKO_PIN) {
            bootstrap.Modal.getInstance(document.getElementById('modalPinKiosko')).hide();
            localStorage.setItem('modoKiosko', 'false');
            document.body.classList.remove('kiosko-active');
            if (typeof actualizarBotonKiosko === 'function') actualizarBotonKiosko(false);
            if (document.fullscreenElement) await document.exitFullscreen();
        } else {
            const dots = document.getElementById('pinDots');
            dots.classList.add('pin-shake');
            dots.querySelectorAll('.pin-dot').forEach(d => { d.style.borderColor='#ef5350'; d.style.background='rgba(239,83,80,.15)'; });
            setTimeout(() => {
                dots.classList.remove('pin-shake');
                _pinActual = '';
                dots.querySelectorAll('.pin-dot').forEach(d => { d.style.borderColor=''; d.style.background=''; d.classList.remove('filled'); });
            }, 500);
        }
    }

    // Soporte teclado físico en el modal (acepta cualquier carácter, no solo dígitos)
    document.getElementById('modalPinKiosko').addEventListener('keydown', (e) => {
        if (e.key === 'Backspace') { e.preventDefault(); _pinBorrar(); }
        else if (e.key === 'Enter')  { e.preventDefault(); _pinConfirmar(); }
        else if (e.key.length === 1 && !e.ctrlKey && !e.altKey && !e.metaKey) {
            const d = parseInt(e.key);
            if (!isNaN(d)) _pinPresionar(d);
        }
    });
</script>
