<!-- ── LOGO EN SIDEBAR ──────────────────────────────────────────────── -->
<div class="sb-logo">
    <img src="/img/fdff.svg" alt="FDFF" onerror="this.style.display='none'">
    <div class="sb-logo-text">
        FEDERACIÓN DOMINICANA
        <small>DE FISICULTURISMO · IFBB</small>
    </div>
</div>

<% if (locals.user) { %>

<!-- ── MI CUENTA ──────────────────────────────────────────────────── -->
<div class="sb-section">
    <div class="sb-section-title">Mi Cuenta</div>
    <a class="sb-link" href="/"><i class="fas fa-home"></i><span class="sb-link-text">Inicio</span></a>
    <a class="sb-link" href="/eventos/competencias"><i class="fas fa-trophy"></i><span class="sb-link-text">Competencias</span></a>
    <a class="sb-link" href="/jueces"><i class="fas fa-gavel"></i><span class="sb-link-text">Comité de Jueces</span></a>

    <% if (locals.user.role === 'atleta' || locals.user.role === 'admin') { %>
        <a class="sb-link" href="/atletas/perfil"><i class="fas fa-user-circle text-warning"></i><span class="sb-link-text">Mi Perfil</span></a>
        <a class="sb-link" href="/servicios"><i class="fas fa-concierge-bell"></i><span class="sb-link-text">Servicios</span></a>
    <% } %>

    <% if (locals.user.role === 'general' || locals.user.role === 'admin') { %>
        <a class="sb-link" href="/afiliacion"><i class="fas fa-id-card text-info"></i><span class="sb-link-text">Afiliación</span></a>
    <% } %>
</div>
<div class="sb-divider"></div>

<% } %>

<!-- ── SECCIÓN PÚBLICA (accesible sin login) ────────────────────── -->
<div class="sb-section">
    <div class="sb-section-title">General</div>
    <a class="sb-link" href="/social/muro"><i class="fas fa-comments"></i><span class="sb-link-text">Muro Social</span></a>
    <a class="sb-link" href="/social/noticias"><i class="fas fa-newspaper"></i><span class="sb-link-text">Noticias</span></a>
    <a class="sb-link" href="/eventos/historico"><i class="fas fa-award"></i><span class="sb-link-text">Salón de la Fama</span></a>
    <a class="sb-link" href="/preparadores/ranking-teams"><i class="fas fa-trophy"></i><span class="sb-link-text">Ranking Teams</span></a>
</div>

<% if (locals.user) { %>

<!-- ── PANEL DE CONTROL (Admin / Ejecutivo) ───────────────────────── -->
<% if (locals.user.role === 'admin' || locals.user.role === 'ejecutivo') { %>
<div class="sb-divider"></div>
<div class="sb-section">
    <div class="sb-section-title">Gestión</div>

    <a class="sb-link" href="/admin/registro_staff"><i class="fas fa-user-shield"></i><span class="sb-link-text">Personal</span></a>
    <a class="sb-link" href="/atletas"><i class="fas fa-users"></i><span class="sb-link-text">Atletas</span></a>
    <a class="sb-link" href="/preparadores"><i class="fas fa-user-tie"></i><span class="sb-link-text">Coaches</span></a>
    <a class="sb-link" href="/categorias"><i class="fas fa-tags"></i><span class="sb-link-text">Categorías</span></a>
    <a class="sb-link" href="/categorias/nuevoEvento"><i class="fas fa-calendar-plus"></i><span class="sb-link-text">Crear Evento</span></a>

</div>
<% } %>

<!-- ── JUECES ─────────────────────────────────────────────────────── -->
<% if (locals.user.role === 'juez') { %>
<div class="sb-divider"></div>
<div class="sb-section">
    <div class="sb-section-title">Jueces</div>
    <a class="sb-link" href="/jueces"><i class="fas fa-gavel"></i><span class="sb-link-text">Panel de Jueces</span></a>
</div>
<% } %>

<!-- ── PREPARADOR / COACH ─────────────────────────────────────────── -->
<% if (locals.user.role === 'preparador') { %>
<div class="sb-divider"></div>
<div class="sb-section">
    <div class="sb-section-title">Mi Team</div>
    <a class="sb-link" href="/preparadores/panel"><i class="fas fa-clipboard-list text-primary"></i><span class="sb-link-text">Mi Panel</span></a>
    <a class="sb-link" href="/preparadores/ranking-teams"><i class="fas fa-trophy text-warning"></i><span class="sb-link-text">Ranking Teams</span></a>
</div>
<% } %>

<!-- ── FOTÓGRAFO ──────────────────────────────────────────────────── -->
<% if (locals.user.role === 'fotografo') { %>
<div class="sb-divider"></div>
<div class="sb-section">
    <div class="sb-section-title">Fotografía</div>
    <a class="sb-link" href="/fotografo/upload"><i class="fas fa-camera"></i><span class="sb-link-text">Subir Fotos</span></a>
</div>
<% } %>

<% } %>
