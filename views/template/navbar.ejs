        <% if (user.role === 'estadistico' || user.role === 'admin') { %>
          <li class="nav-item active"><a class="nav-link" href="/inscripcion"><strong>Pesaje</strong></a></li>
          <li class="nav-item active"><a class="nav-link" href="/estadisticas"><strong>Estadísticas</strong></a></li>
        <% } %>

