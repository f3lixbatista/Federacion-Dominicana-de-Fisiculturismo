        <% if (user.role === 'atleta' || user.role === 'admin') { %>
          <li class="nav-item active"><a class="nav-link" href="/servicios"><strong>Servicios</strong></a></li>
          <li class="nav-item active"><a class="nav-link" href="/InscripcionAtleta"><strong>Afiliacion</strong></a></li>
        <% } %>

        <!-- JUECES -->
        <% if (user.role === 'juez' || user.role === 'admin') { %>
          <li class="nav-item active"><a class="nav-link" href="/jueces"><strong>Jueces</strong></a></li>
          <li class="nav-item active"><a class="nav-link" href="/atletas"><strong>Atletas</strong></a></li>
        <% } %>

        <!-- EJECUTIVO (Configuración) -->
        <% if (user.role === 'ejecutivo' || user.role === 'admin') { %>
          <li class="nav-item active"><a class="nav-link" href="/categorias"><strong>Categorías</strong></a></li>
          <li class="nav-item active"><a class="nav-link" href="/categorias/nuevoEvento"><strong>Crear Evento</strong></a></li>
        <% } %>

