<%- include("template/cabecera", {tituloWeb: "Cálculos de Competencia"}) %>

<div class="p-2 divGeneral">
    <div class="row g-2">
        <div class="col-6">
            <h1 class="my-4 seccionAtl">Panel de Jueces</h1>
        </div>
        <div class="col-6 d-flex flex-row-reverse">
            <h2 class="text-primary my-4"><%= datos.nombre %></h2>
        </div>
    </div>

    <div class="table-responsive" id="mydatatable-container">
        <table class="records_list table table-striped table-bordered border-dark table-hover" id="mydatatable">
            <thead>
                <tr class="table-blue text-center">
                    <th scope="col">Acción</th>
                    <th scope="col">Atleta</th>
                    <th scope="col">No.</th>
                    <% for(let i=1; i<=13; i++) { %>
                        <th scope="col">J<%= i %></th>
                    <% } %>
                    <th scope="col">Total</th>
                    <th scope="col">Posición</th>
                </tr>
            </thead>
            <tfoot>
                <tr>
                    <td class="bg-dark text-white fs-5 fw-bold text-center"><%= datos.salida %></td>
                    <td colspan="16" class="bg-primary text-white fs-4 text-center fw-bold lh-1">
                        <%= datos.categoria %> - <%= datos.nombre %>
                    </td>
                </tr>
            </tfoot>
            <tbody>
                <% if (datos.Competidor && datos.Competidor.length > 0) { %>
                    <% datos.Competidor.forEach(comp => { %> 
                        <tr>
                            <td><a href="/atletas/<%= comp.idfdff %>" class="btn btn-warning btn-sm">Perfil</a></td>
                            <td class="fw-bold"><%= comp.nombre %></td>
                            <td class="text-center bg-light fw-bold"><%= comp.numero_competidor %></td>

                            <!-- Inputs para los 13 jueces -->
                            <% for(let j=1; j<=13; j++) { %>
                                <td class="p-0">
                                    <input name="j<%= j %>" type="number" 
                                           style="width:100%;" 
                                           class="text-center border-0 p-1" 
                                           data-atleta="<%= comp.id %>">
                                </td>
                            <% } %>

                            <td class="p-0">
                                <input id="total_<%= comp.id %>" type="number" readonly
                                       style="width:100%; font-weight:bold;" 
                                       class="text-center bg-light border-0 p-1">
                            </td>
                            <td class="p-0">
                                <input id="pos_<%= comp.id %>" type="number" 
                                       style="width:100%;" 
                                       class="text-center border-0 p-1">
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="18" class="text-center">No hay competidores inscritos en esta categoría.</td>
                    </tr>
                <% } %>     
            </tbody>
        </table>
    </div>

    <script type="text/javascript">
        $(document).ready(function () {
            var table = $('#mydatatable').DataTable({
                "dom": 'Bfrtip',
                "responsive": false,
                "language": { "url": "https://cdn.datatables.net/plug-ins/1.10.19/i18n/Spanish.json" },
                "buttons": ['excel', 'pdf', 'print']
            });
        });

        // Lógica para calcular totales automáticamente
document.addEventListener('input', function (e) {
    // Verificamos si el input que cambió pertenece a un juez
    if (e.target.name && e.target.name.startsWith('j')) {
        
        // Buscamos la fila (tr) donde está el juez que acaba de escribir
        const fila = e.target.closest('tr');
        
        // Seleccionamos todos los inputs de jueces (j1 al j13) de ESA fila
        const inputsJueces = fila.querySelectorAll('input[name^="j"]');
        
        let sumaTotal = 0;

        inputsJueces.forEach(input => {
            const valor = parseInt(input.value);
            // Si el valor es un número válido, lo sumamos
            if (!isNaN(valor)) {
                sumaTotal += valor;
            }
        });

        // Buscamos el input del total de esa fila y le asignamos el resultado
        // Usamos una selección por atributo id parcial o clase
        const inputTotal = fila.querySelector('input[id^="total_"]');
        if (inputTotal) {
            inputTotal.value = sumaTotal;
        }
    }
});
    
    </script>
</div>
<%- include("template/footer") %>
