<%- include("template/cabecera", {tituloWeb: "Gestión de Categorías"}) %>

<div class="container container-fluid pt-5">
    <div class="row mb-4">
        <div class="col-md-6">
            <a class="btn btn-dark" href="/categorias/crearCategoria">
                Nueva Categoria
            </a>
        </div>
        <div class="col-md-6">
            <input type="text" id="buscar" class="form-control" placeholder="Buscar categoría...">
        </div>
    </div>

    <div class="table-responsive" id="mydatatable-container">
        <table class="records_list table table-striped table-bordered border-3 border-dark table-hover" id="mydatatable">
            <thead class="fw-bold lh-1 border border-3 border-dark">
                <tr>
                    <th scope="col" class="fs-3 pl-5">Categorias</th>
                    <td colspan="2" class="fs-5 pt-3 text-center border border-3 border-dark">Edad</td>
                    <td colspan="2" class="fs-5 pt-3 text-center border border-3 border-dark">Peso</td>
                    <td colspan="2" class="fs-5 pt-3 text-center border border-3 border-dark">Estatura</td>
                </tr>
            </thead>
            <tfoot class="col-12 bg-dark">
                <tr class="text-white text-center">
                    <th></th>
                    <td>Desde</td><td>Hasta</td>
                    <td>Desde</td><td>Hasta</td>
                    <td>Desde</td><td>Hasta</td>
                </tr>
            </tfoot>
            <tbody>
                <% if (arrayCategorias.length > 0) { %>
                    <% arrayCategorias.forEach(categoria => { %>
                        <tr class="fila-categoria">
                            <!-- CAMBIO: variables en minúsculas segun Supabase -->
                            <td class="fs-4 border border-2 border-dark nombre-cat"><%= categoria.nombre %></td>
                            <td class="fs-5 border border-2 border-dark"><%= categoria.desde_edad %></td>
                            <td class="fs-5 border border-2 border-dark"><%= categoria.hasta_edad %></td>
                            <td class="fs-5 border border-2 border-dark"><%= categoria.desde_peso %></td>
                            <td class="fs-5 border border-2 border-dark"><%= categoria.hasta_peso %></td>
                            <td class="fs-5 border border-2 border-dark"><%= categoria.desde_estatura %></td>
                            <td class="fs-5 border border-2 border-dark"><%= categoria.hasta_estatura %></td>
                        </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>

    <script>
        // Script de búsqueda optimizado
        const inputBuscar = document.getElementById("buscar");
        inputBuscar.addEventListener('keyup', function() {
            const textoBusqueda = inputBuscar.value.toLowerCase();
            const filas = document.querySelectorAll(".fila-categoria");

            filas.forEach(fila => {
                const nombreCategoria = fila.querySelector(".nombre-cat").textContent.toLowerCase();
                if (nombreCategoria.includes(textoBusqueda)) {
                    fila.style.display = ""; // Muestra la fila
                } else {
                    fila.style.display = "none"; // Oculta la fila
                }
            });
        });
    </script>
</div>

<%- include("template/footer") %>
