<%- include("template/cabecera", {tituloWeb: "Gestión de Categorías"}) %>

<div class="container container-fluid pt-5">
    <div class="row mb-4 align-items-center">
        <div class="col-md-4 d-flex gap-2">
            <a class="btn btn-dark fw-bold" href="/categorias/crearCategoria">
                <i class="fas fa-plus me-1"></i> Nueva Categoría
            </a>
        </div>
        <div class="col-md-5 ms-auto">
            <input type="text" id="buscar" class="form-control" placeholder="Buscar categoría...">
        </div>
    </div>

    <div class="table-responsive" id="mydatatable-container">
        <table class="records_list table table-striped table-bordered border-2 table-hover shadow-sm" id="mydatatable">
            <thead class="fw-bold lh-1 border-bottom border-dark bg-dark text-white">
                <tr>
                    <th scope="col" class="fs-3 pl-5">Categorias</th>
                    <td colspan="2" class="fs-5 pt-3 text-center border-start">Edad (Años)</td>
                    <td colspan="2" class="fs-5 pt-3 text-center border-start">Peso (Kg)</td>
                    <td colspan="2" class="fs-5 pt-3 text-center border-start">Estatura (cm)</td>
                </tr>
                <tr class="text-white text-center" style="font-size:.85rem;opacity:.8;">
                    <th>Nombre</th>
                    <td>Desde</td><td>Hasta</td>
                    <td>Desde</td><td>Hasta</td>
                    <td>Desde</td><td>Hasta</td>
                </tr>
            </thead>
            <tbody>
                <% if (arrayCategorias.length > 0) { %>
                    <% arrayCategorias.forEach(categoria => { %>
                        <tr class="fila-categoria">
                            <!-- CAMBIO: variables en minúsculas segun Supabase -->
                            <td class="fs-5 fw-bold nombre-cat">
                                <% if(categoria.sexo === 'F') { %> <i class="fas fa-venus text-danger me-1"></i> <% } %>
                                <% if(categoria.sexo === 'M') { %> <i class="fas fa-mars text-primary me-1"></i> <% } %>
                                <%= categoria.nombre %>
                                <div class="small text-muted fw-normal" style="font-size: 0.75rem;"><%= categoria.modalidad %> | <%= categoria.disciplina %></div>
                            </td>
                            <td class="fs-6 text-center border-start"><%= categoria.edad_min || '-' %></td>
                            <td class="fs-6 text-center"><%= categoria.edad_max || '-' %></td>
                            <td class="fs-6 text-center border-start"><%= categoria.peso_min || '-' %></td>
                            <td class="fs-6 text-center"><%= categoria.peso_max || '-' %></td>
                            <td class="fs-6 text-center border-start"><%= categoria.estatura_min || '-' %></td>
                            <td class="fs-6 text-center"><%= categoria.estatura_max || '-' %></td>
                        </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>

    <script>
        document.getElementById("buscar").addEventListener('keyup', function() {
            const texto = this.value.toLowerCase();
            document.querySelectorAll(".fila-categoria").forEach(fila => {
                const nombre = fila.querySelector(".nombre-cat").textContent.toLowerCase();
                fila.style.display = nombre.includes(texto) ? "" : "none";
            });
        });

        async function borrarTodasCategorias() {
            const total = document.querySelectorAll(".fila-categoria").length;
            if (!confirm(`¿Borrar las ${total} categorías? Esta acción es irreversible.`)) return;
            const resp = await fetch('/categorias/todas', { method: 'DELETE' });
            const result = await resp.json();
            if (result.ok) { alert('Categorías eliminadas.'); location.reload(); }
            else alert('Error: ' + (result.error || 'desconocido'));
        }
    </script>
</div>

<%- include("template/footer") %>
