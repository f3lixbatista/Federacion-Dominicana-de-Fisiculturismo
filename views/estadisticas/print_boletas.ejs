<%- include("../template/cabecera", {tituloWeb: "Impresión de Boletas"}) %>
<style>
    @media print {
        .no-print { display: none; }
        .page-break { page-break-after: always; border-bottom: 2px dashed #ccc; padding-bottom: 20px; }
        body { background: white; }
    }
    .boleta-box { border: 2px solid #000; padding: 20px; margin-bottom: 30px; border-radius: 10px; }
    .table-boleta th, .table-boleta td { border: 1px solid #000 !important; font-size: 1.1rem; }
</style>

<div class="container my-4 no-print text-center">
    <button onclick="window.print()" class="btn btn-danger btn-lg fw-bold"><i class="fas fa-print"></i> IMPRIMIR TODAS LAS BOLETAS</button>
</div>

<div class="container mt-2">
    <% categorias.forEach(cat => { %>
        <div class="boleta-box page-break">
            <div class="row align-items-center mb-3">
                <div class="col-2"><img src="/img/fdff3.jpg" style="width: 80px;"></div>
                <div class="col-8 text-center">
                    <h4 class="fw-bold mb-0">BOLETA OFICIAL DE VOTACIÓN</h4>
                    <h5 class="text-uppercase"><%= cat.categorias.nombre %></h5>
                </div>
                <div class="col-2 text-end"><strong>SILLA: ____</strong></div>
            </div>

            <table class="table table-boleta text-center align-middle">
                <thead>
                    <tr class="bg-light">
                        <th style="width: 15%;">DORSAL</th>
                        <th class="text-start ps-3">NOMBRE DEL ATLETA</th>
                        <th style="width: 25%;">LUGAR (PUESTO)</th>
                    </tr>
                </thead>
                <tbody>
                    <% cat.competidores.sort((a,b)=>a.numero_atleta - b.numero_atleta).forEach(comp => { %>
                        <tr style="height: 50px;">
                            <td class="fw-bold fs-4"><%= comp.numero_atleta %></td>
                            <td class="text-start ps-3"><%= comp.atletas.nombre %></td>
                            <td></td> <!-- Espacio para que el juez escriba -->
                        </tr>
                    <% }) %>
                </tbody>
            </table>

            <div class="row mt-5">
                <div class="col-6 text-center">
                    <p class="mb-0">__________________________</p>
                    <small>Firma del Juez</small>
                </div>
                <div class="col-6 text-center">
                    <p class="mb-0">__________________________</p>
                    <small>Juez Estadístico</small>
                </div>
            </div>
        </div>
    <% }) %>
</div>

<%- include("../template/footer") %>