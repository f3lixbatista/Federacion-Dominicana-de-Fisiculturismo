<%- include("template/cabecera", {tituloWeb: "Registro de Preparadores"}) %>
<main class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Registrar Preparador / Coach</h5>
                </div>
                <div class="card-body">
                    <% if (locals.error) { %>
                        <div class="alert alert-danger"><%= error %></div>
                    <% } %>
                    <% if (locals.query && query.success) { %>
                        <div class="alert alert-success">Preparador registrado correctamente.</div>
                    <% } %>

                    <form method="POST" action="/afiliacion/nuevo-preparador">
                        <div class="mb-3">
                            <label class="form-label fw-bold text-primary">ID Coach FDFF</label>
                            <input name="ID_Coach_FDFF" value="<%= locals.ID_Coach_FDFF || '00045' %>" type="text" class="form-control bg-light" readonly>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Nombre completo</label>
                            <input name="nombre_completo" value="<%= locals.nombre_completo || '' %>" type="text" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Cédula / Identificación</label>
                            <input name="cedula" value="<%= locals.cedula || '' %>" type="text" class="form-control">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Correo Electrónico</label>
                            <input name="email" value="<%= locals.email || '' %>" type="email" class="form-control">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Teléfono / WhatsApp</label>
                            <input name="telefono" value="<%= locals.telefono || '' %>" type="text" class="form-control">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Gimnasio donde labora</label>
                            <input name="gimnasio" value="<%= locals.gimnasio || '' %>" type="text" class="form-control">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Dirección Residencial</label>
                            <textarea name="direccion" class="form-control" rows="2"><%= locals.direccion || '' %></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">Guardar Preparador</button>
                        <a href="/afiliacion" class="btn btn-secondary ms-2">Volver a Afiliación</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>
<%- include('template/footer') %>
