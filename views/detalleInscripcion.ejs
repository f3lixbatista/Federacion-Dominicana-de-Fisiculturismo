<%- include("template/cabecera", {tituloWeb: "Selección de Categoría"}) %>

<div class="container divGralDetIns border border-primary border-3 mb-2 p-4">

    <% if (error) { %>
        <div class="text-center">
            <p class="alert alert-danger"><%= mensaje %></p>
            <a href="/inscripcion" class="btn btn-warning">Volver a Inscripción</a>
        </div>
    <% } %>

    <% if (!error) { %>
        <!-- El id se envía vía PUT a la ruta de inscripción -->
        <form id="formularioInscribir" class="row g-3 needs-validation was-validated" data-id="<%= atleta.id %>">
            
            <h6 class="position-relative mt-4 opacity-50">Datos del Atleta (Verificación)</h6>
                
            <div class="col-md-2">
                <label class="form-label">ID-FDFF</label>
                <input value="<%= atleta.idfdff %>" type="number" class="form-control" name="idfdff" readonly>
            </div>

            <div class="col-md-4">
                <label class="form-label">Nombre Completo</label>
                <input value="<%= atleta.nombre %>" type="text" class="form-control" name="nombre" readonly>
            </div>

            <div class="col-md-3">
                <label class="form-label">Fecha Inscripción</label>
                <input value="<%= new Date().toISOString().split('T')[0] %>" type="date" class="form-control" name="fecha_inscripcion" readonly>
            </div>

            <div class="col-md-3">
                <label class="form-label">Cédula</label>
                <input value="<%= atleta.cedula %>" type="number" class="form-control" name="cedula" readonly>
            </div>

            <h6 class="position-relative mt-5 opacity-50">Mediciones del Evento y Categoría</h6>

            <div class="col-md-4">
                <label class="form-label text-primary fw-bold">Seleccionar Categoría del Evento</label>
                <select class="form-control border-primary" name="id_evento" required>
                    <option value="" selected disabled>Seleccione el Evento...</option>
                    <% arrayCategorias.forEach(cat => { %>
                        <option value="<%= cat.id %>"><%= cat.nombre %> - <%= cat.categoria %></option>
                    <% }) %>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Peso Real (kg)</label>
                <input type="number" step="0.01" class="form-control" name="peso_real" placeholder="0.00" required>
            </div>

            <div class="col-md-2">
                <label class="form-label">Estatura Real (cm)</label>
                <input type="number" step="0.01" class="form-control" name="estatura_real" placeholder="0.00" required>
            </div>

            <div class="col-md-4">
                <label class="form-label">Preparador/Coach</label>
                <input value="<%= atleta.preparador %>" type="text" class="form-control" name="preparador">
            </div>

            <div class="col-12 mt-5">
                <button type="submit" class="btn btn-primary btn-lg w-100">Confirmar Inscripción en Evento</button>
                <a href="/inscripcion" class="btn btn-outline-secondary w-100 mt-2">Cancelar</a>
            </div>
        </form>
    <% } %>
</div>

<%- include("template/footer") %>

<script>
    const formulario = document.querySelector('#formularioInscribir');
    if(formulario) {
        formulario.addEventListener('submit', async (e) => {
            e.preventDefault();
            const idAtleta = formulario.dataset.id;
            const formData = new FormData(formulario);
            const dataObject = Object.fromEntries(formData.entries());

            try {
                // Enviamos los datos al router de inscripción
                const res = await fetch(`/inscripcion/${idAtleta}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(dataObject)
                });
                const resData = await res.json();

                if(resData.estado) {
                    alert('¡Atleta inscrito con éxito!');
                    window.location.href = '/inscripcion';
                } else {
                    alert('Error: ' + resData.mensaje);
                }
            } catch (err) {
                console.error("Error en inscripción:", err);
            }
        });
    }
</script>
