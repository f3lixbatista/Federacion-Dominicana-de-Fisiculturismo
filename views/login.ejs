<%- include("template/cabecera", {tituloWeb: "Iniciar Sesión - FDFF"}) %>

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg p-4" style="width: 100%; max-width: 400px; border-radius: 15px;">
        <div class="text-center mb-4">
            <!-- Nota: Asegúrate de que el logo esté en /public/img/logo.png -->
            <img src="/img/logo.png" alt="FDFF Logo" style="width: 80px;" class="mb-2">
            <h2 class="fw-bold">Bienvenido</h2>
            <p class="text-muted">Accede al panel federativo</p>
        </div>

        <!-- Botones de Redes Sociales -->
        <div class="d-grid gap-2 mb-4">
            <button onclick="loginConRedSocial('google')" class="btn btn-outline-danger d-flex align-items-center justify-content-center py-2">
                <i class="fab fa-google me-2"></i> Entrar con Google
            </button>
            <button onclick="loginConRedSocial('facebook')" class="btn btn-outline-primary d-flex align-items-center justify-content-center py-2">
                <i class="fab fa-facebook me-2"></i> Entrar con Facebook
            </button>
        </div>

        <div class="position-relative mb-4">
            <hr>
            <span class="position-absolute top-50 start-50 translate-middle bg-white px-2 text-muted small">o con tu email</span>
        </div>

        <!-- Formulario de Email -->
        <form id="formLogin">
            <div class="mb-3">
                <label class="form-label">Correo Electrónico</label>
                <input type="email" id="email" class="form-control" placeholder="ejemplo@correo.com" required>
            </div>
            <div class="mb-3">
                <label class="form-label">Contraseña</label>
                <input type="password" id="password" class="form-control" placeholder="••••••••" required>
            </div>
            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary py-2 fw-bold">Iniciar Sesión</button>
                <button type="button" onclick="registrarUsuario()" class="btn btn-link btn-sm text-decoration-none">¿No tienes cuenta? Regístrate</button>
            </div>
        </form>
    </div>
</div>

<!-- CDN corregido: Usamos unpkg que es más directo para el navegador -->
<script src="https://unpkg.com"></script>

<script>
    // Inicializar Supabase en el Frontend
    // Nota: Las variables vienen de tu archivo .env a través del render de Express
    const supabaseUrl = "<%= process.env.SUPABASE_URL %>";
    const supabaseKey = "<%= process.env.SUPABASE_KEY %>";
    
    // El objeto global de la librería cargada por CDN es 'supabase'
    const _supabase = supabase.createClient(supabaseUrl, supabaseKey);

    // 1. Login con Redes Sociales
    async function loginConRedSocial(provider) {
        const { error } = await _supabase.auth.signInWithOAuth({
            provider: provider,
            options: {
                // Esto redirige al usuario a la ruta de callback que creamos
                redirectTo: window.location.origin + '/auth/callback'
            }
        });
        if (error) alert("Error: " + error.message);
    }

    // 2. Login con Email/Password
    const formLogin = document.getElementById('formLogin');
    formLogin.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = document.getElementById('email').value;
        const password = document.getElementById('password').value;

        const { data, error } = await _supabase.auth.signInWithPassword({
            email: email,
            password: password
        });

        if (error) {
            alert("Error al entrar: " + error.message);
        } else {
            window.location.href = '/'; 
        }
    });

    // 3. Registro de Usuario Nuevo
    async function registrarUsuario() {
        const email = document.getElementById('email').value;
        const password = document.getElementById('password').value;
        
        if(!email || !password) return alert("Completa los campos para registrarte");

        const { error } = await _supabase.auth.signUp({
            email: email,
            password: password
        });

        if (error) alert(error.message);
        else alert("¡Revisa tu correo para confirmar tu cuenta!");
    }
</script>

<%- include("template/footer") %>
