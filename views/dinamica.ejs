<%- include("template/cabecera", {tituloWeb: "Categorías del Evento"}) %>

<div class="container container-fluid p-1">
    <div class="my-4">
        <!-- Mostramos el nombre del evento de forma limpia -->
        <h2 class="fw-bold text-primary"><%= eventosDinamicos %></h2>
        <hr>
    </div>

    <div class="table-responsive" id="mydatatable-container">
        <table class="records_list table table-striped table-bordered table-hover" id="mydatatable">
            <thead>
                <tr class="table-dark">
                    <th scope="col">Orden Salida</th>
                    <th scope="col">Categoría</th>
                    <th scope="col">Estado / Info</th>
                    <th scope="col">Acción</th>
                </tr>
            </thead>
            <tbody>
                <% if (arrayDinamicos.length > 0) { %>
                    <% arrayDinamicos.forEach(item => { %>
                        <tr>
                            <th scope="row" class="text-center"><%= item.salida %></th>
                            <td><%= item.categoria %></td>
                            <td>
                                <!-- Verificamos si hay competidores (si los pasaste en el objeto) -->
                                <% if (item.Competidor && item.Competidor.length > 0) { %>
                                    <span class="badge bg-success"><%= item.Competidor.length %> Inscritos</span>
                                <% } else { %>
                                    <span class="badge bg-secondary">Sin inscritos</span>
                                <% } %>
                            </td>
                            <td>
                                <!-- Enlace dinámico al panel de jueceo usando el ID de Supabase -->
                                <a href="/estadisticas/<%= item.id %>" class="btn btn-warning btn-sm">
                                    Calificar / Editar
                                </a>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="4" class="text-center">No se encontraron categorías para este evento.</td>
                    </tr>
                <% } %>
            </tbody>
            <tfoot>
                <tr>
                    <th>Filtrar..</th>
                    <th>Filtrar..</th>
                    <th></th>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </div>

    <script type="text/javascript">
        $(document).ready(function () {
            // Configuración de filtros en el footer
            $('#mydatatable tfoot th').each(function () {
                $(this).html('<input type="text" class="form-control form-control-sm" placeholder="Buscar..." />');
            });

            var table = $('#mydatatable').DataTable({
                "dom": 'Bfrtip',
                "responsive": true,
                "language": {
                    "url": "https://cdn.datatables.net/plug-ins/1.10.19/i18n/Spanish.json"
                },
                "order": [[0, "asc"]],
                "buttons": ['csv', 'excel', 'pdf', 'print']
            });

            // Lógica de filtrado por columna
            table.columns().every(function () {
                var that = this;
                $('input', this.footer()).on('keyup change', function () {
                    if (that.search() !== this.value) {
                        that.search(this.value).draw();
                    }
                });
            });
        });
    </script>
</div>

<%- include("template/footer") %>
