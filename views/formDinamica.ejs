<%- include("template/cabecera", {tituloWeb: "Consultar Evento"}) %>

    <div class="container col-sm-8 mt-5">
      <h1 class="my-5">Consultar Estadísticas de Evento</h1>
        <!-- Ajustamos el action para que coincida con tu ruta de estadísticas -->
        <form id="formularioDinamico" method="POST" action="/estadisticas/buscar">
            <div class="mb-3">
                <label for="inputEvento" class="form-label">Escriba el nombre exacto del evento</label>
                <input type="text" 
                       placeholder="Ej: Mr. Región Norte 2022" 
                       class="form-control my-2 col-sm-8" 
                       name="nombre_evento" 
                       id="inputEvento" 
                       required>
            </div>
            
            <button class="btn btn-primary btn-block my-3 col-sm-8" type="submit" id="botonAgregar">
                Consultar Categorías
            </button> 
        </form>

        <div class="mt-4 p-3 bg-light border rounded">
            <small class="text-muted">
                <strong>Nota:</strong> Este formulario buscará todas las categorías asociadas al nombre del evento ingresado en la tabla <code>eventos</code> de Supabase.
            </small>
        </div>
    </div>

<%- include("template/footer") %>
