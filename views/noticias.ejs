<%- include("template/cabecera", {tituloWeb: "Noticias FDFF"}) %>

<div class="container-fluid mt-4">
    <h1 class="text-center mb-5 fw-bold">Actualidad y Noticias FDFF</h1>

    <!-- Usamos una fila de Bootstrap con wrap para que sea responsivo -->
    <div class="row g-4 justify-content-center">

        <!-- Carrusel 1: Talleres y Donaciones -->
        <div class="col-12 col-md-6 col-lg-4">
            <div id="carouselNoticias1" class="carousel slide shadow rounded overflow-hidden" data-bs-ride="carousel">
                <div class="carousel-indicators">
                    <button type="button" data-bs-target="#carouselNoticias1" data-bs-slide-to="0" class="active"></button>
                    <button type="button" data-bs-target="#carouselNoticias1" data-bs-slide-to="1"></button>
                    <button type="button" data-bs-target="#carouselNoticias1" data-bs-slide-to="2"></button>
                </div>
                <div class="carousel-inner">
                    <div class="carousel-item active">
                        <img src="/img/certific seminario.jpeg" class="d-block w-100" alt="Taller" style="height: 300px; object-fit: cover;">
                        <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded">
                            <h5>Taller de Jueces</h5>
                            <p>Entrega Certificados 2021</p>
                        </div>
                    </div>
                    <div class="carousel-item">
                        <img src="/img/Clara trofeo.jpeg" class="d-block w-100" alt="Donación" style="height: 300px; object-fit: cover;">
                        <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded">
                            <h5>Vitasalud</h5>
                            <p>Donación Trofeo Absoluto CAC</p>
                        </div>
                    </div>
                    <div class="carousel-item">
                        <img src="/img/ejecutivo2.jpeg" class="d-block w-100" alt="Reunión" style="height: 300px; object-fit: cover;">
                        <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded">
                            <h5>Comité FDFF</h5>
                            <p>Reunión Ordinaria</p>
                        </div>
                    </div>
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#carouselNoticias1" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#carouselNoticias1" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>
            </div>
        </div>

        <!-- Carrusel 2: Eventos y Jueces -->
        <div class="col-12 col-md-6 col-lg-4">
            <div id="carouselNoticias2" class="carousel slide shadow rounded overflow-hidden" data-bs-ride="carousel">
                <div class="carousel-indicators">
                    <button type="button" data-bs-target="#carouselNoticias2" data-bs-slide-to="0" class="active"></button>
                    <button type="button" data-bs-target="#carouselNoticias2" data-bs-slide-to="1"></button>
                    <button type="button" data-bs-target="#carouselNoticias2" data-bs-slide-to="2"></button>
                </div>
                <div class="carousel-inner">
                    <div class="carousel-item active">
                        <img src="/img/juecesMundial.jpg" class="d-block w-100" alt="Mundial" style="height: 300px; object-fit: cover;">
                        <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded">
                            <h5>Mundial Junior & Master</h5>
                            <p>Reconocimiento IFBB</p>
                        </div>
                    </div>
                    <div class="carousel-item">
                        <img src="/img/juecesRegion.jpg" class="d-block w-100" alt="Región" style="height: 300px; object-fit: cover;">
                        <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded">
                            <h5>Mr. Región Norte</h5>
                            <p>Santiago de los Caballeros</p>
                        </div>
                    </div>
                    <div class="carousel-item">
                        <img src="/img/juecesDFC.jpg" class="d-block w-100" alt="DFC" style="height: 300px; object-fit: cover;">
                        <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded">
                            <h5>Evento DFC</h5>
                            <p>Santo Domingo, RD</p>
                        </div>
                    </div>
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#carouselNoticias2" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#carouselNoticias2" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>
            </div>
        </div>

        <!-- Carrusel 3: Delegaciones -->
        <div class="col-12 col-md-6 col-lg-4">
            <div id="carouselNoticias3" class="carousel slide shadow rounded overflow-hidden" data-bs-ride="carousel">
                <div class="carousel-indicators">
                    <button type="button" data-bs-target="#carouselNoticias3" data-bs-slide-to="0" class="active"></button>
                    <button type="button" data-bs-target="#carouselNoticias3" data-bs-slide-to="1"></button>
                    <button type="button" data-bs-target="#carouselNoticias3" data-bs-slide-to="2"></button>
                </div>
                <div class="carousel-inner">
                    <div class="carousel-item active">
                        <img src="/img/fronteraHaiti.jpg" class="d-block w-100" alt="Frontera" style="height: 300px; object-fit: cover;">
                        <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded">
                            <h5>Hacia Haití</h5>
                            <p>Delegación en Frontera</p>
                        </div>
                    </div>
                    <div class="carousel-item">
                        <img src="/img/enHaiti.jpg" class="d-block w-100" alt="Haití" style="height: 300px; object-fit: cover;">
                        <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded">
                            <h5>Desde Haití</h5>
                            <p>Hospitalidad Haitiana</p>
                        </div>
                    </div>
                    <div class="carousel-item">
                        <img src="/img/teamColombia.jpg" class="d-block w-100" alt="Colombia" style="height: 300px; object-fit: cover;">
                        <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded">
                            <h5>Team Colombia</h5>
                            <p>Representación Dominicana</p>
                        </div>
                    </div>
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#carouselNoticias3" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#carouselNoticias3" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>
            </div>
        </div>

    </div>
</div>

<%- include("template/footer") %>
