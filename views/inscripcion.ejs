<%- include("template/cabecera", {tituloWeb: "Panel de Inscripción"}) %>

<!-- SECCIÓN 1: Seleccionar Atleta para Inscribir -->
<div class="container divGeneral border border-1 border-dark p-2 col-10" style="min-height: 41vh;">
    <div class="table-responsive col-12 mt-0 pt-0">     
        <h1 class="my-3">Inscripción a Evento</h1>
       
        <table class="records_list table table-striped table-bordered border-dark table-hover" id="mydatatable">
            <thead>
                <tr class="table-blue text-white"> 
                    <th scope="col" class="bg-primary">Cédula</th>
                    <th scope="col" class="bg-primary">Nombre</th>  
                    <th scope="col" class="bg-primary">IDFDFF</th>
                    <th scope="col" class="bg-primary">Acción</th>
                </tr>
            </thead>
            <tbody>
                <% if (arrayAtletas.length > 0) { %>
                    <% arrayAtletas.forEach(atleta => { %>
                        <tr>
                            <td class="col-sm-3"><%= atleta.cedula %></td>
                            <td class="col-sm-8 fs-4"><%= atleta.nombre %></td>
                            <th class="col-sm-2" scope="row"><%= atleta.idfdff %></th>
                            <!-- Cambio: atleta.id (Supabase) -->
                            <td><a href="inscripcion/<%= atleta.id %>" class="btn btn-warning btn-sm">Inscribir</a></td>
                        </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<!-- SECCIÓN 2: Listado de Competidores por Categoría (Para asignar Números) -->
<div class="imprInsc container table-responsive col-10 mx-auto mt-5 pt-0">     
    <div class="text-center mb-4">
        <h1 class="fw-bold text-dark">Listado de Competidores Inscritos</h1>
        <p class="text-muted">Asigne los números de competidor y guarde los cambios</p>
    </div>

    <form action="/inscripcion/asignar-numeros" method="POST">
        <div id="mitabla">
            <% if (arrayCategorias.length > 0) { %>
                <% arrayCategorias.forEach(categoria => { %>

                <table class="table table-bordered border-dark border-3 mb-5">
                    <thead>
                        <tr class="table-dark">
                            <th class="text-center" style="width: 10%;"><%= categoria.salida %></th> 
                            <th colspan="4" class="fs-4 text-center"><%= categoria.categoria %> - <%= categoria.nombre %></th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="fw-bold bg-light text-center">
                            <td style="width: 15%;">No. Competidor</td>
                            <td>Atleta</td>
                            <td>Edad</td>
                            <td>Peso</td>
                            <td>Estatura</td>
                        </tr>
                        
                        <!-- Supabase: Los competidores vienen como array dentro de la categoria -->
                        <% if (categoria.Competidor && categoria.Competidor.length > 0) { %>
                            <% categoria.Competidor.forEach(comp => { %>
                                <tr class="align-middle">
                                    <td class="p-0">
                                        <input name="Numero" value="<%= comp.numero_competidor %>" 
                                               class="form-control text-center border-0 fw-bold" 
                                               type="number" placeholder="---">
                                        
                                        <!-- Inputs ocultos para procesar el POST masivo -->
                                        <input type="hidden" name="IdCompetidor" value="<%= comp.id %>">
                                        <input type="hidden" name="IdCat" value="<%= categoria.id %>">
                                    </td>
                                    <td class="fs-5 fw-bold"><%= comp.nombre %></td>
                                    <td class="text-center"><%= comp.edad || '--' %></td>
                                    <td class="text-center"><%= comp.peso_real || '--' %> kg</td>
                                    <td class="text-center"><%= comp.estatura_real || '--' %> cm</td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="5" class="text-center text-muted">Sin competidores aún</td></tr>
                        <% } %>
                    </tbody>
                </table>

                <% }) %>
            <% } %>
        </div>

        <button id="btnInscripcion" class="btn btn-success btn-lg w-100 mb-5" type="submit">
            Guardar Números de Competidor
        </button>
    </form>
</div>

<script type="text/javascript">
    $(document).ready(function () {
        // Inicialización de DataTable para la tabla de atletas (arriba)
        var table = $('#mydatatable').DataTable({
            "dom": 'Bfrtip',
            "language": { "url": "https://cdn.datatables.net/plug-ins/1.10.19/i18n/Spanish.json" },
            "buttons": ['excel', 'pdf']
        });
    });
</script>

<%- include("template/footer") %>
