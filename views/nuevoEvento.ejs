<%- include("template/cabecera", {tituloWeb: "Configurar Evento"}) %>

<div class="container" style="margin-top: 2vh;">
    <% if (error) { %>
        <div class="alert alert-danger">
            <%= mensaje %>
            <a href="/inscripcion" class="btn btn-warning d-block mt-2">Volver a Inscripción</a>
        </div>
    <% } %>

    <% if (!error) { %>
        <div class="card p-4 shadow-sm border-primary mb-5">
            <label class="fs-1 fw-bold text-primary mb-3">Crear Evento</label>
            
            <input class="form-control form-control-lg mb-4 border-primary" 
                   type="text" 
                   placeholder="Nombre del Evento (Ej: Mr. Region Norte 2024)" 
                   id="input_evento_maestro">

            <div class="mb-4 row align-items-center">
                <label for="buscar" class="fs-5 fw-bold col-auto">Buscar Categoría:</label>
                <div class="col-sm-4">
                    <input type="text" placeholder="Filtrar..." class="form-control" id="buscador_intern">
                </div>
            </div>

            <!-- Listado de Categorías Disponibles -->
            <div class="container mt-2 col-12 bg-white border rounded shadow-sm">
                <div class="row bg-primary text-white p-2 fw-bold text-center rounded-top"> 
                    <div class="col-9 text-start">Categorías Disponibles</div>
                    <div class="col-1 small">Edad</div>
                    <div class="col-1 small">Peso</div>
                    <div class="col-1 small">Est.</div>
                </div>
                
                <div class="overflow-auto" style="max-height: 350px;">
                    <% if (arrayCategorias.length > 0) { %>
                        <% arrayCategorias.forEach((categoria, index) => { %>
                            <div class="row border-bottom p-2 align-items-center fila-categoria" data-nombre="<%= categoria.nombre.toLowerCase() %>"> 
                                <div class="col-9 form-check">
                                    <input class="form-check-input check-selector" 
                                           type="checkbox" 
                                           value="<%= categoria.nombre %>" 
                                           id="cat_<%= index %>"
                                           data-index="<%= index %>"
                                           data-json='<%= JSON.stringify(categoria) %>'>
                                    <label class="form-check-label fw-bold" for="cat_<%= index %>">
                                        <%= categoria.nombre %>
                                    </label>
                                </div> 
                                <div class="col-1 text-center small text-muted"><%= categoria.desde_edad %>/<%= categoria.hasta_edad %></div>
                                <div class="col-1 text-center small text-muted"><%= categoria.desde_peso %>/<%= categoria.hasta_peso %></div>
                                <div class="col-1 text-center small text-muted"><%= categoria.desde_estatura %>/<%= categoria.hasta_estatura %></div>
                            </div>                   
                        <% }) %>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- FORMULARIO FINAL DE ENVÍO -->
        <form id="formEventoFinal" action="/categorias/nuevoEvento" method="POST" class="card p-4 shadow border-success mb-5">
            <div class="row mb-3 align-items-center">
                <label class="col-sm-2 col-form-label fs-3">Evento:</label>
                <div class="col-sm-10">
                    <input type="text" id="nombre_evento_hidden" name="NombreEvento" class="border-0 fs-3 fw-bold text-primary bg-white w-100" readonly required>
                </div>
            </div>

            <h4 class="mb-4 text-success fw-bold">Confirmar Selección y Orden de Salida:</h4>
            
            <!-- Contenedores donde se inyectan los inputs dinámicamente -->
            <div id="resultado_principal" class="mb-4"></div>
            
            <!-- Contenedores ocultos para los metadatos -->
            <div id="res_modalidad" class="d-none"></div>
            <div id="res_genero" class="d-none"></div>
            <div id="res_disciplina" class="d-none"></div>
            <div id="res_division" class="d-none"></div>
            <div id="res_edad_desde" class="d-none"></div>
            <div id="res_edad_hasta" class="d-none"></div>
            <div id="res_peso_desde" class="d-none"></div>
            <div id="res_peso_hasta" class="d-none"></div>
            <div id="res_estatura_desde" class="d-none"></div>
            <div id="res_estatura_hasta" class="d-none"></div>

            <button class="btn btn-success btn-lg w-100 mt-4 shadow" type="submit">
                Registrar Evento y Categorías Seleccionadas
            </button>
        </form>
    <% } %>
</div>

<script>
    // 1. Sincronizar el nombre del evento
    const inputMaster = document.getElementById('input_evento_maestro');
    const inputHidden = document.getElementById('nombre_evento_hidden');
    inputMaster.addEventListener('input', () => { inputHidden.value = inputMaster.value; });

    // 2. Buscador de categorías
    const buscador = document.getElementById('buscador_intern');
    buscador.addEventListener('keyup', () => {
        const term = buscador.value.toLowerCase();
        document.querySelectorAll('.fila-categoria').forEach(fila => {
            fila.style.display = fila.dataset.nombre.includes(term) ? 'flex' : 'none';
        });
    });

    // 3. Lógica dinámica de selección
    document.addEventListener('change', (e) => {
        if (e.target.classList.contains('check-selector')) {
            const index = e.target.dataset.index;
            const cat = JSON.parse(e.target.dataset.json);
            
            if (e.target.checked) {
                // Crear bloque visible de Orden de Salida
                const blockHTML = `
                    <div class="row align-items-center mb-2 bg-light p-2 rounded border" id="item_${index}">
                        <div class="col-md-2">
                            <input type="number" name="Salida" class="form-control text-center fw-bold border-primary" placeholder="Orden" required>
                        </div>
                        <div class="col-md-10">
                            <input type="text" name="Categorias" value="${cat.nombre}" class="form-control-plaintext fw-bold" readonly>
                        </div>
                        <!-- Inputs ocultos para Supabase -->
                        <input type="hidden" name="Modalidad" value="${cat.modalidad}" id="mod_${index}">
                        <input type="hidden" name="Genero" value="${cat.genero}" id="gen_${index}">
                        <input type="hidden" name="Disciplina" value="${cat.disciplina}" id="dis_${index}">
                        <input type="hidden" name="Division" value="${cat.division}" id="div_${index}">
                        <input type="hidden" name="DesdeEdad" value="${cat.desde_edad}" id="ed_${index}">
                        <input type="hidden" name="HastaEdad" value="${cat.hasta_edad}" id="eh_${index}">
                        <input type="hidden" name="DesdePeso" value="${cat.desde_peso}" id="pd_${index}">
                        <input type="hidden" name="HastaPeso" value="${cat.hasta_peso}" id="ph_${index}">
                        <input type="hidden" name="DesdeEstatura" value="${cat.desde_estatura}" id="std_${index}">
                        <input type="hidden" name="HastaEstatura" value="${cat.hasta_estatura}" id="sth_${index}">
                    </div>`;
                document.getElementById('resultado_principal').insertAdjacentHTML('beforeend', blockHTML);
            } else {
                // Eliminar el bloque si se desmarca
                const el = document.getElementById(`item_${index}`);
                if (el) el.remove();
            }
        }
    });
</script>

<%- include("template/footer") %>
