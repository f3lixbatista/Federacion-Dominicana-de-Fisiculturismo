# ============================================================
# FEDERACIÓN DOMINICANA DE FISICULTURISMO - Variables de Entorno
# Copia este archivo como .env y completa los valores reales.
# NUNCA commitees el archivo .env al repositorio.
# ============================================================

# Puerto del servidor (por defecto 3000)
PORT=3000

# Supabase - Obtén estos valores en: https://supabase.com/dashboard/project/[tu-proyecto]/settings/api
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu_clave_anonima_aqui
SUPABASE_SERVICE_ROLE_KEY=tu_clave_service_role_aqui

# Nombre de la cookie de sesión (opcional, default: sb-access-token)
SUPABASE_SESSION_COOKIE_NAME=sb-access-token

# VAPID Keys para Notificaciones Push Web
# Genera tus propias claves VAPID con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=tu_clave_vapid_publica_aqui
VAPID_PRIVATE_KEY=tu_clave_vapid_privada_aqui
VAPID_EMAIL=mailto:tu@email.com

# PIN para el modo Kiosko (pantalla de espera en eventos)
KIOSKO_PIN=tu_pin_aqui

# Ambiente: 'development' o 'production'
NODE_ENV=development
